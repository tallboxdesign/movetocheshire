---
interface SpokeLink {
  label: string;
  href: string;
  description?: string;
}

interface RelatedHub {
  label: string;
  href: string;
}

interface Props {
  tag: string;
  breadcrumb?: string;
  title: string;
  description: string;
  spokes: SpokeLink[];
  relatedHubs?: RelatedHub[];
  accentColor?: string;
}

const { tag, breadcrumb, title, description, spokes, relatedHubs, accentColor = '#3D5A3E' } = Astro.props;
const breadcrumbLabel = breadcrumb || tag;
---

<div style="background-color: #F9F7F4;">
    <!-- Breadcrumb -->
    <div class="section-pad" style="padding-top: 20px; padding-bottom: 0;">
      <div class="section-inner">
        <nav aria-label="Breadcrumb" style="font-family: Inter, Arial, sans-serif; font-size: 13px; color: #999999;">
          <a href="/" style="color: #999999; text-decoration: none;">Home</a>
          <span style="margin: 0 8px;">/</span>
          <span style="color: #1C1C1E;">{breadcrumbLabel}</span>
        </nav>
      </div>
    </div>

    <!-- Hero -->
    <section
      class="section-pad"
      style="background-color: #F9F7F4; padding-top: 40px; border-bottom: 1px solid #E5E0D8;"
    >
      <div class="section-inner" style="max-width: 720px;">
        <span
          style={`font-family: Inter, Arial, sans-serif; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: ${accentColor}; display: block; margin-bottom: 14px;`}
        >
          {tag}
        </span>

        <h1
          style="font-family: Georgia, serif; font-size: clamp(28px, 4.5vw, 44px); font-weight: 700; color: #1C1C1E; line-height: 1.15; letter-spacing: -0.02em; margin: 0 0 20px 0;"
        >
          {title}
        </h1>

        <p
          style="font-family: Inter, Arial, sans-serif; font-size: 18px; line-height: 1.7; color: #444444; margin: 0;"
        >
          {description}
        </p>
      </div>
    </section>

    <section class="section-pad" style="background-color: #FFFFFF; border-bottom: 1px solid #E5E0D8;">
      <div class="section-inner">
        <slot />
      </div>
    </section>

    <section
      class="section-pad"
      style="background-color: #F2EFE9; border-bottom: 1px solid #E5E0D8;"
    >
      <div class="section-inner">
        <span class="section-label">Guides in this section</span>
        <h2
          style="font-family: Georgia, serif; font-size: clamp(22px, 3vw, 30px); font-weight: 700; color: #1C1C1E; line-height: 1.2; letter-spacing: -0.01em; margin: 0 0 40px 0;"
        >
          Browse all Cheshire {breadcrumbLabel.toLowerCase().replace(/ guide$/i, '')} guides
        </h2>
        <p style="font-family: Inter, Arial, sans-serif; font-size: 15px; line-height: 1.7; color: #555555; margin: -24px 0 32px 0; max-width: 640px;">
          Each Cheshire guide covers prices, schools, commute times, and honest trade-offs sourced from ONS, Rightmove, and National Rail data.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {spokes.map((spoke) => (
            <a href={spoke.href} style="text-decoration: none;">
              <article class="pillar-card" style="height: 100%; display: flex; flex-direction: column;">
                <h3
                  style="font-family: Inter, Arial, sans-serif; font-size: 17px; font-weight: 700; color: #1C1C1E; line-height: 1.3; margin: 0 0 10px 0;"
                >
                  {spoke.label}
                </h3>
                {spoke.description && (
                  <p
                    style="font-family: Inter, Arial, sans-serif; font-size: 14px; line-height: 1.6; color: #777777; margin: 0 0 20px 0; flex-grow: 1;"
                  >
                    {spoke.description}
                  </p>
                )}
                <span
                  style={`font-family: Inter, Arial, sans-serif; font-size: 13px; font-weight: 600; color: ${accentColor}; border-bottom: 1px solid ${accentColor}40; padding-bottom: 1px;`}
                >
                  Read Cheshire guide &rarr;
                </span>
              </article>
            </a>
          ))}
        </div>
      </div>
    </section>

    {relatedHubs && relatedHubs.length > 0 && (
      <section class="section-pad" style="background-color: #F9F7F4;">
        <div class="section-inner">
          <span class="section-label">Related Cheshire guides</span>
          <div style="display: flex; flex-wrap: wrap; gap: 12px; margin-top: 16px;">
            {relatedHubs.map((hub) => (
              <a
                href={hub.href}
                style="font-family: Inter, Arial, sans-serif; font-size: 13px; font-weight: 600; color: #3D5A3E; border: 1px solid #3D5A3E; padding: 9px 18px; text-decoration: none; transition: background-color 0.15s ease, color 0.15s ease; display: inline-block;"
              >
                {hub.label}
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
</div>
