---
const quickLinks = [
  { label: 'Where to Live', href: '/where-to-live' },
  { label: 'House Prices', href: '/house-prices' },
  { label: 'Schools', href: '/schools' },
  { label: 'Commuting', href: '/commuting' },
  { label: 'Is It Worth It?', href: '/lifestyle' },
  { label: 'Investment', href: '/investment', highlight: true },
];
---

<section
  aria-labelledby="hero-heading"
  class="section-pad"
  style="background-color: #F9F7F4; overflow: hidden;"
>
  <div style="max-width: 1200px; margin: 0 auto; padding: 48px 20px 0 20px;">
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(min(100%, 400px), 1fr)); gap: 48px; align-items: flex-start;">
      <!-- LEFT COLUMN: Text and Value Prop -->
      <div style="max-width: 600px;">
        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 24px;">
          <div style="width: 28px; height: 2px; background-color: #3D5A3E; flex-shrink: 0;" />
          <span style="font-family: Inter, Arial, sans-serif; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: #3D5A3E;">
            Independent Relocation Intelligence - Cheshire, England
          </span>
        </div>

        <h1
          id="hero-heading"
          style="font-family: Georgia, serif; font-size: clamp(36px, 5vw, 56px); font-weight: 700; line-height: 1.1; color: #1C1C1E; letter-spacing: -0.02em; margin-bottom: 32px;"
        >
          Moving to Cheshire?
        </h1>

        <!-- PUNCHY DATA POINTS (Concept 3) -->
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(min(100%, 220px), 1fr)); gap: 24px; margin-bottom: 40px;">
          <div>
            <div style="font-family: Inter, Arial, sans-serif; font-size: 28px; font-weight: 700; color: #3D5A3E; margin-bottom: 4px; line-height: 1;">£314k</div>
            <div style="font-family: Inter, Arial, sans-serif; font-size: 13px; color: #555555; line-height: 1.4; padding-right: 12px;">Average price (44% below London's £551k)</div>
          </div>
          <div>
            <div style="font-family: Inter, Arial, sans-serif; font-size: 28px; font-weight: 700; color: #3D5A3E; margin-bottom: 4px; line-height: 1;">112</div>
            <div style="font-family: Inter, Arial, sans-serif; font-size: 13px; color: #555555; line-height: 1.4; padding-right: 12px;">Outstanding-rated schools</div>
          </div>
          <div>
            <div style="font-family: Inter, Arial, sans-serif; font-size: 28px; font-weight: 700; color: #3D5A3E; margin-bottom: 4px; line-height: 1;">17-55m</div>
            <div style="font-family: Inter, Arial, sans-serif; font-size: 13px; color: #555555; line-height: 1.4; padding-right: 12px;">Commute times to Manchester</div>
          </div>
          <div>
            <div style="font-family: Inter, Arial, sans-serif; font-size: 28px; font-weight: 700; color: #3D5A3E; margin-bottom: 4px; line-height: 1;">10</div>
            <div style="font-family: Inter, Arial, sans-serif; font-size: 13px; color: #555555; line-height: 1.4; padding-right: 12px;">Towns compared side-by-side</div>
          </div>
        </div>

        <div style="border-left: 3px solid #3D5A3E; background-color: rgba(61, 90, 62, 0.04); padding: 16px 20px; margin-bottom: 40px;">
          <p style="font-family: Inter, Arial, sans-serif; font-size: 15px; font-weight: 600; color: #1C1C1E; margin: 0; margin-bottom: 4px;">
            No estate agent spin. No sponsored content. Just answers.
          </p>
          <p style="font-family: Inter, Arial, sans-serif; font-size: 13px; color: #666666; margin: 0;">
            Data sourced from ONS, Ofsted, and National Rail. Updated Feb 2026.
          </p>
        </div>

        <nav aria-label="Page sections" style="display: flex; flex-wrap: wrap; gap: 10px;">
          {quickLinks.map((link) => {
            const isHighlight = 'highlight' in link && link.highlight;
            return (
              <a
                href={link.href}
                class={`hero-link ${isHighlight ? 'hero-link--highlight' : ''}`}
                style={`font-family: Inter, Arial, sans-serif; font-size: 13px; font-weight: 600; color: ${isHighlight ? '#C4933F' : '#3D5A3E'}; border: 1px solid ${isHighlight ? 'rgba(196,147,63,0.5)' : '#3D5A3E'}; padding: 9px 18px; text-decoration: none; letter-spacing: 0.01em; transition: background-color 0.15s ease, color 0.15s ease; display: inline-block;`}
              >
                {link.label}
              </a>
            );
          })}
        </nav>

        <!-- VALUE PROPOSITION CHECKLIST -->
        <div style="margin-top: 48px; border-top: 1px solid #E5E0D8; padding-top: 32px;">
          <p style="font-family: Inter, Arial, sans-serif; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #888; margin-bottom: 16px; margin-top: 0;">
            Why use our intelligence?
          </p>
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 16px;">
            <li style="display: flex; align-items: flex-start; gap: 12px;">
              <svg style="color: #3D5A3E; width: 18px; height: 18px; flex-shrink: 0; margin-top: 1px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
              <span style="font-family: Inter, Arial, sans-serif; font-size: 14px; color: #444; line-height: 1.4;"><strong>Instantly match</strong> your budget to realistic properties across 10 premium Cheshire towns.</span>
            </li>
            <li style="display: flex; align-items: flex-start; gap: 12px;">
              <svg style="color: #3D5A3E; width: 18px; height: 18px; flex-shrink: 0; margin-top: 1px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
              <span style="font-family: Inter, Arial, sans-serif; font-size: 14px; color: #444; line-height: 1.4;"><strong>Bypass estate agent spin</strong> with hard facts on school catchments and actual commute times.</span>
            </li>
            <li style="display: flex; align-items: flex-start; gap: 12px;">
              <svg style="color: #3D5A3E; width: 18px; height: 18px; flex-shrink: 0; margin-top: 1px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
              <span style="font-family: Inter, Arial, sans-serif; font-size: 14px; color: #444; line-height: 1.4;"><strong>Save 40+ hours</strong> of stressful Rightmove scrolling and spreadsheets.</span>
            </li>
          </ul>
        </div>

        <!-- TRUST SIGNAL / EXPERT QUOTE -->
        <blockquote style="margin-top: 48px; position: relative; padding-left: 20px;">
          <div style="position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background-color: #C4933F;"></div>
          <svg style="color: rgba(196,147,63,0.3); width: 28px; height: 28px; position: absolute; left: 16px; top: -10px; z-index: -1;" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" /></svg>
          <p style="font-family: Georgia, serif; font-size: 15px; font-style: italic; color: #555555; line-height: 1.6; margin: 0 0 12px 0;">
            "The Cheshire market is driven by fundamentals: quality of life, access to good schools, and strong transport links. Flexible working has been a game-changer [for the region]."
          </p>
          <cite style="display: flex; align-items: center; gap: 10px; font-style: normal;">
            <div style="width: 32px; height: 32px; background-color: #1C1C1E; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-family: Inter, Arial, sans-serif; font-size: 12px; font-weight: 700;">CK</div>
            <div>
              <div style="font-family: Inter, Arial, sans-serif; font-size: 13px; font-weight: 700; color: #1C1C1E;">Charlie Kannreuther</div>
              <div style="font-family: Inter, Arial, sans-serif; font-size: 11px; color: #888888; text-transform: uppercase; letter-spacing: 0.05em;">Head of North West Residential, Savills</div>
            </div>
          </cite>
        </blockquote>

      </div>

      <!-- RIGHT COLUMN: Interactive Tool (Slot) -->
      <div style="position: relative; z-index: 10;">
        <slot />
      </div>
    </div>
  </div>
</section>

<style>
  .hero-link:hover {
    background-color: #3D5A3E !important;
    color: #FFFFFF !important;
  }
  .hero-link--highlight:hover {
    background-color: #C4933F !important;
    color: #FFFFFF !important;
  }
</style>
