---
const sources = [
  'ONS House Price Index',
  'Ofsted',
  'National Rail',
  'Cheshire East Council',
  'Rightmove',
  'Cheshire Constabulary',
];
---

<section
  aria-label="Data freshness and update schedule"
  style="background-color: #FAFAF8; border-top: 1px solid #E5E0D8; border-bottom: 1px solid #E5E0D8; padding: 24px 20px;"
>
  <div
    class="section-inner"
    style="display: flex; flex-direction: column; gap: 16px;"
  >
    <div style="display: flex; align-items: center; gap: 16px;">
      <div
        style="width: 36px; height: 36px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; background-color: rgba(61, 90, 62, 0.08);"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#3D5A3E" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
      </div>
      <div>
        <p style="font-family: Inter, Arial, sans-serif; font-size: 14px; color: #1C1C1E; margin: 0 0 2px 0; font-weight: 600;">
          Data reviewed quarterly
        </p>
        <p style="font-family: Inter, Arial, sans-serif; font-size: 12.5px; color: #888888; margin: 0;">
          <strong style="color: #666666; font-weight: 600;">Last reviewed: February 2026.</strong>{' '}
          <strong style="color: #666666; font-weight: 600;">Next update: May 2026.</strong>
        </p>
      </div>
    </div>

    <div style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap;">
      <span
        style="font-family: Inter, Arial, sans-serif; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #AAAAAA; margin-right: 4px;"
      >
        Sources:
      </span>
      {sources.map((source, i) => (
        <span style="font-family: Inter, Arial, sans-serif; font-size: 12px; color: #888888;">
          {source}{i < sources.length - 1 ? ' \u00B7' : ''}
        </span>
      ))}
    </div>
  </div>
</section>
