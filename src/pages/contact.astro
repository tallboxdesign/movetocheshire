---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.tsx';

const contactPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  url: 'https://movetocheshire.uk/contact',
  name: 'Contact Us | movetocheshire.uk',
  description: 'Get in touch with movetocheshire.uk. Data corrections, area questions, press enquiries welcome.',
  inLanguage: 'en-GB',
  isPartOf: { '@type': 'WebSite', name: 'movetocheshire.uk', url: 'https://movetocheshire.uk' },
  mainEntity: { '@id': 'https://movetocheshire.uk/#person-tom-cairns' },
};

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': 'https://movetocheshire.uk/#person-tom-cairns',
  name: 'Tom Cairns',
  description: 'Independent researcher specialising in Cheshire relocation data. Based in the North West, researching since 2023.',
  url: 'https://movetocheshire.uk/contact',
  areaServed: { '@type': 'AdministrativeArea', name: 'Cheshire' },
  knowsAbout: ['Cheshire property market', 'Cheshire town comparisons', 'North West relocation', 'School catchment areas in Cheshire'],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://movetocheshire.uk' },
    { '@type': 'ListItem', position: 2, name: 'Contact', item: 'https://movetocheshire.uk/contact' },
  ],
};
---

<BaseLayout
  title="Contact Us | movetocheshire.uk"
  description="Get in touch with movetocheshire.uk. Data corrections, area questions, press enquiries welcome. Independent Cheshire relocation research."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(contactPageSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <!-- Hero -->
  <section style="max-width: 1200px; margin: 0 auto; padding: 52px 24px 36px; width: 100%;">
    <div style="max-width: 640px;">
      <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 18px;">
        <a href="/" style="font-size: 12px; color: #999; text-decoration: none;">Home</a>
        <span style="color: #ccc; font-size: 12px;">/</span>
        <span style="font-size: 12px; color: #555;">Contact</span>
      </div>
      <h1 style="font-family: Georgia, serif; font-size: clamp(28px, 4vw, 42px); font-weight: 700; color: #1a2332; line-height: 1.15; letter-spacing: -0.02em; margin: 0 0 16px 0;">
        Get in Touch
      </h1>
      <p style="font-size: 17px; line-height: 1.7; color: #3d4c5c; margin: 0; max-width: 560px;">
        movetocheshire.uk is an independent research site. There's no office - just one person trying to make Cheshire relocation research actually useful.
      </p>
    </div>
  </section>

  <!-- Two-column layout -->
  <section style="max-width: 1200px; margin: 0 auto; padding: 0 24px 80px; width: 100%; flex-grow: 1;">
    <div class="grid grid-cols-1 lg:grid-cols-2" style="gap: 64px; align-items: start;">

      <!-- Left - About -->
      <div>
        <span style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: #2d7a4f; display: block; margin-bottom: 16px;">
          About this site
        </span>
        <p style="font-size: 15px; line-height: 1.8; color: #3d4c5c; margin: 0 0 32px 0;">
          This site was built to fill a gap: most Cheshire relocation content is either estate agent marketing or generic listicles. Every page here is independently researched, data-cited, and written for people making a real decision about where to live - not for clicks.
        </p>

        <!-- Author card -->
        <div style="display: flex; align-items: flex-start; gap: 16px; padding: 20px; background-color: #f7f5f2; border-radius: 6px; margin-bottom: 32px;">
          <div style="width: 44px; height: 44px; border-radius: 50%; background-color: #e6f2eb; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            <span style="font-size: 14px; font-weight: 700; color: #2d7a4f;">TC</span>
          </div>
          <div>
            <p style="font-size: 15px; font-weight: 700; color: #1a2332; margin: 0 0 4px 0;">Tom Cairns</p>
            <p style="font-size: 13px; color: #6b7a8d; margin: 0; line-height: 1.55;">
              Based in the North West · Researching Cheshire relocation since 2023
            </p>
          </div>
        </div>

        <!-- Trust bullets -->
        <div style="margin-bottom: 32px; display: flex; flex-direction: column; gap: 10px;">
          {['All data independently sourced and cited', 'No estate agent affiliation', 'No financial advice'].map((item) => (
            <div style="display: flex; align-items: center; gap: 10px;">
              <div style="width: 20px; height: 20px; border-radius: 50%; background-color: #e6f2eb; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                  <path d="M2 6l3 3 5-5" stroke="#2d7a4f" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </div>
              <span style="font-size: 14px; color: #2a3442; font-weight: 500;">{item}</span>
            </div>
          ))}
        </div>

        <!-- What you can contact us about -->
        <div style="margin-bottom: 24px;">
          <p style="font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #1a2332; margin: 0 0 16px 0;">
            What you can contact us about
          </p>
          <div>
            {[
              { label: 'Data corrections', desc: 'Spotted an outdated figure? Let us know.' },
              { label: 'Area questions', desc: 'Specific question about a Cheshire town or neighbourhood.' },
              { label: 'Press or partnerships', desc: 'Journalists and relevant collaborations welcome.' },
            ].map((item, i) => (
              <div style={`padding: 14px 0; ${i < 2 ? 'border-bottom: 1px solid #e8e4de;' : ''}`}>
                <span style="font-size: 14px; font-weight: 700; color: #1a2332; display: block; margin-bottom: 2px;">{item.label}</span>
                <span style="font-size: 13.5px; color: #6b7a8d; line-height: 1.55;">{item.desc}</span>
              </div>
            ))}
          </div>
        </div>

        <p style="font-size: 12px; color: #aaa; margin: 0;">
          We can't provide financial, legal or estate agent advice.
        </p>
      </div>

      <!-- Right - Form -->
      <div>
        <ContactForm client:load />
      </div>

    </div>
  </section>
</BaseLayout>
