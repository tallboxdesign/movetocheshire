---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found | movetocheshire.uk"
  description="This page doesn't exist yet. Return to the homepage to browse available Cheshire relocation guides."
>
  <section class="section-pad">
    <div class="section-inner" style="max-width: 600px;">
      <span style="font-family: Inter, Arial, sans-serif; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: #3D5A3E; display: block; margin-bottom: 16px;">
        404
      </span>
      <h1 style="font-family: Georgia, serif; font-size: clamp(28px, 4vw, 42px); font-weight: 700; color: #1C1C1E; line-height: 1.15; letter-spacing: -0.02em; margin: 0 0 20px 0;">
        Page not found
      </h1>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 17px; line-height: 1.7; color: #555555; margin: 0 0 32px 0;">
        This page doesn't exist yet - it may be in preparation. Return to the homepage to browse available guides.
      </p>
      <a
        href="/"
        style="font-family: Inter, Arial, sans-serif; font-size: 14px; font-weight: 600; color: #3D5A3E; border: 1px solid #3D5A3E; padding: 12px 24px; text-decoration: none; display: inline-block;"
      >
        Back to homepage →
      </a>
    </div>
  </section>
</BaseLayout>
