---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HubLayout from '../../components/HubLayout.astro';

const spokes = [
  { label: 'Best Places to Live in Cheshire', href: '/where-to-live/best-places-cheshire', description: "A data-led ranking of Cheshire's most desirable towns and villages, weighing schools, commute times, prices, and quality of life." },
  { label: 'The Cheshire Golden Triangle', href: '/where-to-live/cheshire-golden-triangle', description: "Wilmslow, Alderley Edge, and Prestbury - what makes the Golden Triangle different, who lives there, and whether the premium is justified." },
  { label: 'Moving to Chester', href: '/where-to-live/chester', description: "The county's historic city - its own character, a distinct buyer profile, and a separate value proposition." },
];

const relatedHubs = [
  { label: 'Cheshire House Prices', href: '/house-prices' },
  { label: 'Cheshire Schools', href: '/schools' },
  { label: 'Cheshire Commuting', href: '/commuting' },
  { label: 'Cheshire Lifestyle', href: '/lifestyle' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'Is Cheshire expensive to live in?', acceptedAnswer: { '@type': 'Answer', text: 'It depends which part. Cheshire East averages £306,000 across all property types (ONS, November 2025), but the range spans from Crewe at £175,000 to Alderley Edge above £700,000. Day-to-day costs outside premium towns are broadly in line with the national average.' } },
    { '@type': 'Question', name: 'Is Cheshire a good place to raise a family?', acceptedAnswer: { '@type': 'Answer', text: 'Cheshire has a high density of Outstanding and Good Ofsted schools, particularly in Cheshire East, and most main towns have accessible parks, sports clubs, and youth facilities. The constraint is that outside larger towns, getting children to activities depends on car ownership.' } },
    { '@type': 'Question', name: 'What is the Golden Triangle in Cheshire?', acceptedAnswer: { '@type': 'Answer', text: 'The Golden Triangle refers to the area bounded by Wilmslow, Alderley Edge, and Prestbury - three towns in northeast Cheshire with the highest property prices, high-earning residents, and premium schools. Average prices exceed £490,000 in Wilmslow and £700,000 in Alderley Edge (Rightmove, Q4 2025).' } },
    { '@type': 'Question', name: 'How long is the commute from Cheshire to Manchester?', acceptedAnswer: { '@type': 'Answer', text: 'It varies by town. The fastest is Wilmslow at 17 minutes to Manchester Piccadilly (National Rail, 2025). Prestbury and Alderley Edge are 20 and 22 minutes. Macclesfield is 25 minutes. Chester is approximately 50 minutes.' } },
    { '@type': 'Question', name: 'Is it worth moving from London to Cheshire?', acceptedAnswer: { '@type': 'Answer', text: 'For most households selling in inner or mid London, the equity released is substantial - a London flat that sold for £600,000 buys a four-bedroom detached house in Wilmslow with money left over. The trade-offs are London\'s cultural density and, for those still commuting to London, a significant journey time.' } },
    { '@type': 'Question', name: 'What is the cost of living in Cheshire compared to London?', acceptedAnswer: { '@type': 'Answer', text: 'Housing is the main difference - Cheshire East averages £306,000 (ONS, November 2025) versus London\'s £551,294 (Land Registry, December 2025). Groceries, utilities, and everyday services are broadly comparable. Council tax Band D runs £2,332.61 in Cheshire East and £1,978.09 in Cheshire West and Chester (GOV.UK, 2025-26).' } },
  ],
};

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Where to Live in Cheshire?',
  description: 'Area-by-area comparisons of every major Cheshire town and village, with average prices, school data, and commute times.',
  url: 'https://movetocheshire.uk/where-to-live',
  dateModified: '2026-02-01',
  inLanguage: 'en-GB',
  spatialCoverage: { '@type': 'Place', name: 'Cheshire' },
  isPartOf: { '@type': 'WebSite', name: 'Move to Cheshire', url: 'https://movetocheshire.uk' },
};

const areaListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Cheshire residential areas compared',
  numberOfItems: 10,
  itemListElement: [
    { '@type': 'ListItem', position: 1, item: { '@type': 'Place', name: 'Alderley Edge', description: 'Average price above £700,000. Train to Manchester: 22 minutes.', containedInPlace: { '@type': 'AdministrativeArea', name: 'Cheshire East' } } },
    { '@type': 'ListItem', position: 2, item: { '@type': 'Place', name: 'Prestbury', description: 'Average price above £650,000. Train to Manchester: 20 minutes.', containedInPlace: { '@type': 'AdministrativeArea', name: 'Cheshire East' } } },
    { '@type': 'ListItem', position: 3, item: { '@type': 'Place', name: 'Wilmslow', description: 'Average price £490,000. Train to Manchester: 17 minutes.', containedInPlace: { '@type': 'AdministrativeArea', name: 'Cheshire East' } } },
    { '@type': 'ListItem', position: 4, item: { '@type': 'Place', name: 'Knutsford', description: 'Average price £430,000. Train to Manchester: 35 minutes.', containedInPlace: { '@type': 'AdministrativeArea', name: 'Cheshire East' } } },
    { '@type': 'ListItem', position: 5, item: { '@type': 'Place', name: 'Tarporley', description: 'Average price £380,000. Train to Manchester: 55 minutes (indirect).', containedInPlace: { '@type': 'AdministrativeArea', name: 'Cheshire West and Chester' } } },
    { '@type': 'ListItem', position: 6, item: { '@type': 'Place', name: 'Nantwich', description: 'Average price £295,000. Train to Manchester: 60 minutes (indirect).', containedInPlace: { '@type': 'AdministrativeArea', name: 'Cheshire East' } } },
    { '@type': 'ListItem', position: 7, item: { '@type': 'Place', name: 'Macclesfield', description: 'Average price £280,000. Train to Manchester: 25 minutes.', containedInPlace: { '@type': 'AdministrativeArea', name: 'Cheshire East' } } },
    { '@type': 'ListItem', position: 8, item: { '@type': 'Place', name: 'Chester', description: 'Average price £250,000. Train to Manchester: 50 minutes.', containedInPlace: { '@type': 'AdministrativeArea', name: 'Cheshire West and Chester' } } },
    { '@type': 'ListItem', position: 9, item: { '@type': 'Place', name: 'Northwich', description: 'Average price £220,000. Train to Manchester: 40 minutes.', containedInPlace: { '@type': 'AdministrativeArea', name: 'Cheshire West and Chester' } } },
    { '@type': 'ListItem', position: 10, item: { '@type': 'Place', name: 'Crewe', description: 'Average price £175,000. Train to Manchester: 55 minutes.', containedInPlace: { '@type': 'AdministrativeArea', name: 'Cheshire East' } } },
  ],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://movetocheshire.uk' },
    { '@type': 'ListItem', position: 2, name: 'Where to Live', item: 'https://movetocheshire.uk/where-to-live' },
  ],
};

const areas = [
  { area: 'Alderley Edge', price: '£700,000+', commute: '22 min', bestFor: 'Premium schools, Manchester exec commute' },
  { area: 'Prestbury', price: '£650,000+', commute: '20 min', bestFor: 'Village character, Golden Triangle access' },
  { area: 'Wilmslow', price: '£490,000', commute: '17 min', bestFor: 'Fastest commute, strong schools, most amenities' },
  { area: 'Knutsford', price: '£430,000', commute: '35 min', bestFor: 'Georgian centre, quieter pace, good schools' },
  { area: 'Tarporley', price: '£380,000', commute: '55 min (indirect)', bestFor: 'Rural feel, village life, home-working households' },
  { area: 'Nantwich', price: '£295,000', commute: '60 min (indirect)', bestFor: 'Market town character, lower price point' },
  { area: 'Macclesfield', price: '£280,000', commute: '25 min', bestFor: 'Value relative to commute time, improving centre' },
  { area: 'Chester', price: '£250,000', commute: '50 min', bestFor: 'City living, own employment base, London rail link' },
  { area: 'Northwich', price: '£220,000', commute: '40 min', bestFor: 'Affordable mid-county, improving offer' },
  { area: 'Crewe', price: '£175,000', commute: '55 min', bestFor: 'Lowest entry price, direct rail connections' },
];

const faqs = [
  {
    question: 'Is Cheshire expensive to live in?',
    answer: `Cheshire East averages £306,000 and Cheshire West averages £266,000 across all property types (Source: ONS, November 2025). The range spans from £175,000 in Crewe to above £700,000 in Alderley Edge. Cheshire East sits 5% above the national average; Cheshire West sits 8% below. Day-to-day costs outside premium towns are broadly national average, though Golden Triangle restaurants and independent schools push spending higher.`,
  },
  {
    question: 'Is Cheshire a good place to raise a family?',
    answer: `Cheshire East has 76 Outstanding Ofsted schools - 22% versus 16% nationally (Source: SNobe / Ofsted, 2024-25). Wilmslow, Knutsford, Macclesfield, Chester, and Nantwich have accessible parks, sports clubs, and youth facilities. The constraint: outside larger towns, getting children to activities depends on car ownership - public transport is limited outside the main rail corridors.`,
  },
  {
    question: 'What is the Golden Triangle in Cheshire?',
    answer: `The Golden Triangle is the area bounded by Wilmslow, Alderley Edge, and Prestbury in northeast Cheshire - the highest concentration of expensive property, high-earning residents, and premium schools in the county. Prices exceed £490,000 in Wilmslow and £700,000 in Alderley Edge (Rightmove, Q4 2025).`,
  },
  {
    question: 'How long is the commute from Cheshire to Manchester?',
    answer: `Wilmslow is the fastest Cheshire commute at 17 minutes to Manchester Piccadilly (Source: National Rail, 2025). Prestbury takes 20 minutes, Alderley Edge 22 minutes, and Macclesfield 25 minutes. Chester is approximately 50 minutes. Tarporley and Nantwich have no direct rail service and require a car to a connecting station, putting the total journey above 60 minutes.`,
  },
  {
    question: 'Is it worth moving from London to Cheshire?',
    answer: `A London flat sold for £600,000 buys a four-bedroom detached house in Wilmslow with equity remaining. The trade-offs: London's cultural density does not exist in Cheshire, and regular London office presence requires a 2-hour train. For Manchester commuters, the 17- to 25-minute rail journey makes the equity gain straightforward.`,
  },
  {
    question: 'What is the cost of living in Cheshire compared to London?',
    answer: `Housing is the main difference - Cheshire East averages £306,000 against London's £551,294 (Source: ONS / Land Registry UKHPI, December 2025). Groceries and utilities are broadly comparable. Council tax Band D runs £2,332.61 in Cheshire East and £1,978.09 in Cheshire West and Chester (Source: GOV.UK, 2025-26). Premium town costs (restaurants, private schools) are closer to London levels.`,
  },
];
---

<BaseLayout
  title="Where to Live in Cheshire? | Area Guides | movetocheshire.uk"
  description="Cheshire's ten main residential towns range from £175,000 in Crewe to above £700,000 in Alderley Edge, split across three price tiers with train commutes of 17 to 60 minutes to Manchester. Budget, commute tolerance, and school catchment determine which tier fits - this guide compares all ten by ONS price data, Ofsted ratings, and National Rail times (2025-26)."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(areaListSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <HubLayout
    breadcrumb="Area Guide"
    tag="Relocation Guide"
    title="Where to Live in Cheshire?"
    description="Cheshire's ten main residential towns range from £175,000 in Crewe to above £700,000 in Alderley Edge, split across three price tiers with train commutes of 17 to 60 minutes to Manchester. Budget, commute tolerance, and school catchment determine which tier fits - this guide compares all ten by ONS price data, Ofsted ratings, and National Rail times (2025-26)."
    spokes={spokes}
    relatedHubs={relatedHubs}
  >

    <!-- LAST UPDATED BADGE -->
    <p style="font-family: Inter, Arial, sans-serif; font-size: 12px; color: #888888; margin: 0 0 32px 0;">
      Last updated: February 2026
    </p>

    <!-- STAT BAR -->
    <p style="font-family: Inter, Arial, sans-serif; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #888888; margin: 0 0 12px 0;">Cheshire at a glance</p>
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; border: 1px solid #E5E0D8; margin-bottom: 48px;">
      <div style="padding: 24px; border-right: 1px solid #E5E0D8; text-align: center;">
        <p style="font-family: Georgia, serif; font-size: clamp(22px, 3vw, 30px); font-weight: 700; color: #1C1C1E; margin: 0 0 6px 0;">£306,000</p>
        <p style="font-family: Inter, Arial, sans-serif; font-size: 13px; color: #555555; margin: 0 0 4px 0;">Cheshire East average house price</p>
        <p style="font-family: Inter, Arial, sans-serif; font-size: 11px; color: #999999; font-style: italic; margin: 0;">Source: ONS, November 2025</p>
      </div>
      <div style="padding: 24px; border-right: 1px solid #E5E0D8; text-align: center;">
        <p style="font-family: Georgia, serif; font-size: clamp(22px, 3vw, 30px); font-weight: 700; color: #1C1C1E; margin: 0 0 6px 0;">£266,000</p>
        <p style="font-family: Inter, Arial, sans-serif; font-size: 13px; color: #555555; margin: 0 0 4px 0;">Cheshire West & Chester average</p>
        <p style="font-family: Inter, Arial, sans-serif; font-size: 11px; color: #999999; font-style: italic; margin: 0;">Source: ONS, November 2025</p>
      </div>
      <div style="padding: 24px; text-align: center;">
        <p style="font-family: Georgia, serif; font-size: clamp(22px, 3vw, 30px); font-weight: 700; color: #C4933F; margin: 0 0 6px 0;">17 mins</p>
        <p style="font-family: Inter, Arial, sans-serif; font-size: 13px; color: #555555; margin: 0 0 4px 0;">Fastest Cheshire train, Wilmslow to Manchester</p>
        <p style="font-family: Inter, Arial, sans-serif; font-size: 11px; color: #999999; font-style: italic; margin: 0;">Source: National Rail, 2025</p>
      </div>
    </div>

    <!-- INTRO COPY -->
    <div style="max-width: 720px; margin-bottom: 48px; margin-left: auto; margin-right: auto;">
      <p style="font-family: Inter, Arial, sans-serif; font-size: 17px; line-height: 1.75; color: #333333; margin: 0 0 14px 0;">
        Ten Cheshire towns serve three distinct buyer profiles.
      </p>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 17px; line-height: 1.75; color: #333333; margin: 0 0 14px 0;">
        The premium tier - Wilmslow, Alderley Edge, Prestbury - clusters Outstanding-rated schools within a 17- to 22-minute Manchester commute at £490,000 to £700,000+.
      </p>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 17px; line-height: 1.75; color: #333333; margin: 0 0 14px 0;">
        Knutsford, Macclesfield, Chester, and Nantwich form the mid-range tier, delivering Good and Outstanding schools at 32% to 60% lower prices than the Golden Triangle average (~£630,000).
      </p>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 17px; line-height: 1.75; color: #333333; margin: 0 0 14px 0;">
        Northwich and Crewe anchor the accessible tier from £175,000, suited to buyers prioritising mortgage cost over commute time.
      </p>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 17px; line-height: 1.75; color: #333333; margin: 0 0 24px 0;">
        Cheshire East has 76 Outstanding-rated schools, 22% of its total versus 16% nationally (Ofsted/SNobe, 2024-25).
      </p>
      <!-- CHESHIRE MAP -->
      <figure style="margin: 0;">
        <img
          src="/images/cheshire-map.webp"
          alt="Cheshire county map plotting ten residential towns by location and price tier - premium towns Alderley Edge, Prestbury, and Wilmslow clustered in the northeast Golden Triangle, mid-range Knutsford, Macclesfield, Chester, and Nantwich spread across the centre, and accessible Northwich and Crewe in the south"
          width="1024"
          height="1024"
          loading="eager"
          style="width: 100%; height: auto; border: 1px solid #E5E0D8;"
        />
        <figcaption style="font-family: Inter, Arial, sans-serif; font-size: 12px; color: #888888; margin-top: 8px; line-height: 1.5;">
          Cheshire's ten main residential towns span from Chester in the west to Macclesfield in the east. The Golden Triangle (Alderley Edge, Prestbury, Wilmslow) is highlighted in amber. Prices range from £175,000 in Crewe to above £700,000 in Alderley Edge. (Sources: ONS, November 2025; Rightmove, Q4 2025)
        </figcaption>
      </figure>
    </div>

    <!-- THREE PRICE TIERS -->
    <div style="max-width: 720px; margin-bottom: 48px; margin-left: auto; margin-right: auto;">
      <h2 style="font-family: Georgia, serif; font-size: clamp(22px, 3vw, 28px); font-weight: 700; color: #1C1C1E; margin: 0 0 12px 0;">How does each Cheshire price tier compare?</h2>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 15px; color: #555555; margin: 0 0 24px 0;">
        Cheshire's residential market spans £525,000 between the cheapest and most expensive towns. The premium tier averages £490,000 to £700,000+ with sub-22-minute Manchester trains; the mid-range tier runs £250,000 to £430,000 with 25- to 50-minute commutes; the accessible tier starts at £175,000 with longer or indirect rail connections (ONS, November 2025; National Rail, 2025).
      </p>
      <figure style="margin: 0 0 28px 0;">
        <!-- Container: image + CSS text overlay -->
        <div style="position: relative; width: 100%; border: 1px solid #E5E0D8; overflow: hidden;">
          <!-- Base illustration (no text) -->
          <img
            src="/images/cheshire-tiers-illustration.webp"
            alt="Cheshire's three residential price tiers compared - premium Golden Triangle towns at £490,000 to £700,000+, mid-range market towns at £250,000 to £430,000, and accessible towns from £175,000"
            width="1024"
            height="1024"
            loading="lazy"
            style="width: 100%; height: auto; display: block;"
          />
          <!-- CSS text overlay: three tier cards at bottom -->
          <div style="position: absolute; bottom: 0; left: 0; right: 0; display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1px; background: rgba(0,0,0,0.1);">
            <!-- Premium tier -->
            <div style="background: rgba(61,90,62,0.88); padding: clamp(8px, 2vw, 16px); text-align: center;">
              <span style="font-family: Inter, Arial, sans-serif; font-size: clamp(10px, 1.4vw, 13px); font-weight: 600; color: rgba(255,255,255,0.7); text-transform: uppercase; letter-spacing: 0.08em; display: block; margin-bottom: 4px;">Premium</span>
              <span style="font-family: Inter, Arial, sans-serif; font-size: clamp(14px, 2.2vw, 20px); font-weight: 700; color: #FFFFFF; display: block;">£490k-£700k+</span>
              <span style="font-family: Inter, Arial, sans-serif; font-size: clamp(9px, 1.2vw, 12px); color: rgba(255,255,255,0.8); display: block; margin-top: 2px;">17-22 min to Manchester</span>
            </div>
            <!-- Mid-range tier -->
            <div style="background: rgba(122,143,109,0.88); padding: clamp(8px, 2vw, 16px); text-align: center;">
              <span style="font-family: Inter, Arial, sans-serif; font-size: clamp(10px, 1.4vw, 13px); font-weight: 600; color: rgba(255,255,255,0.7); text-transform: uppercase; letter-spacing: 0.08em; display: block; margin-bottom: 4px;">Mid-range</span>
              <span style="font-family: Inter, Arial, sans-serif; font-size: clamp(14px, 2.2vw, 20px); font-weight: 700; color: #FFFFFF; display: block;">£250k-£430k</span>
              <span style="font-family: Inter, Arial, sans-serif; font-size: clamp(9px, 1.2vw, 12px); color: rgba(255,255,255,0.8); display: block; margin-top: 2px;">25-50 min to Manchester</span>
            </div>
            <!-- Accessible tier -->
            <div style="background: rgba(200,190,170,0.88); padding: clamp(8px, 2vw, 16px); text-align: center;">
              <span style="font-family: Inter, Arial, sans-serif; font-size: clamp(10px, 1.4vw, 13px); font-weight: 600; color: rgba(61,90,62,0.8); text-transform: uppercase; letter-spacing: 0.08em; display: block; margin-bottom: 4px;">Accessible</span>
              <span style="font-family: Inter, Arial, sans-serif; font-size: clamp(14px, 2.2vw, 20px); font-weight: 700; color: #3D5A3E; display: block;">£175k-£220k</span>
              <span style="font-family: Inter, Arial, sans-serif; font-size: clamp(9px, 1.2vw, 12px); color: rgba(61,90,62,0.7); display: block; margin-top: 2px;">55-60 min to Manchester</span>
            </div>
          </div>
        </div>
        <figcaption style="font-family: Inter, Arial, sans-serif; font-size: 12px; color: #888888; margin-top: 8px; line-height: 1.5;">
          Cheshire property tiers by average house price and train commute to Manchester Piccadilly. (Sources: ONS, November 2025; National Rail, 2025)
        </figcaption>
      </figure>

      <h3 style="font-family: Inter, Arial, sans-serif; font-size: 19px; font-weight: 700; color: #1C1C1E; margin: 0 0 12px 0;">What does the premium Cheshire tier offer?</h3>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 17px; line-height: 1.75; color: #333333; margin: 0 0 10px 0;">
        The <a href="/where-to-live/cheshire-golden-triangle" style="color: #3D5A3E; text-decoration: underline;">Golden Triangle</a> - Wilmslow, Alderley Edge, and Prestbury - averages £490,000 to above £700,000. Trains to Manchester Piccadilly run every 15 to 20 minutes, with Wilmslow the fastest at 17 minutes. <em style="color: #888888; font-size: 14px;">(Source: National Rail, 2025)</em>
      </p>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 17px; line-height: 1.75; color: #333333; margin: 0 0 28px 0;">
        Wilmslow, Alderley Edge, and Prestbury have the county's highest concentration of Outstanding-rated primary and secondary schools (Ofsted, 2024-25). Buyers with budgets above £600,000 and a Manchester commute access the county's highest-rated catchments and fastest rail connections from this tier.
      </p>

      <h3 style="font-family: Inter, Arial, sans-serif; font-size: 19px; font-weight: 700; color: #1C1C1E; margin: 0 0 12px 0;">What does the mid-range Cheshire tier offer?</h3>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 17px; line-height: 1.75; color: #333333; margin: 0 0 10px 0;">
        Knutsford, Macclesfield, Chester, and Nantwich each have multiple Good- and Outstanding-rated schools at 32% to 60% lower prices than the Golden Triangle average (~£630,000). Macclesfield averages £280,000 with a 25-minute train to Manchester Piccadilly.
      </p>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 17px; line-height: 1.75; color: #333333; margin: 0 0 28px 0;">
        <a href="/where-to-live/chester" style="color: #3D5A3E; text-decoration: underline;">Chester</a> is the county's only true city, with its own employment base and a direct train to London Euston at an average price of £250,000.
      </p>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 17px; line-height: 1.75; color: #333333; margin: 0 0 28px 0;">
        The Manchester commute at roughly 50 minutes is the trade-off. Most London relocators bringing £400,000 to £650,000 from a zone 2 or 3 sale land in this mid-range band.
      </p>

      <h3 style="font-family: Inter, Arial, sans-serif; font-size: 19px; font-weight: 700; color: #1C1C1E; margin: 0 0 12px 0;">What does the accessible Cheshire tier offer?</h3>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 17px; line-height: 1.75; color: #333333; margin: 0 0 10px 0;">
        Northwich at £220,000 and Crewe at £175,000 serve buyers working locally, hybrid-working from home, or prioritising mortgage size over commute time. Crewe has direct trains to Manchester and London, but the housing stock is predominantly terraced and semi-detached.
      </p>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 17px; line-height: 1.75; color: #333333; margin: 0;">
        Northwich sits between Cheshire's two larger zones and has added a Barons Quay retail development and new-build housing since 2015. Northwich lacks the independent retail scene of Knutsford or the school density of the Golden Triangle.
      </p>
    </div>

    <!-- LONDON EQUITY -->
    <div style="max-width: 720px; margin-bottom: 48px; margin-left: auto; margin-right: auto;">
      <h2 style="font-family: Georgia, serif; font-size: clamp(22px, 3vw, 28px); font-weight: 700; color: #1C1C1E; margin: 0 0 12px 0;">How far does London equity stretch in Cheshire?</h2>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 17px; line-height: 1.75; color: #333333; margin: 0 0 10px 0;">
        London equity of £400,000 to £900,000 buys a detached house with a garden in Cheshire - a property type that costs £750,000 to £1,200,000 in Surrey or Hertfordshire (Land Registry, Dec 2025). London's average sits at £551,294 against Cheshire East's £306,000. <em style="color: #888888; font-size: 14px;">(Source: ONS / Land Registry UKHPI, December 2025)</em>
      </p>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 17px; line-height: 1.75; color: #333333; margin: 0;">
