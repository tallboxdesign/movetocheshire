      <figure style="margin: 24px auto 0; max-width: 720px;">
        <img src="/images/where-to-live/alderley-edge-commute.webp"
          alt="Alderley Edge commute connectivity diagram showing 27 minutes to Manchester Piccadilly, 15-20 minutes to Manchester Airport, and 2.5 hours to London Euston"
          width="1200" height="630"
          loading="lazy"
