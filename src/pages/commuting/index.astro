---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HubLayout from '../../components/HubLayout.astro';

const spokes = [
  { label: 'Commuting from Cheshire to Manchester', href: '/commuting/cheshire-manchester-commute', description: 'Train times, frequencies, and season ticket costs from every Cheshire town to Manchester city centre and Piccadilly.' },
  { label: 'Wilmslow to Manchester Train', href: '/commuting/wilmslow-manchester-train', description: 'The most popular commuter route in Cheshire. Journey times, platforms, peak vs off-peak, and what the commute is actually like.' },
  { label: 'Commuting from Cheshire to Liverpool', href: '/commuting/cheshire-liverpool-commute', description: 'Train and road options to Liverpool from Chester, Frodsham, and Northwich. Which areas offer the most viable Liverpool commute?' },
  { label: 'Commuting from Cheshire to London', href: '/commuting/cheshire-london-commute', description: 'Intercity options from Crewe, Macclesfield, and Wilmslow to London Euston. Season ticket costs and realistic journey times.' },
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://movetocheshire.uk' },
    { '@type': 'ListItem', position: 2, name: 'Commuting from Cheshire', item: 'https://movetocheshire.uk/commuting' },
  ],
};

const collectionPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Commuting from Cheshire',
  description: 'Direct train times and driving routes from Cheshire to Manchester, Liverpool, Leeds, and London. Season ticket costs, frequency data, and honest assessments of commute viability.',
  url: 'https://movetocheshire.uk/commuting',
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Commuting from Cheshire to Manchester', url: 'https://movetocheshire.uk/commuting/cheshire-manchester-commute' },
      { '@type': 'ListItem', position: 2, name: 'Wilmslow to Manchester Train', url: 'https://movetocheshire.uk/commuting/wilmslow-manchester-train' },
      { '@type': 'ListItem', position: 3, name: 'Commuting from Cheshire to Liverpool', url: 'https://movetocheshire.uk/commuting/cheshire-liverpool-commute' },
      { '@type': 'ListItem', position: 4, name: 'Commuting from Cheshire to London', url: 'https://movetocheshire.uk/commuting/cheshire-london-commute' },
    ],
  },
};

const relatedHubs = [
  { label: 'Where to Live', href: '/where-to-live' },
  { label: 'House Prices', href: '/house-prices' },
];
---

<BaseLayout
  title="Commuting from Cheshire | Transport Guide | movetocheshire.uk"
  description="Direct train times and driving routes from Cheshire to Manchester, Liverpool, Leeds, and London. Season ticket costs, frequency data, and honest assessments of commute viability."

  publishDate="2026-02-01"
  updatedDate="2026-03-01"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(collectionPageSchema)} />
  </Fragment>
  <HubLayout
    tag="Cheshire commuter routes"
    breadcrumb="Transport"
    title="Commuting from Cheshire"
    description="Direct train times and driving routes to Manchester, Liverpool, Leeds, and London, mapped by town. Season ticket costs, frequency data, and an honest assessment of which areas offer viable commutes to which cities."
    spokes={spokes}
    relatedHubs={relatedHubs}
  />
</BaseLayout>
