import BaseLayout from '../../layouts/BaseLayout.astro';

const faqs = [
  {
    question: 'How long is the train from Wilmslow to Manchester?',
    answer: 'The fastest Wilmslow to Manchester Piccadilly service takes 21 minutes on Northern Rail express departures. Typical peak-hour journey time is 28 minutes on stopping services that call at Handforth, Heald Green, and Cheadle Hulme. The station handles around 4 trains per hour during the morning peak. Avanti West Coast also serves Wilmslow, with non-stop services completing the journey in as little as 17-19 minutes (National Rail timetable, 2025-26).'
  },
  {
    question: 'Is Knutsford on the Manchester train line?',
    answer: 'Yes, but via a different line to Wilmslow and Alderley Edge. Knutsford station is served by the Mid-Cheshire Line, which runs to Manchester Oxford Road - not Manchester Piccadilly. Oxford Road is approximately 800m from Piccadilly on foot, adding around 10 minutes to journeys into the Piccadilly area. Knutsford has 2 trains per hour at peak times, and the fastest journey to Oxford Road is 52 minutes (Northern Rail timetable, 2025-26).'
  },
  {
    question: 'What is the season ticket cost from Cheshire to Manchester?',
    answer: 'Annual season ticket costs vary by origin. Macclesfield to Manchester Piccadilly costs approximately £3,600 per year. Wilmslow is approximately £3,800. Alderley Edge is approximately £4,100. Chester is the most expensive Cheshire town at approximately £5,200 per year due to the greater distance. Knutsford costs approximately £2,900 per year to Manchester Oxford Road. All figures are approximate based on National Rail 2025-26 fares - verify at nationalrail.co.uk before purchase.'
  },
  {
    question: 'Which Cheshire town has the best train connection to Manchester?',
    answer: 'Macclesfield (SK10) offers the fastest journey time at 18 minutes to Manchester Piccadilly via Avanti West Coast express services, despite sitting 17 miles from Manchester. Wilmslow (SK9) is the next fastest at 21 minutes with 4 trains per hour and arguably the most flexible timetable. For commuters prioritising frequency and journey time combined, Wilmslow and Macclesfield lead. Knutsford and Chester involve significantly longer journeys. The right answer depends on whether speed, frequency, cost, or property value represents the priority for each buyer.'
  },
  {
    question: 'Can I get to Manchester Airport from Cheshire by train?',
    answer: 'Yes. Wilmslow to Manchester Airport is 8 minutes on Northern Rail, with 2 trains per hour on the same line used for Manchester Piccadilly services - making Wilmslow one of the most convenient Cheshire towns for regular airport travel. Alderley Edge requires a change at Wilmslow or Styal for airport services. Knutsford has no direct airport service - passengers must change at Manchester Oxford Road or Piccadilly. Macclesfield airport access requires a change, typically at Manchester Piccadilly.'
  }
];

