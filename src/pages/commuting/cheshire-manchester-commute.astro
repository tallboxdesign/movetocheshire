  <!-- Hero -->
  <section style="background-color: #F5F0E8; padding: clamp(40px, 6vw, 72px) 24px clamp(32px, 5vw, 56px);">
    <div style="max-width: 800px; margin: 0 auto;">
      <p style="font-family: Inter, Arial, sans-serif; font-size: 13px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #3D5A3E; margin: 0 0 16px 0;">Commuting Guide</p>
      <h1 style="font-family: Georgia, serif; font-size: clamp(26px, 4vw, 40px); font-weight: 700; color: #1C1C1E; line-height: 1.2; margin: 0 0 20px 0;">
        Cheshire to Manchester Commute: Train Times, Season Ticket Costs and Routes (2026)
      </h1>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 17px; line-height: 1.7; color: #444444; margin: 0 0 36px 0; max-width: 680px;">
        A line-by-line breakdown of train services from Cheshire to Manchester, with journey times, annual season ticket costs, and the commute quality differences that separate Wilmslow from Knutsford from Macclesfield. Data sourced from National Rail 2025-26 fares and current timetables.
      </p>

      <!-- Stat tiles -->
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 16px;">
        <div style="background: #ffffff; border: 1px solid #E5E0D8; border-radius: 6px; padding: 20px 18px;">
