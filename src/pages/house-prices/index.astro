  { label: 'Investment', href: '/investment', description: 'Market conditions, price trends, and whether now is the right time to buy.', icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6' },
  { label: 'Buying Guide', href: '/buying-guide', description: 'Stamp duty, surveys, conveyancing, and what to expect from the purchase process.', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z' },
];

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': ['WebPage', 'Report'],
  name: "Cheshire House Prices by Area and Property Type",
  description: "Cheshire averages £314,000 (ONS, 2025). Prices by unitary authority, town, ward, and property type from ONS, Rightmove, and CW&C Council data.",
  url: 'https://movetocheshire.uk/house-prices',
  dateModified: '2026-02-24',
  temporalCoverage: '2025/2026',
  spatialCoverage: { '@type': 'AdministrativeArea', name: 'Cheshire' },
  isBasedOn: [
    { '@type': 'Dataset', name: 'ONS UK House Price Index', publisher: { '@type': 'GovernmentOrganization', name: 'Office for National Statistics' } },
    { '@type': 'Dataset', name: 'Rightmove House Price Data', publisher: { '@type': 'Organization', name: 'Rightmove' } },
    { '@type': 'Dataset', name: 'CW&C Ward Price Data', publisher: { '@type': 'GovernmentOrganization', name: 'Cheshire West and Chester Council' } },
  ],
