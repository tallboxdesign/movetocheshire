  isPartOf: { '@type': 'WebPage', url: 'https://movetocheshire.uk/house-prices' },
  itemListElement: neighbours.map((n, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Observation',
      name: `${n.name} average house price`,
      observationAbout: { '@type': 'AdministrativeArea', name: n.name, containedInPlace: { '@type': 'Country', name: 'England' } },
      observationDate: '2025',
      measuredProperty: { '@type': 'Property', name: 'averageHousePrice' },
      description: n.note,
    },
  })),
};

const wardListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Cheshire West and Chester Ward House Prices',
  description: 'Median house prices for 35 wards in Cheshire West and Chester with population (Census 2021), settlement type, and key attributes.',
  numberOfItems: cheshireWestTowns.length,
  itemListOrder: 'https://schema.org/ItemListOrderDescending',
  isPartOf: { '@type': 'WebPage', url: 'https://movetocheshire.uk/house-prices' },
  itemListElement: cheshireWestTowns.map((town, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Place',
      additionalType: 'https://schema.org/Residence',
      name: town.name,
      description: `${town.type} in Cheshire West and Chester. Population ${town.pop} (Census 2021). ${town.attr}. Median house price ${town.price} (CW&C Council, 2023).`,
      containedInPlace: { '@type': 'AdministrativeArea', name: 'Cheshire West and Chester' },
    },
  })),
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.q,
    acceptedAnswer: { '@type': 'Answer', text: faq.a },
  })),
};
---

<BaseLayout
  title="Cheshire House Prices by Area and Property Type | movetocheshire.uk"
  description="Cheshire averages £314,000 (ONS, 2025). Prices by unitary authority, town, ward, and property type - detached, semi-detached, terraced, flat - from ONS, Rightmove, and council data."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(authorityListSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(neighboursListSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(wardListSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <!-- Breadcrumb -->
  <div class="section-pad" style="padding-top: 20px; padding-bottom: 0;">
    <div class="section-inner">
      <nav aria-label="Breadcrumb" style="font-family: Inter, Arial, sans-serif; font-size: 13px; color: #999999;">
        <a href="/" style="color: #999999; text-decoration: none;">Home</a>
        <span style="margin: 0 8px;">/</span>
        <span style="color: #1C1C1E;">House Prices</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="section-pad" style="padding-top: 40px;">
    <div class="section-inner" style="max-width: 720px;">
      <span class="section-label">Property Data</span>
      <h1 style="font-family: Georgia, serif; font-size: clamp(28px, 4.5vw, 44px); font-weight: 700; color: #1C1C1E; line-height: 1.15; margin: 0 0 20px 0; letter-spacing: -0.02em;">
        Cheshire House Prices by Area and Property Type
      </h1>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 18px; line-height: 1.7; color: #444444; margin: 0 0 24px 0;">
        Cheshire averages £314,000 across all property types (PlumPlot/ONS, 2025), 8% above the UK national average of £290,000. Prices range from £115,000 in Ellesmere Port Westminster ward to £1,163,360 for a detached home in Alderley Edge (CW&C Council 2023, Rightmove Feb 2026).
      </p>
      <span style="display: inline-block; font-family: Inter, Arial, sans-serif; font-size: 12px; font-weight: 600; color: #3D5A3E; background-color: rgba(61, 90, 62, 0.08); padding: 6px 12px; letter-spacing: 0.02em;">Last updated: February 2026</span>
    </div>
  </section>

  <!-- Stat Bar -->
  <section class="section-pad" style="padding-top: 0;">
    <div class="section-inner">
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px;">
        {stats.map((stat) => (
          <div style="background-color: #FFFFFF; border: 1px solid #E5E0D8; padding: 28px 24px;">
            <p class="data-tile-value" style="margin: 0 0 8px 0;">{stat.value}</p>
            <p style="font-family: Inter, Arial, sans-serif; font-size: 14px; font-weight: 600; color: #1C1C1E; margin: 0 0 4px 0;">{stat.label}</p>
            <p style="font-family: Inter, Arial, sans-serif; font-size: 12px; color: #999999; margin: 0;">{stat.source}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Quick Answer -->
  <section class="section-pad">
    <div class="section-inner" style="max-width: 720px;">
      <span class="section-label">The short answer</span>
      <h2 style="font-family: Georgia, serif; font-size: clamp(22px, 3vw, 30px); font-weight: 700; color: #1C1C1E; line-height: 1.25; margin: 0 0 24px 0;">How much does a house cost in Cheshire?</h2>
      <div style="display: flex; flex-direction: column; gap: 16px;">
        <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #1C1C1E; margin: 0;">Cheshire averages £314,000 across all property types (PlumPlot/ONS, 2025), with a median of £255,000. Cheshire East averages £306,000 (ONS, Dec 2025), up 5.7% year-on-year. Cheshire West and Chester averages £266,000, up 2.8%. Warrington averages £252,000, up 6.0%.</p>
        <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0;">Cheshire has 34% detached housing stock versus 22% nationally (Census 2021), which pulls the county average above the UK figure of £290,000. A detached home in Cheshire East averages £496,000. A terraced home in Cheshire West averages £207,000. A flat in Halton averages £103,000.</p>
        <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0;">Cheshire prices range from £115,000 in Ellesmere Port Westminster ward to £1,163,360 for a detached home in Alderley Edge (CW&C Council 2023, Rightmove Feb 2026). A £1,048,360 spread within a single county makes the headline average unreliable without area and property type breakdowns.</p>
      </div>
    </div>
  </section>

  <!-- Unitary Authority Comparison -->
  <section class="section-pad" style="background-color: #FFFFFF; border-top: 1px solid #E5E0D8; border-bottom: 1px solid #E5E0D8;">
    <div class="section-inner" style="max-width: 900px;">
      <span class="section-label">By authority</span>
      <h2 style="font-family: Georgia, serif; font-size: clamp(22px, 3vw, 30px); font-weight: 700; color: #1C1C1E; line-height: 1.25; margin: 0 0 12px 0;">What are house prices in each Cheshire authority area?</h2>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 15px; line-height: 1.7; color: #444444; margin: 0 0 28px 0;">Cheshire East averages £306,000, Cheshire West £266,000, Warrington £252,000, and Halton £189,000 (ONS, Dec 2025). Halton is 35% below the county average of £314,000. Cheshire East recorded the strongest year-on-year growth at 5.7%.</p>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 16px;">
        {authorities.map((auth) => (
          <div style="border-left: 3px solid #3D5A3E; background-color: #F9F7F4; padding: 24px;">
            <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; font-weight: 700; color: #1C1C1E; margin: 0 0 4px 0;">{auth.name}</p>
            <p style="font-family: Georgia, serif; font-size: 28px; font-weight: 700; color: #3D5A3E; margin: 0 0 2px 0;">{auth.price}</p>
            <p style="font-family: Inter, Arial, sans-serif; font-size: 13px; font-weight: 600; color: #C4933F; margin: 0 0 16px 0;">{auth.growth} YoY</p>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px;">
              <div><p style="font-family: Inter, Arial, sans-serif; font-size: 11px; color: #999999; margin: 0;">Detached</p><p style="font-family: Inter, Arial, sans-serif; font-size: 14px; font-weight: 600; color: #1C1C1E; margin: 0;">{auth.detached}</p></div>
              <div><p style="font-family: Inter, Arial, sans-serif; font-size: 11px; color: #999999; margin: 0;">Semi</p><p style="font-family: Inter, Arial, sans-serif; font-size: 14px; font-weight: 600; color: #1C1C1E; margin: 0;">{auth.semi}</p></div>
              <div><p style="font-family: Inter, Arial, sans-serif; font-size: 11px; color: #999999; margin: 0;">Terraced</p><p style="font-family: Inter, Arial, sans-serif; font-size: 14px; font-weight: 600; color: #1C1C1E; margin: 0;">{auth.terraced}</p></div>
              <div><p style="font-family: Inter, Arial, sans-serif; font-size: 11px; color: #999999; margin: 0;">Flat</p><p style="font-family: Inter, Arial, sans-serif; font-size: 14px; font-weight: 600; color: #1C1C1E; margin: 0;">{auth.flat}</p></div>
            </div>
          </div>
        ))}
      </div>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 12px; color: #999999; margin: 16px 0 0 0;">Source: ONS UK House Price Index, December 2025. Year-on-year growth compares Dec 2025 to Dec 2024.</p>
    </div>
  </section>

  <!-- Golden Triangle -->
  <section class="section-pad">
    <div class="section-inner" style="max-width: 900px;">
      <span class="section-label">Premium towns</span>
      <h2 style="font-family: Georgia, serif; font-size: clamp(22px, 3vw, 30px); font-weight: 700; color: #1C1C1E; line-height: 1.25; margin: 0 0 12px 0;">What do houses cost in the Golden Triangle?</h2>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 15px; line-height: 1.7; color: #444444; margin: 0 0 28px 0;">Golden Triangle houses cost £489,105 in Wilmslow, £606,876 in Knutsford, and £666,489 in Alderley Edge (Rightmove, 12 months to Feb 2026). Alderley Edge detached homes average £1,163,360, 135% above the Cheshire East detached average of £496,000.</p>
      <div style="overflow-x: auto;">
        <table style="width: 100%; border-collapse: collapse; min-width: 600px;">
          <thead>
            <tr style="border-bottom: 2px solid #3D5A3E;">
              {['Town', 'Average', 'Detached', 'Semi', 'Terraced', 'Flat'].map((col) => (
                <th style="text-align: left; padding: 12px 12px; font-family: Inter, Arial, sans-serif; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #1C1C1E;">{col}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {goldenTriangle.map((town, i) => (
              <tr style={`background-color: ${i % 2 === 0 ? '#FFFFFF' : '#F9F7F4'}; border-bottom: 1px solid #E5E0D8;`}>
                <td style="padding: 14px 12px; font-family: Inter, Arial, sans-serif; font-size: 14px; font-weight: 600; color: #1C1C1E;">{town.name}</td>
                <td style="padding: 14px 12px; font-family: Inter, Arial, sans-serif; font-size: 14px; font-weight: 700; color: #3D5A3E;">{town.avg}</td>
                <td style="padding: 14px 12px; font-family: Inter, Arial, sans-serif; font-size: 14px; color: #444444;">{town.detached}</td>
                <td style="padding: 14px 12px; font-family: Inter, Arial, sans-serif; font-size: 14px; color: #444444;">{town.semi}</td>
                <td style="padding: 14px 12px; font-family: Inter, Arial, sans-serif; font-size: 14px; color: #444444;">{town.terraced}</td>
                <td style="padding: 14px 12px; font-family: Inter, Arial, sans-serif; font-size: 14px; color: #444444;">{town.flat}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 12px; color: #999999; margin: 12px 0 0 0;">Source: Rightmove, 12 months to early 2026. Poynton verified via data.md. "-" indicates insufficient transaction data for that property type.</p>
    </div>
  </section>

  <!-- Property Type Breakdown -->
  <section class="section-pad" style="background-color: #FFFFFF; border-top: 1px solid #E5E0D8; border-bottom: 1px solid #E5E0D8;">
    <div class="section-inner" style="max-width: 900px;">
      <span class="section-label">By property type</span>
      <h2 style="font-family: Georgia, serif; font-size: clamp(22px, 3vw, 30px); font-weight: 700; color: #1C1C1E; line-height: 1.25; margin: 0 0 12px 0;">How much does each property type cost in Cheshire?</h2>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 15px; line-height: 1.7; color: #444444; margin: 0 0 28px 0;">Cheshire detached homes average £496,000 county-wide (ONS, Dec 2025). Flats average £170,000, a £326,000 difference that reflects the county's high proportion of detached stock at 34% versus 22% nationally (Census 2021).</p>
      <div style="overflow-x: auto;">
        <table style="width: 100%; border-collapse: collapse; min-width: 550px;">
          <thead>
            <tr style="border-bottom: 2px solid #3D5A3E;">
              {['Area', 'Detached', 'Semi-detached', 'Terraced', 'Flat'].map((col) => (
                <th style="text-align: left; padding: 12px; font-family: Inter, Arial, sans-serif; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #1C1C1E;">{col}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {[...propertyTypes, ...selectedWardTypes].map((row, i) => (
              <tr style={`background-color: ${i % 2 === 0 ? '#FFFFFF' : '#F9F7F4'}; border-bottom: 1px solid #E5E0D8; ${i === 4 ? 'border-bottom: 2px solid #E5E0D8;' : ''}`}>
                <td style={`padding: 14px 12px; font-family: Inter, Arial, sans-serif; font-size: 14px; font-weight: ${i < 5 ? '600' : '500'}; color: #1C1C1E;`}>{row.area}</td>
                <td style="padding: 14px 12px; font-family: Inter, Arial, sans-serif; font-size: 14px; color: #444444;">{row.detached}</td>
                <td style="padding: 14px 12px; font-family: Inter, Arial, sans-serif; font-size: 14px; color: #444444;">{row.semi}</td>
                <td style="padding: 14px 12px; font-family: Inter, Arial, sans-serif; font-size: 14px; color: #444444;">{row.terraced}</td>
                <td style="padding: 14px 12px; font-family: Inter, Arial, sans-serif; font-size: 14px; color: #444444;">{row.flat}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 12px; color: #999999; margin: 12px 0 0 0;">Source: ONS UK HPI Dec 2025 (authority rows). Rightmove 12 months to Feb 2026 (town rows). CW&C Council 2023 (Frodsham, Helsby, Northwich). "-" = insufficient data.</p>
    </div>
  </section>

  <!-- Cheshire West Ward Prices -->
  <section class="section-pad">
    <div class="section-inner" style="max-width: 900px;">
      <span class="section-label">Ward-level data</span>
      <h2 style="font-family: Georgia, serif; font-size: clamp(22px, 3vw, 30px); font-weight: 700; color: #1C1C1E; line-height: 1.25; margin: 0 0 12px 0;">What are house prices in each Cheshire West ward?</h2>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 15px; line-height: 1.7; color: #444444; margin: 0 0 28px 0;">Cheshire West and Chester ward-level prices range from £115,000 in Ellesmere Port Westminster to £487,500 in Tattenhall (CW&C Council, 2023). Chester wards span from £172,000 in Blacon to £340,000 in Handbridge Park and Upton.</p>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 10px;">
        {cheshireWestTowns.map((town) => (
          <article style={`padding: 16px; border-left: 3px solid ${town.level === 'premium' ? '#C4933F' : town.level === 'high' ? '#3D5A3E' : town.level === 'mid' ? '#6B8F71' : '#8BA38F'}; background-color: #F9F7F4;`}>
            <p style="font-family: Inter, Arial, sans-serif; font-size: 14px; font-weight: 700; color: #1C1C1E; margin: 0 0 4px 0;">{town.name}</p>
            <p style="font-family: Georgia, serif; font-size: 20px; font-weight: 700; color: #1C1C1E; margin: 0 0 8px 0;">{town.price}</p>
            <p style="display: flex; flex-wrap: wrap; gap: 4px; margin: 0;">
              <span style="font-family: Inter, Arial, sans-serif; font-size: 11px; color: #3D5A3E; background-color: rgba(61, 90, 62, 0.08); padding: 2px 7px; white-space: nowrap;">Pop. {town.pop}</span>
              <span style="font-family: Inter, Arial, sans-serif; font-size: 11px; color: #1C1C1E; background-color: rgba(28, 28, 30, 0.05); padding: 2px 7px; white-space: nowrap;">{town.type}</span>
              <span style="font-family: Inter, Arial, sans-serif; font-size: 11px; color: #444444; background-color: rgba(28, 28, 30, 0.04); padding: 2px 7px;">{town.attr}</span>
            </p>
          </article>
        ))}
      </div>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 12px; color: #999999; margin: 12px 0 0 0;">Source: CW&C Council ward-level median prices, 2023. Population: ONS Census 2021. Northwich combines Leftwich (4,785), Winnington & Castle (9,226), and Witton (5,116) wards. Gold = premium (£450k+), dark green = high (£300-449k), mid green = mid (£200-299k), light = under £200k.</p>
    </div>
  </section>

  <!-- Cross-Cheshire Comparison with Tabs -->
  <section class="section-pad" style="background-color: #FFFFFF; border-top: 1px solid #E5E0D8; border-bottom: 1px solid #E5E0D8;">
    <div class="section-inner" style="max-width: 900px;">
      <span class="section-label">All areas ranked</span>
      <h2 style="font-family: Georgia, serif; font-size: clamp(22px, 3vw, 30px); font-weight: 700; color: #1C1C1E; line-height: 1.25; margin: 0 0 12px 0;">How do Cheshire towns compare to each other by price?</h2>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 15px; line-height: 1.7; color: #444444; margin: 0 0 20px 0;">Cheshire town prices range from £115,000 in Ellesmere Port Westminster to £666,489 in Alderley Edge, a £551,489 spread across a single county (CW&C Council 2023, Rightmove Feb 2026). Cheshire East dominates the top of the table. CW&C wards span the full spectrum from premium rural villages to affordable urban areas.</p>

      <!-- Tab buttons -->
      <div style="display: flex; gap: 0; margin-bottom: 0; border-bottom: 2px solid #E5E0D8;" id="area-tabs">
        <button class="area-tab area-tab--active" data-filter="all" style="padding: 10px 20px; font-family: Inter, Arial, sans-serif; font-size: 13px; font-weight: 600; color: #3D5A3E; background: #F9F7F4; border: 1px solid #E5E0D8; border-bottom: 2px solid #3D5A3E; margin-bottom: -2px; cursor: pointer;">All Cheshire</button>
        <button class="area-tab" data-filter="Cheshire East" style="padding: 10px 20px; font-family: Inter, Arial, sans-serif; font-size: 13px; font-weight: 600; color: #999999; background: transparent; border: 1px solid transparent; border-bottom: 2px solid transparent; margin-bottom: -2px; cursor: pointer;">Cheshire East</button>
        <button class="area-tab" data-filter="CW&C" style="padding: 10px 20px; font-family: Inter, Arial, sans-serif; font-size: 13px; font-weight: 600; color: #999999; background: transparent; border: 1px solid transparent; border-bottom: 2px solid transparent; margin-bottom: -2px; cursor: pointer;">Cheshire West</button>
      </div>

      <div style="overflow-x: auto; max-height: 600px; overflow-y: auto; border: 1px solid #E5E0D8; border-top: 0;">
        <table style="width: 100%; border-collapse: collapse; min-width: 500px;" id="ranked-table">
          <thead style="position: sticky; top: 0; z-index: 1;">
            <tr style="border-bottom: 2px solid #3D5A3E; background-color: #F9F7F4;">
              {['#', 'Town / Ward', 'Authority', 'Average Price'].map((col) => (
                <th style="text-align: left; padding: 12px; font-family: Inter, Arial, sans-serif; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #1C1C1E;">{col}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {allTownsRanked.map((town, i) => (
              <tr data-authority={town.authority} style={`background-color: ${i % 2 === 0 ? '#FFFFFF' : '#F9F7F4'}; border-bottom: 1px solid #E5E0D8;`}>
                <td class="row-num" style="padding: 10px 12px; font-family: Inter, Arial, sans-serif; font-size: 13px; color: #999999; width: 40px;">{i + 1}</td>
                <td style="padding: 10px 12px; font-family: Inter, Arial, sans-serif; font-size: 14px; font-weight: 600; color: #1C1C1E;">{town.name}</td>
                <td style="padding: 10px 12px; font-family: Inter, Arial, sans-serif; font-size: 13px; color: #444444;">{town.authority}</td>
                <td style={`padding: 10px 12px; font-family: Inter, Arial, sans-serif; font-size: 14px; font-weight: 600; color: ${town.level === 'premium' ? '#C4933F' : town.level === 'high' ? '#3D5A3E' : town.level === 'mid' ? '#6B8F71' : '#8BA38F'};`}>{town.price}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 12px; color: #999999; margin: 12px 0 0 0;">Sources: Rightmove 12 months to Feb 2026 (Cheshire East towns). CW&C Council ward-level median prices, 2023 (Cheshire West wards). Prestbury excluded - insufficient Rightmove transaction data for a precise average (estimated £700,000+).</p>

      <!-- Post-table narrative -->
      <div style="margin-top: 28px; display: flex; flex-direction: column; gap: 16px;">
        <h3 style="font-family: Georgia, serif; font-size: 20px; font-weight: 700; color: #1C1C1E; margin: 0;">What is the median Cheshire house price and where are the cheapest and most expensive areas?</h3>
        <p style="font-family: Inter, Arial, sans-serif; font-size: 15px; line-height: 1.75; color: #444444; margin: 0;">The county median is £255,000 (PlumPlot/ONS, 2025), £59,000 below the £314,000 mean average. The gap reflects high-value outliers in the Golden Triangle pulling the mean upward. For a typical Cheshire buyer, the median is a more reliable benchmark.</p>
        <p style="font-family: Inter, Arial, sans-serif; font-size: 15px; line-height: 1.75; color: #444444; margin: 0;">The cheapest detached house in Cheshire is in Halton at £320,000 average (ONS, Dec 2025). The cheapest terraced house is in Halton at £155,000. The cheapest flat is in Halton at £103,000. Ellesmere Port Westminster ward at £115,000 overall median (CW&C Council, 2023) offers the lowest entry point across all property types in the county. Winsford Dene at £157,500 and Blacon Chester at £172,000 follow as the next most affordable wards.</p>
        <p style="font-family: Inter, Arial, sans-serif; font-size: 15px; line-height: 1.75; color: #444444; margin: 0;">The most expensive detached house is in Alderley Edge at £1,163,360 average (Rightmove, Feb 2026). The most expensive semi-detached is in Alderley Edge at £570,089. The most expensive terraced is in Knutsford at £435,418. The most expensive flat is in Alderley Edge at £309,393. Cheshire East contains six of the seven priciest towns in the county. CW&C's premium areas - Tattenhall at £487,500 and Tarporley at £475,000 - are rural villages with populations under 5,200 (Census 2021).</p>
      </div>
    </div>
  </section>

  <script>
    document.getElementById('area-tabs')?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('[data-filter]') as HTMLElement;
      if (!btn) return;
      const filter = btn.dataset.filter;
      document.querySelectorAll('.area-tab').forEach(t => {
        const el = t as HTMLElement;
        el.style.color = '#999999';
        el.style.background = 'transparent';
        el.style.borderBottom = '2px solid transparent';
        el.style.border = '1px solid transparent';
        el.classList.remove('area-tab--active');
      });
      btn.style.color = '#3D5A3E';
      btn.style.background = '#F9F7F4';
      btn.style.borderBottom = '2px solid #3D5A3E';
      btn.style.border = '1px solid #E5E0D8';
      btn.classList.add('area-tab--active');
      let num = 1;
      document.querySelectorAll('#ranked-table tbody tr').forEach(row => {
        const el = row as HTMLElement;
        if (filter === 'all' || el.dataset.authority === filter) {
          el.style.display = '';
          const numCell = el.querySelector('.row-num') as HTMLElement;
          if (numCell) numCell.textContent = String(num++);
        } else {
          el.style.display = 'none';
        }
      });
    });
  </script>

  <!-- Neighbouring Counties Comparison -->
  <section class="section-pad">
    <div class="section-inner" style="max-width: 900px;">
      <span class="section-label">Regional context</span>
      <h2 style="font-family: Georgia, serif; font-size: clamp(22px, 3vw, 30px); font-weight: 700; color: #1C1C1E; line-height: 1.25; margin: 0 0 12px 0;">How do Cheshire house prices compare to neighbouring counties?</h2>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 15px; line-height: 1.7; color: #444444; margin: 0 0 16px 0;">Cheshire averages £314,000 (PlumPlot/ONS, 2025), £92,000 above Merseyside at £222,000 and £105,000 above Lancashire at £209,000. Cheshire ranks 26th of 55 English and Welsh counties by average price (PlumPlot, 2025). Move to Cheshire calculates a population-weighted authority average of £274,250 for the four Cheshire unitary authorities (ONS Dec 2025, Census 2021 populations), which sits between the PlumPlot aggregate and the individual ONS figures.</p>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 15px; line-height: 1.7; color: #444444; margin: 0 0 28px 0;">Two neighbouring areas exceed the Cheshire county average: Trafford in Greater Manchester at £378,094 (ONS, Aug 2025) and Derbyshire Dales at £339,448. Both are localised premiums within otherwise cheaper counties. Even using the lower population-weighted figure of £274,250, Cheshire remains £52,000 above Merseyside, £65,000 above Lancashire, and £40,000 above Derbyshire overall. Cheshire East at £302,000-£306,000 (ONS Aug-Dec 2025) is the most consistently expensive authority across the North West and bordering Midlands.</p>
      <div style="overflow-x: auto;">
        <table style="width: 100%; border-collapse: collapse; min-width: 650px;">
          <thead>
            <tr style="border-bottom: 2px solid #3D5A3E;">
              {['County / Region', 'Average', 'Range (min-max)', 'Premium Area', 'Source'].map((col) => (
                <th style="text-align: left; padding: 12px; font-family: Inter, Arial, sans-serif; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #1C1C1E;">{col}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {neighbours.map((n, i) => (
              <tr style={`background-color: ${i % 2 === 0 ? '#FFFFFF' : '#F9F7F4'}; border-bottom: 1px solid #E5E0D8; ${i === 0 ? 'border-left: 3px solid #3D5A3E;' : ''}`}>
                <td style={`padding: 14px 12px; font-family: Inter, Arial, sans-serif; font-size: 14px; font-weight: ${i === 0 ? '700' : '600'}; color: #1C1C1E;`}>{n.name}</td>
                <td style={`padding: 14px 12px; font-family: Inter, Arial, sans-serif; font-size: 14px; font-weight: 700; color: ${i === 0 ? '#3D5A3E' : '#444444'};`}>{n.avg}</td>
                <td style="padding: 14px 12px; font-family: Inter, Arial, sans-serif; font-size: 13px; color: #444444;">{n.range}</td>
                <td style="padding: 14px 12px; font-family: Inter, Arial, sans-serif; font-size: 13px; color: #444444;">{n.premium}</td>
                <td style="padding: 14px 12px; font-family: Inter, Arial, sans-serif; font-size: 12px; color: #999999;">{n.source}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div style="margin-top: 20px; border-left: 3px solid #C4933F; background-color: rgba(196, 147, 63, 0.04); padding: 20px 24px;">
        <p style="font-family: Inter, Arial, sans-serif; font-size: 14px; font-weight: 700; color: #C4933F; margin: 0 0 8px 0; text-transform: uppercase; letter-spacing: 0.05em;">Move to Cheshire methodology</p>
        <p style="font-family: Inter, Arial, sans-serif; font-size: 14px; line-height: 1.7; color: #444444; margin: 0 0 12px 0;"><strong>The problem:</strong> No single official source publishes a "Cheshire house price." PlumPlot aggregates all authorities within the ceremonial county boundary and reports £314,000 (2025). ONS UK HPI reports individual authority averages - Cheshire East at £306,000 and CW&C at £266,000 (Dec 2025) - but publishes no county-level figure. The same issue affects Greater Manchester (10 boroughs, no single average) and Lancashire (PlumPlot £209,000 vs ONS £186,000 for the local authority area only, excluding Blackburn, Blackpool, and Burnley unitaries).</p>
        <p style="font-family: Inter, Arial, sans-serif; font-size: 14px; line-height: 1.7; color: #444444; margin: 0 0 12px 0;"><strong>Our formula:</strong> Move to Cheshire calculates a population-weighted authority average using ONS UK HPI prices and Census 2021 populations. The formula weights each authority's average price by its share of the total Cheshire population: (CE price x CE pop + CW&C price x CW&C pop + Warrington price x Warrington pop + Halton price x Halton pop) / total Cheshire pop. This produces £274,250 - lower than PlumPlot's £314,000 because it accounts for Halton (pop. 128,500) and Warrington (pop. 209,500) pulling the weighted average below the Cheshire East figure.</p>
        <p style="font-family: Inter, Arial, sans-serif; font-size: 14px; line-height: 1.7; color: #444444; margin: 0;"><strong>Which figure to use:</strong> The table above shows both the established PlumPlot/ONS aggregates and the min-max range for each county. The range column is the most reliable comparison because it reveals the spread within each area. A single "average" for Greater Manchester (£190,000-£378,000) or Cheshire (£189,000-£306,000 by authority, £115,000-£666,000 by town) conceals more than it reveals.</p>
      </div>
    </div>
  </section>

  <!-- Relocator Questions -->
  <section class="section-pad" style="background-color: #FFFFFF; border-top: 1px solid #E5E0D8; border-bottom: 1px solid #E5E0D8;">
