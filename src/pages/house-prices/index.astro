      value: parseInt(auth.price.replace(/[£,]/g, '')),
      unitCode: 'GBP',
    },
  })),
};

const neighboursListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Cheshire vs Neighbouring County House Prices',
  description: 'Average house prices for Cheshire and six neighbouring counties with min-max ranges and premium areas.',
  numberOfItems: neighbours.length,
  itemListOrder: 'https://schema.org/ItemListOrderDescending',
  isPartOf: { '@type': 'WebPage', url: 'https://movetocheshire.uk/house-prices' },
  itemListElement: neighbours.map((n, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Observation',
      name: `${n.name} average house price`,
      observationAbout: { '@type': 'AdministrativeArea', name: n.name, containedInPlace: { '@type': 'Country', name: 'England' } },
      observationDate: '2025',
      measuredProperty: { '@type': 'Property', name: 'averageHousePrice' },
      description: n.note,
    },
  })),
};

const wardListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Cheshire West and Chester Ward House Prices',
  description: 'Median house prices for 35 wards in Cheshire West and Chester with population (Census 2021), settlement type, and key attributes.',
  numberOfItems: cheshireWestTowns.length,
  itemListOrder: 'https://schema.org/ItemListOrderDescending',
  isPartOf: { '@type': 'WebPage', url: 'https://movetocheshire.uk/house-prices' },
  itemListElement: cheshireWestTowns.map((town, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Place',
      additionalType: 'https://schema.org/Residence',
      name: town.name,
      description: `${town.type} in Cheshire West and Chester. Population ${town.pop} (Census 2021). ${town.attr}. Median house price ${town.price} (CW&C Council, 2023).`,
      containedInPlace: { '@type': 'AdministrativeArea', name: 'Cheshire West and Chester' },
    },
  })),
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.q,
    acceptedAnswer: { '@type': 'Answer', text: faq.a },
  })),
};
---

<BaseLayout
  title="Cheshire House Prices 2025 | £115k to £666k"
  description="Cheshire house prices average £314,000 (ONS, 2025). Compare 41 towns and 35 wards from £115,000 to £666,000 with data from ONS, Rightmove, and council sources."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(authorityListSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(neighboursListSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(wardListSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <!-- Breadcrumb -->
  <div class="section-pad" style="padding-top: 20px; padding-bottom: 0;">
    <div class="section-inner">
      <nav aria-label="Breadcrumb" style="font-family: Inter, Arial, sans-serif; font-size: 13px; color: #999999;">
        <a href="/" style="color: #999999; text-decoration: none;">Home</a>
        <span style="margin: 0 8px;">/</span>
        <span style="color: #1C1C1E;">House Prices</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="section-pad" style="padding-top: 40px;">
    <div class="section-inner" style="max-width: 720px;">
      <span class="section-label">Cheshire house prices</span>
      <h1 style="font-family: Georgia, serif; font-size: clamp(28px, 4.5vw, 44px); font-weight: 700; color: #1C1C1E; line-height: 1.15; margin: 0 0 20px 0; letter-spacing: -0.02em;">
        Cheshire House Prices: £115k to £666k Across 41 Towns
      </h1>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 18px; line-height: 1.7; color: #444444; margin: 0 0 24px 0;">
        Cheshire averages £314,000 across all property types (PlumPlot/ONS, 2025), 8% above the UK national average of £290,000. Prices range from £115,000 in Ellesmere Port Westminster ward to £1,163,360 for a detached home in Alderley Edge (CW&C Council 2023, Rightmove Feb 2026).
      </p>
      <span style="display: inline-block; font-family: Inter, Arial, sans-serif; font-size: 12px; font-weight: 600; color: #3D5A3E; background-color: rgba(61, 90, 62, 0.08); padding: 6px 12px; letter-spacing: 0.02em;">Last updated: February 2026</span>
      <nav aria-label="Jump to price data" style="display: flex; flex-wrap: wrap; gap: 8px; margin-top: 20px;">
        <a href="#by-authority" style="font-family: Inter, Arial, sans-serif; font-size: 13px; font-weight: 600; color: #3D5A3E; text-decoration: none; border: 1px solid #E5E0D8; padding: 6px 14px; background-color: #FFFFFF; transition: border-color 0.2s, background-color 0.2s;">By Cheshire authority</a>
        <a href="#golden-triangle" style="font-family: Inter, Arial, sans-serif; font-size: 13px; font-weight: 600; color: #3D5A3E; text-decoration: none; border: 1px solid #E5E0D8; padding: 6px 14px; background-color: #FFFFFF; transition: border-color 0.2s, background-color 0.2s;">Cheshire Golden Triangle</a>
        <a href="#by-property-type" style="font-family: Inter, Arial, sans-serif; font-size: 13px; font-weight: 600; color: #3D5A3E; text-decoration: none; border: 1px solid #E5E0D8; padding: 6px 14px; background-color: #FFFFFF; transition: border-color 0.2s, background-color 0.2s;">Cheshire property types</a>
        <a href="#ward-prices" style="font-family: Inter, Arial, sans-serif; font-size: 13px; font-weight: 600; color: #3D5A3E; text-decoration: none; border: 1px solid #E5E0D8; padding: 6px 14px; background-color: #FFFFFF; transition: border-color 0.2s, background-color 0.2s;">35 Cheshire West wards</a>
        <a href="#towns-ranked" style="font-family: Inter, Arial, sans-serif; font-size: 13px; font-weight: 600; color: #3D5A3E; text-decoration: none; border: 1px solid #E5E0D8; padding: 6px 14px; background-color: #FFFFFF; transition: border-color 0.2s, background-color 0.2s;">41 Cheshire towns ranked</a>
        <a href="#vs-neighbours" style="font-family: Inter, Arial, sans-serif; font-size: 13px; font-weight: 600; color: #3D5A3E; text-decoration: none; border: 1px solid #E5E0D8; padding: 6px 14px; background-color: #FFFFFF; transition: border-color 0.2s, background-color 0.2s;">Cheshire vs neighbours</a>
      </nav>
    </div>
  </section>

  <!-- Stat Bar -->
  <section class="section-pad" style="padding-top: 0;">
    <div class="section-inner">
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px;">
        {stats.map((stat) => (
          <div style="background-color: #FFFFFF; border: 1px solid #E5E0D8; padding: 28px 24px;">
            <p class="data-tile-value" style="margin: 0 0 8px 0;">{stat.value}</p>
            <p style="font-family: Inter, Arial, sans-serif; font-size: 14px; font-weight: 600; color: #1C1C1E; margin: 0 0 4px 0;">{stat.label}</p>
            <p style="font-family: Inter, Arial, sans-serif; font-size: 12px; color: #999999; margin: 0;">{stat.source}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Data Sources Explainer -->
  <section style="padding: 0 20px 0 20px;">
    <div class="section-inner" style="max-width: 720px;">
      <p style="font-family: Inter, Arial, sans-serif; font-size: 13px; line-height: 1.65; color: #999999; margin: 0; padding: 16px 0; border-top: 1px solid #E5E0D8;">
        <strong style="color: #444444;">How we built this data.</strong> Move to Cheshire cross-references three sources to create a single county-wide view that no individual source provides. ONS UK HPI (Dec 2025) supplies authority-level averages from Land Registry completed transactions. Rightmove (12 months to Feb 2026) supplies town-level asking and sold prices. CW&C Council (2023) supplies 35 ward-level medians. Where sources diverge, we show ranges and cite both figures. <a href="#methodology" style="color: #3D5A3E; text-decoration: underline;">Full methodology below.</a>
      </p>
    </div>
  </section>

  <!-- Quick Answer -->
  <section class="section-pad">
    <div class="section-inner" style="max-width: 720px;">
      <span class="section-label">Cheshire house price summary</span>
      <h2 style="font-family: Georgia, serif; font-size: clamp(22px, 3vw, 30px); font-weight: 700; color: #1C1C1E; line-height: 1.25; margin: 0 0 24px 0;">How much does a house cost in Cheshire?</h2>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #1C1C1E; margin: 0 0 24px 0; padding-bottom: 20px; border-bottom: 1px solid #E5E0D8;"><strong>Cheshire averages £314,000 across all property types (PlumPlot/ONS, 2025), 8% above the UK average of £290,000.</strong> Cheshire East averages £306,000, up 5.7% year-on-year. Cheshire West averages £266,000, up 2.8%. Warrington averages £252,000, up 6.0% (ONS, Dec 2025). This page compares 4 authorities, 41 towns, and 35 wards from 3 data sources.</p>
      <div style="display: flex; flex-direction: column; gap: 16px;">
        <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0;">Cheshire has 34% detached housing stock versus 22% nationally (Census 2021), which pulls the county average above the UK figure. A detached home in Cheshire East averages £496,000. A terraced home in Cheshire West averages £207,000. A flat in Halton averages £103,000.</p>
        <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0;">Cheshire prices range from £115,000 in Ellesmere Port Westminster ward to £1,163,360 for a detached home in Alderley Edge (CW&C Council 2023, Rightmove Feb 2026). A £1,048,360 spread within a single county makes the headline average unreliable without area and property type breakdowns.</p>
      </div>
    </div>
  </section>

  <!-- Unitary Authority Comparison -->
  <section id="by-authority" class="section-pad" style="background-color: #FFFFFF; border-top: 1px solid #E5E0D8; border-bottom: 1px solid #E5E0D8;">
    <div class="section-inner" style="max-width: 900px;">
      <span class="section-label">Cheshire authority prices</span>
      <h2 style="font-family: Georgia, serif; font-size: clamp(22px, 3vw, 30px); font-weight: 700; color: #1C1C1E; line-height: 1.25; margin: 0 0 12px 0;">What are house prices in each Cheshire authority area?</h2>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 15px; line-height: 1.7; color: #444444; margin: 0 0 28px 0;">Cheshire East averages £306,000, Cheshire West £266,000, Warrington £252,000, and Halton £189,000 (ONS, Dec 2025). Halton is 35% below the county average of £314,000. Cheshire East recorded the strongest year-on-year growth at 5.7%.</p>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 16px;">
        {authorities.map((auth) => (
          <div style="border-left: 3px solid #3D5A3E; background-color: #F9F7F4; padding: 24px;">
            <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; font-weight: 700; color: #1C1C1E; margin: 0 0 4px 0;">{auth.name}</p>
            <p style="font-family: Georgia, serif; font-size: 28px; font-weight: 700; color: #3D5A3E; margin: 0 0 2px 0;">{auth.price}</p>
            <p style="font-family: Inter, Arial, sans-serif; font-size: 13px; font-weight: 600; color: #C4933F; margin: 0 0 16px 0;">{auth.growth} YoY</p>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px;">
              <div><p style="font-family: Inter, Arial, sans-serif; font-size: 11px; color: #999999; margin: 0;">Detached</p><p style="font-family: Inter, Arial, sans-serif; font-size: 14px; font-weight: 600; color: #1C1C1E; margin: 0;">{auth.detached}</p></div>
              <div><p style="font-family: Inter, Arial, sans-serif; font-size: 11px; color: #999999; margin: 0;">Semi</p><p style="font-family: Inter, Arial, sans-serif; font-size: 14px; font-weight: 600; color: #1C1C1E; margin: 0;">{auth.semi}</p></div>
              <div><p style="font-family: Inter, Arial, sans-serif; font-size: 11px; color: #999999; margin: 0;">Terraced</p><p style="font-family: Inter, Arial, sans-serif; font-size: 14px; font-weight: 600; color: #1C1C1E; margin: 0;">{auth.terraced}</p></div>
              <div><p style="font-family: Inter, Arial, sans-serif; font-size: 11px; color: #999999; margin: 0;">Flat</p><p style="font-family: Inter, Arial, sans-serif; font-size: 14px; font-weight: 600; color: #1C1C1E; margin: 0;">{auth.flat}</p></div>
            </div>
          </div>
        ))}
      </div>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 12px; color: #999999; margin: 16px 0 0 0;">Source: ONS UK House Price Index, December 2025. Year-on-year growth compares Dec 2025 to Dec 2024.</p>
    </div>
  </section>

  <!-- Golden Triangle -->
  <section id="golden-triangle" class="section-pad">
    <div class="section-inner" style="max-width: 900px;">
      <span class="section-label">Cheshire Golden Triangle prices</span>
      <h2 style="font-family: Georgia, serif; font-size: clamp(22px, 3vw, 30px); font-weight: 700; color: #1C1C1E; line-height: 1.25; margin: 0 0 12px 0;">What do houses cost in Cheshire's Golden Triangle?</h2>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 15px; line-height: 1.7; color: #444444; margin: 0 0 28px 0;">Golden Triangle houses cost £489,105 in Wilmslow, £606,876 in Knutsford, and £666,489 in Alderley Edge (Rightmove, 12 months to Feb 2026). Alderley Edge detached homes average £1,163,360, 135% above the Cheshire East detached average of £496,000.</p>
      <span class="scroll-hint-label">&larr; &rarr; Scroll for more columns</span>
      <div class="scroll-wrap" style="overflow-x: auto; -webkit-overflow-scrolling: touch; margin-bottom: 28px;">
        <table style="width: 100%; border-collapse: collapse; min-width: 520px;">
          <thead>
            <tr style="border-bottom: 2px solid #3D5A3E; background-color: #F9F7F4;">
              <th style="text-align: left; padding: 10px 8px; font-family: Inter, Arial, sans-serif; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #1C1C1E; position: sticky; left: 0; background-color: #F9F7F4; z-index: 1;">Cheshire Town</th>
              <th style="text-align: right; padding: 10px 8px; font-family: Inter, Arial, sans-serif; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #1C1C1E;">Average</th>
              <th style="text-align: right; padding: 10px 8px; font-family: Inter, Arial, sans-serif; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #1C1C1E;">Detached</th>
              <th style="text-align: right; padding: 10px 8px; font-family: Inter, Arial, sans-serif; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #1C1C1E;">Semi</th>
              <th style="text-align: right; padding: 10px 8px; font-family: Inter, Arial, sans-serif; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #1C1C1E;">Terraced</th>
              <th style="text-align: right; padding: 10px 8px; font-family: Inter, Arial, sans-serif; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #1C1C1E;">Flat</th>
            </tr>
          </thead>
          <tbody>
            {goldenTriangle.map((town, i) => (
              <tr style={`background-color: ${i % 2 === 0 ? '#FFFFFF' : '#F9F7F4'}; border-bottom: 1px solid #E5E0D8;`}>
                <td style={`padding: 10px 8px; font-family: Inter, Arial, sans-serif; font-size: 14px; font-weight: 600; color: #1C1C1E; position: sticky; left: 0; background-color: ${i % 2 === 0 ? '#FFFFFF' : '#F9F7F4'}; z-index: 1; white-space: nowrap;`}>{town.name}</td>
                <td style="padding: 10px 8px; font-family: Inter, Arial, sans-serif; font-size: 14px; font-weight: 700; color: #3D5A3E; text-align: right; white-space: nowrap;">{town.avg}</td>
                <td style="padding: 10px 8px; font-family: Inter, Arial, sans-serif; font-size: 14px; color: #444444; text-align: right; white-space: nowrap;">{town.detached}</td>
                <td style="padding: 10px 8px; font-family: Inter, Arial, sans-serif; font-size: 14px; color: #444444; text-align: right; white-space: nowrap;">{town.semi}</td>
                <td style="padding: 10px 8px; font-family: Inter, Arial, sans-serif; font-size: 14px; color: #444444; text-align: right; white-space: nowrap;">{town.terraced}</td>
                <td style="padding: 10px 8px; font-family: Inter, Arial, sans-serif; font-size: 14px; color: #444444; text-align: right; white-space: nowrap;">{town.flat}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 12px; color: #999999; margin: 12px 0 0 0;">Source: Rightmove, 12 months to early 2026. Poynton verified via data.md. "-" indicates insufficient transaction data for that property type.</p>
    </div>
  </section>

  <!-- Property Type Breakdown -->
  <section id="by-property-type" class="section-pad" style="background-color: #FFFFFF; border-top: 1px solid #E5E0D8; border-bottom: 1px solid #E5E0D8;">
    <div class="section-inner" style="max-width: 900px;">
      <span class="section-label">Cheshire property type prices</span>
      <h2 style="font-family: Georgia, serif; font-size: clamp(22px, 3vw, 30px); font-weight: 700; color: #1C1C1E; line-height: 1.25; margin: 0 0 12px 0;">How much does each property type cost in Cheshire?</h2>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 15px; line-height: 1.7; color: #444444; margin: 0 0 28px 0;">Cheshire detached homes average £496,000 county-wide (ONS, Dec 2025). Flats average £170,000, a £326,000 difference that reflects the county's high proportion of detached stock at 34% versus 22% nationally (Census 2021).</p>
      <span class="scroll-hint-label">&larr; &rarr; Scroll for more columns</span>
      <div class="scroll-wrap" style="overflow-x: auto; -webkit-overflow-scrolling: touch; margin-bottom: 28px;">
        <table style="width: 100%; border-collapse: collapse; min-width: 550px;">
          <thead>
            <tr style="border-bottom: 2px solid #3D5A3E; background-color: #FFFFFF;">
              {['Area', 'Detached', 'Semi-detached', 'Terraced', 'Flat'].map((col) => (
                <th style="text-align: left; padding: 12px; font-family: Inter, Arial, sans-serif; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #1C1C1E;">{col}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {[...propertyTypes, ...selectedWardTypes].map((row, i) => (
              <tr style={`background-color: ${i % 2 === 0 ? '#FFFFFF' : '#F9F7F4'}; border-bottom: 1px solid #E5E0D8; ${i === 4 ? 'border-bottom: 2px solid #E5E0D8;' : ''}`}>
                <td style={`padding: 14px 12px; font-family: Inter, Arial, sans-serif; font-size: 14px; font-weight: ${i < 5 ? '600' : '500'}; color: #1C1C1E;`}>{row.area}</td>
                <td style="padding: 14px 12px; font-family: Inter, Arial, sans-serif; font-size: 14px; color: #444444;">{row.detached}</td>
                <td style="padding: 14px 12px; font-family: Inter, Arial, sans-serif; font-size: 14px; color: #444444;">{row.semi}</td>
                <td style="padding: 14px 12px; font-family: Inter, Arial, sans-serif; font-size: 14px; color: #444444;">{row.terraced}</td>
                <td style="padding: 14px 12px; font-family: Inter, Arial, sans-serif; font-size: 14px; color: #444444;">{row.flat}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 12px; color: #999999; margin: 12px 0 0 0;">Source: ONS UK HPI Dec 2025 (authority rows). Rightmove 12 months to Feb 2026 (town rows). CW&C Council 2023 (Frodsham, Helsby, Northwich). "-" = insufficient data.</p>
    </div>
  </section>

  <!-- Cheshire West Ward Prices -->
  <section id="ward-prices" class="section-pad">
    <div class="section-inner" style="max-width: 900px;">
      <span class="section-label">Cheshire West ward prices</span>
      <h2 style="font-family: Georgia, serif; font-size: clamp(22px, 3vw, 30px); font-weight: 700; color: #1C1C1E; line-height: 1.25; margin: 0 0 12px 0;">What are house prices in each Cheshire West ward?</h2>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 15px; line-height: 1.7; color: #444444; margin: 0 0 20px 0;">Cheshire West and Chester ward-level prices range from £115,000 in Ellesmere Port Westminster to £487,500 in Tattenhall (CW&C Council, 2023). Chester wards span from £172,000 in Blacon to £340,000 in Handbridge Park and Upton.</p>

      <!-- Filter controls -->
      <div class="ward-filter-bar" id="ward-filters">
        <input type="text" class="ward-search" id="ward-search" placeholder="Search Cheshire West ward or type..." autocomplete="off" />
        <div class="ward-range-group">
          <span class="ward-range-label">Max price</span>
          <input type="range" class="ward-range" id="ward-price-range" min="100000" max="500000" step="10000" value="500000" />
          <span class="ward-range-value" id="ward-price-label">£500k</span>
        </div>
      </div>
      <p class="ward-count" id="ward-count">Showing 35 of 35 Cheshire West wards</p>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 10px;" id="ward-grid">
        {cheshireWestTowns.map((town) => {
          const numPrice = parseInt(town.price.replace(/[£,]/g, ''));
          return (
            <article class="ward-card" data-price={numPrice} data-name={town.name.toLowerCase()} data-type={town.type.toLowerCase()} style={`padding: 16px; border-left: 3px solid ${town.level === 'premium' ? '#C4933F' : town.level === 'high' ? '#3D5A3E' : town.level === 'mid' ? '#6B8F71' : '#8BA38F'}; background-color: #F9F7F4;`}>
              <p style="font-family: Inter, Arial, sans-serif; font-size: 14px; font-weight: 700; color: #1C1C1E; margin: 0 0 4px 0;">{town.name}</p>
              <p style="font-family: Georgia, serif; font-size: 20px; font-weight: 700; color: #1C1C1E; margin: 0 0 8px 0;">{town.price}</p>
              <p style="display: flex; flex-wrap: wrap; gap: 4px; margin: 0;">
                <span style="font-family: Inter, Arial, sans-serif; font-size: 11px; color: #3D5A3E; background-color: rgba(61, 90, 62, 0.08); padding: 2px 7px; white-space: nowrap;">Pop. {town.pop}</span>
                <span style="font-family: Inter, Arial, sans-serif; font-size: 11px; color: #1C1C1E; background-color: rgba(28, 28, 30, 0.05); padding: 2px 7px; white-space: nowrap;">{town.type}</span>
