            <p style="font-family: Inter, Arial, sans-serif; font-size: 15px; line-height: 1.65; color: #444444; margin: 0 0 16px 0; font-style: italic;">"{card.question}"</p>
            <p style="font-family: Inter, Arial, sans-serif; font-size: 15px; line-height: 1.75; color: #444444; margin: 0;">{card.answer}</p>
