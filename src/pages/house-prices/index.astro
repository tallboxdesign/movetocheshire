---
import BaseLayout from '../../layouts/BaseLayout.astro';

const stats = [
  { value: '£313,000', label: 'County average', source: 'ONS, Nov 2025' },
  { value: '£328,000', label: 'Cheshire East', source: 'ONS, Nov 2025' },
  { value: '£265,000', label: 'Cheshire West', source: 'ONS, Nov 2025' },
];

const faqs = [
  { q: 'How do Cheshire house prices compare to Manchester?', a: "Cheshire East averages around £328,000 - roughly 40% above Greater Manchester's average of around £230,000. The premium reflects school quality, lower density, and the commuter premium for train access into Manchester Piccadilly. In specific areas like Wilmslow and Alderley Edge the gap widens considerably." },
  { q: 'Are house prices in Cheshire still rising in 2026?', a: 'After a correction from the 2022 peak, prices in Cheshire stabilised through 2024 and began edging upward again in late 2025. Annual growth is running at approximately 2-3% county-wide, though Golden Triangle villages are seeing stronger demand. Data is updated quarterly from ONS.' },
  { q: 'What is the most expensive area in Cheshire?', a: 'Alderley Edge consistently records the highest median prices, typically between £650,000 and £800,000 for a family home. Prestbury and parts of Wilmslow (particularly Heybridge Lane and Stanneylands) follow closely.' },
  { q: 'What does £400,000 buy in Cheshire?', a: 'In Northwich or Macclesfield, £400,000 will buy a detached four-bedroom house with a garden. In Knutsford the same budget reaches a large semi-detached or a modest detached. In Wilmslow or Alderley Edge, £400,000 reaches a two-bedroom apartment or a smaller terraced property.' },
  { q: 'Is stamp duty a significant cost at Cheshire price levels?', a: 'At the county average of £313,000, stamp duty for a primary residence is £3,150. At Wilmslow median prices around £500,000, the liability rises to £12,500. Second home buyers pay an additional 3% surcharge on the full purchase price.' },
];

const spokeCards = [
  { title: 'Average House Price in Cheshire', description: 'County-wide price data by property type, updated quarterly from ONS and Rightmove.', href: '/house-prices/average-house-price-cheshire' },
  { title: 'Wilmslow House Prices', description: 'Detailed price breakdowns by street and property type with year-on-year trends.', href: '/house-prices/wilmslow-house-prices' },
  { title: 'Stamp Duty in Cheshire', description: 'SDLT calculations for typical Cheshire prices - first-time buyer, standard, and second home.', href: '/buying-guide/stamp-duty-cheshire' },
  { title: 'Is Now a Good Time to Buy?', description: 'An independent, data-led view of Cheshire market conditions in 2025-26.', href: '/investment/good-time-buy-cheshire' },
];

const tableRows = [
  { area: 'Cheshire East', price: '£328,000', vs: '+43% above UK avg' },
  { area: 'Cheshire West', price: '£265,000', vs: '+16% above UK avg' },
  { area: 'Wilmslow', price: '£497,000', vs: '+117% above UK avg' },
  { area: 'Chester', price: '£258,000', vs: '+13% above UK avg' },
  { area: 'UK National', price: '£229,000', vs: 'Baseline' },
];

const relatedHubs = [
  { label: 'Where to Live', href: '/where-to-live', description: 'Area-by-area comparisons of every major town and village.', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6' },
  { label: 'Investment', href: '/investment', description: 'Market conditions, price trends, and whether now is the right time to buy.', icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6' },
  { label: 'Buying Guide', href: '/buying-guide', description: 'Stamp duty, surveys, conveyancing, and what to expect from the purchase process.', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z' },
];
---

<BaseLayout
  title="Cheshire House Prices: What You'll Actually Pay | movetocheshire.uk"
  description="County-wide Cheshire house price data by area and property type - drawn from ONS and Rightmove, updated quarterly. No estate agent spin."
>
  <!-- Hero -->
  <section style="max-width: 1160px; margin: 0 auto; padding: 64px 24px 48px;">
    <div style="max-width: 720px;">
      <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 20px;">
        <span style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: #2d7a4f;">Property Data</span>
        <span style="color: #ccc;">·</span>
        <a href="/" style="font-size: 12px; color: #999; text-decoration: none;">Home</a>
        <span style="color: #ccc;">/</span>
        <span style="font-size: 12px; color: #555;">House Prices</span>
      </div>
      <h1 style="font-family: Georgia, serif; font-size: clamp(28px, 4.5vw, 46px); font-weight: 700; color: #1a2332; line-height: 1.12; letter-spacing: -0.02em; margin: 0 0 18px 0;">
        Cheshire House Prices: What You'll Actually Pay
      </h1>
      <p style="font-size: 18px; line-height: 1.65; color: #3d4c5c; margin: 0 0 24px 0; max-width: 620px;">
        County-wide price data by area and property type - drawn from ONS and Rightmove, updated quarterly, with no estate agent spin.
      </p>
      <span style="display: inline-block; font-size: 12px; color: #888; background-color: #f4f2ee; padding: 5px 12px; border-radius: 4px; font-weight: 500;">
        Last updated: February 2026
      </span>
    </div>
  </section>

  <!-- Stat Bar -->
  <section style="background-color: #f7f5f2; padding: 40px 24px;">
    <div style="max-width: 1160px; margin: 0 auto;">
      <div class="grid grid-cols-1 sm:grid-cols-3" style="gap: 1px; background-color: #e8e4de; border: 1px solid #e8e4de;">
        {stats.map((stat) => (
          <div style="background-color: #ffffff; padding: 32px 28px; display: flex; flex-direction: column; gap: 6px;">
            <span style="font-family: Georgia, serif; font-size: 38px; font-weight: 700; color: #2d7a4f; line-height: 1; letter-spacing: -0.02em;">{stat.value}</span>
            <span style="font-size: 15px; font-weight: 600; color: #1a2332;">{stat.label}</span>
            <span style="font-size: 11px; color: #999; margin-top: 4px;">Source: {stat.source}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Answer Block -->
  <section style="max-width: 1160px; margin: 0 auto; padding: 64px 24px;">
    <div style="max-width: 720px;">
      <span style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: #2d7a4f; display: block; margin-bottom: 20px;">The honest picture</span>
      <div style="display: flex; flex-direction: column; gap: 20px;">
        <p style="font-size: 16px; line-height: 1.8; color: #2a3442; margin: 0;">Cheshire's average house price sits at approximately £313,000 - around 37% above the UK national average of £229,000. That gap has persisted for over a decade and is structural rather than speculative: it reflects consistently strong school performance, Green Belt constraints on new supply, and proximity to major employment centres in Manchester.</p>
        <p style="font-size: 16px; line-height: 1.8; color: #2a3442; margin: 0;">The county is not uniform. Cheshire East, which covers the commuter towns of Wilmslow, Knutsford, and Alderley Edge, averages £328,000. Cheshire West, covering Chester, Northwich, and Ellesmere Port, averages closer to £265,000. That £63,000 difference largely reflects train access into Manchester rather than any meaningful quality-of-life gap.</p>
        <p style="font-size: 16px; line-height: 1.8; color: #2a3442; margin: 0;">Within those averages, variance is significant. Wilmslow's median price is nearly double the Cheshire West average. At the other end, towns like Winsford and Ellesmere Port are at or below the UK average. Most buyers relocating from southern England will find Cheshire offers genuine value at equivalent or superior quality of life - but only if they choose the right town for their budget.</p>
        <p style="font-size: 16px; line-height: 1.8; color: #2a3442; margin: 0;">Price-to-income ratios in Cheshire East are elevated - similar to outer London - so affordability is real for buyers at median salary levels. The strongest value-for-money cases are found in Northwich, Macclesfield, and parts of Chester, where prices remain accessible while still offering good schools and rail connectivity.</p>
      </div>
    </div>
  </section>

  <!-- Relocator Question Block -->
  <section style="background-color: #f7f5f2; padding: 64px 24px;">
    <div style="max-width: 1160px; margin: 0 auto;">
      <span style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: #2d7a4f; display: block; margin-bottom: 32px;">Questions from people in the process</span>
      <div style="display: flex; flex-direction: column; gap: 20px; max-width: 760px;">
        {[
          { initials: 'RB', location: 'Moving from Surrey', question: '"We have a budget of £550,000. In Surrey that buys a tired three-bed semi. What does the same money get in Cheshire?"', answer: "In most of Cheshire East, £550,000 is a strong budget. In Knutsford it reaches a large detached four or five-bedroom house with a garden and double garage. In Wilmslow you're into high-spec semi-detached or a detached on the outskirts. In Northwich, the same budget puts you in the top tier of the market - you could buy a new-build five-bedroom detached with change to spare." },
          { initials: 'MH', location: 'Moving from North London', question: '"I\'ve seen Rightmove prices for Alderley Edge and they look comparable to Zone 4 London. Is there actually a price advantage?"', answer: "Alderley Edge is the exception, not the rule. It's Cheshire's most expensive postcode and prices there do approach outer London levels for premium properties. Widen the search to Wilmslow proper, Knutsford, or Macclesfield and the comparison shifts substantially. A budget of £700,000 in Zone 4 typically buys a semi-detached. In Knutsford that budget reaches a substantial detached house with significant outdoor space." },
        ].map((item) => (
          <div style="background-color: #ffffff; border-radius: 8px; border-left: 4px solid #2d7a4f; padding: 28px 32px; box-shadow: 0 1px 4px rgba(0,0,0,0.06);">
            <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
              <div style="width: 36px; height: 36px; border-radius: 50%; background-color: #e6f2eb; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                <span style="font-size: 12px; font-weight: 700; color: #2d7a4f;">{item.initials}</span>
              </div>
              <span style="font-size: 12px; font-weight: 600; color: #888; text-transform: uppercase; letter-spacing: 0.06em;">{item.location}</span>
            </div>
            <p style="font-style: italic; font-size: 16px; line-height: 1.65; color: #2a3442; margin: 0 0 16px 0; font-weight: 500;">{item.question}</p>
            <p style="font-size: 15px; line-height: 1.75; color: #3d4c5c; margin: 0;">{item.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- People Also Ask Accordion -->
  <section style="max-width: 1160px; margin: 0 auto; padding: 64px 24px;">
    <div style="max-width: 760px;">
      <span style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: #2d7a4f; display: block; margin-bottom: 8px;">People also ask</span>
      <h2 style="font-family: Georgia, serif; font-size: clamp(20px, 3vw, 28px); font-weight: 700; color: #1a2332; margin: 0 0 32px 0; line-height: 1.2; letter-spacing: -0.01em;">
        Questions people ask before moving to Cheshire
      </h2>
      <div style="border-top: 1px solid #e8e4de;">
        {faqs.map((faq) => (
          <details style="border-bottom: 1px solid #e8e4de;">
            <summary style="padding: 20px 0; cursor: pointer; font-family: Inter, Arial, sans-serif; font-size: 16px; font-weight: 600; color: #1a2332; line-height: 1.4; list-style: none; display: flex; justify-content: space-between; align-items: center; gap: 16px;">
              {faq.q}
              <span style="flex-shrink: 0; color: #2d7a4f; font-size: 20px; font-weight: 300;">+</span>
            </summary>
            <p style="font-family: Inter, Arial, sans-serif; font-size: 15px; line-height: 1.75; color: #3d4c5c; margin: 0 0 20px 0; padding-right: 36px;">
              {faq.a}
            </p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Spoke Card Grid -->
  <section style="background-color: #f7f5f2; padding: 64px 24px;">
    <div style="max-width: 1160px; margin: 0 auto;">
      <span style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: #2d7a4f; display: block; margin-bottom: 8px;">Detailed guides</span>
      <h2 style="font-family: Georgia, serif; font-size: clamp(20px, 3vw, 28px); font-weight: 700; color: #1a2332; margin: 0 0 32px 0; line-height: 1.2; letter-spacing: -0.01em;">
        Explore house price guides
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2" style="gap: 16px;">
        {spokeCards.map((card) => (
          <a href={card.href} style="text-decoration: none;">
            <article class="pillar-card" style="height: 100%; display: flex; flex-direction: column; gap: 10px;">
              <h3 style="font-family: Inter, Arial, sans-serif; font-size: 16px; font-weight: 700; color: #1a2332; margin: 0; line-height: 1.3;">{card.title}</h3>
              <p style="font-size: 14px; line-height: 1.6; color: #6b7a8d; margin: 0; flex-grow: 1;">{card.description}</p>
              <span style="font-size: 13px; font-weight: 600; color: #2d7a4f; display: flex; align-items: center; gap: 4px;">
                Read guide
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
              </span>
            </article>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison Table -->
  <section style="max-width: 1160px; margin: 0 auto; padding: 64px 24px;">
    <span style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: #2d7a4f; display: block; margin-bottom: 8px;">Area breakdown</span>
    <h2 style="font-family: Georgia, serif; font-size: clamp(20px, 3vw, 28px); font-weight: 700; color: #1a2332; margin: 0 0 32px 0; line-height: 1.2; letter-spacing: -0.01em;">House prices by area</h2>
    <div style="overflow-x: auto;">
      <table style="width: 100%; border-collapse: collapse; min-width: 500px;">
        <thead>
          <tr style="border-bottom: 2px solid #1a2332;">
            {['Area', 'Average Price', 'vs UK Average'].map((col) => (
              <th style="text-align: left; padding: 12px 16px; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #1a2332;">{col}</th>
            ))}
          </tr>
        </thead>
        <tbody>
          {tableRows.map((row, i) => (
            <tr style={`background-color: ${i % 2 === 0 ? '#ffffff' : '#f7f5f2'}; border-bottom: 1px solid #e8e4de;`}>
              <td style={`padding: 16px; font-size: 15px; font-weight: ${row.area === 'UK National' ? 500 : 600}; color: #1a2332;`}>{row.area}</td>
              <td style="padding: 16px; font-size: 15px; font-weight: 600; color: #2d7a4f; font-family: Georgia, serif;">{row.price}</td>
              <td style={`padding: 16px; font-size: 14px; color: ${row.area === 'UK National' ? '#888' : '#3d4c5c'};`}>{row.vs}</td>
            </tr>
          ))}
        </tbody>
        <tfoot>
          <tr><td colspan="3" style="padding: 12px 16px; font-size: 11px; color: #999;">Source: ONS UK House Price Index, November 2025. Figures are median transaction prices.</td></tr>
        </tfoot>
      </table>
    </div>
  </section>

  <!-- Good to Know -->
  <section style="max-width: 1160px; margin: 0 auto; padding: 0 24px 64px;">
    <div style="border-left: 4px solid #2d7a4f; background-color: #f0f8f3; padding: 28px 32px; max-width: 760px;">
      <span style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #2d7a4f; display: block; margin-bottom: 10px;">Good to know</span>
      <p style="font-size: 15px; line-height: 1.8; color: #2a3442; margin: 0;">
        Cheshire averages include a wide range of property types that can mislead. The county has an unusually high proportion of large detached homes - which pulls the average up - alongside a significant stock of ex-council and affordable housing that pulls it down. When comparing your target area, look at median prices for your specific property type rather than the headline average.
      </p>
    </div>
  </section>

  <!-- Community Strip -->
  <section style="background-color: #f2efe9; padding: 56px 24px;">
    <div style="max-width: 1160px; margin: 0 auto;">
      <div style="max-width: 760px;">
        <div style="display: flex; align-items: flex-start; gap: 16px;">
          <div style="flex-shrink: 0; margin-top: 2px;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#2d7a4f" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" /></svg>
          </div>
          <p style="font-style: italic; font-size: 17px; line-height: 1.8; color: #2a3442; margin: 0;">
            "Most people moving from London find that Cheshire house prices feel almost artificially low for the quality of property and location on offer - until they look more closely at the commuter towns. Wilmslow and Alderley Edge prices have converged significantly with outer London over the past decade, driven by remote-work-era demand. The genuine value is now found in the second-tier towns: Knutsford, Macclesfield, and Northwich, where prices remain rational and the quality of life argument is just as strong."
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Hubs -->
  <section style="max-width: 1160px; margin: 0 auto; padding: 64px 24px;">
    <span style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: #2d7a4f; display: block; margin-bottom: 8px;">Related guides</span>
    <h2 style="font-family: Georgia, serif; font-size: clamp(18px, 2.5vw, 24px); font-weight: 700; color: #1a2332; margin: 0 0 32px 0; line-height: 1.2; letter-spacing: -0.01em;">Explore the full picture</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3" style="gap: 16px;">
      {relatedHubs.map((hub) => (
        <a href={hub.href} style="text-decoration: none;">
          <div class="pillar-card" style="display: flex; flex-direction: column; gap: 10px;">
            <div style="width: 36px; height: 36px; background-color: #e6f2eb; border-radius: 6px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2d7a4f" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={hub.icon} /></svg>
            </div>
            <span style="font-size: 15px; font-weight: 700; color: #1a2332;">{hub.label}</span>
            <span style="font-size: 13px; line-height: 1.55; color: #6b7a8d;">{hub.description}</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
