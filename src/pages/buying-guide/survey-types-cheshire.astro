---
import BaseLayout from '../../layouts/BaseLayout.astro';

const surveyLevels = [
  { feature: 'Cost range', level1: '£300-£950', level2: '£400-£1,000', level3: '£600-£1,500+' },
  { feature: 'Inspection depth', level1: 'Visual only', level2: 'All accessible areas', level3: 'Comprehensive structural' },
  { feature: 'Condition ratings', level1: 'Traffic light', level2: 'Detailed with advice', level3: 'Full technical analysis' },
  { feature: 'Repair advice', level1: 'No', level2: 'Yes', level3: 'Detailed with cost estimates' },
  { feature: 'Valuation', level1: 'No', level2: 'Optional upgrade', level3: 'No (separate)' },
  { feature: 'Duration', level1: '1-2 hours', level2: '2-4 hours', level3: '4-8 hours' },
  { feature: 'Best for', level1: 'New builds, under 10 years', level2: 'Standard post-1960 homes', level3: 'Pre-1960, listed, complex' },
];

const surveyCosts = [
  { price: '185,000', location: 'Crewe', level2: '£400-£500', level3: '£630-£750' },
  { price: '220,000', location: 'Northwich', level2: '£400-£550', level3: '£650-£800' },
  { price: '266,000', location: 'Chester avg', level2: '£450-£600', level3: '£700-£850' },
  { price: '300,000', location: 'Macclesfield', level2: '£450-£650', level3: '£750-£900' },
  { price: '350,000', location: 'Knutsford entry', level2: '£500-£700', level3: '£800-£1,000' },
  { price: '400,000', location: 'Wilmslow entry', level2: '£550-£750', level3: '£850-£1,050' },
  { price: '480,000', location: 'Knutsford avg', level2: '£600-£800', level3: '£900-£1,100' },
  { price: '550,000', location: 'Wilmslow avg', level2: '£650-£850', level3: '£950-£1,200' },
  { price: '750,000', location: 'Alderley Edge', level2: '£800-£1,000', level3: '£1,200-£1,500' },
  { price: '1,000,000', location: 'Prestbury', level2: '£900-£1,000', level3: '£1,400-£1,800' },
];

const townSurveyGuide = [
  { town: 'Chester', stock: 'Sandstone, medieval, Georgian', recommended: 'Level 3', risks: 'Sandstone erosion, lime mortar decay, lead pipes, Conservation Area restrictions' },
  { town: 'Nantwich', stock: 'Timber-framed, 15th-17th century', recommended: 'Level 3', risks: 'Timber rot, beetle infestation, wattle-and-daub degradation, listed building consent' },
  { town: 'Knutsford', stock: 'Victorian, Edwardian, period character', recommended: 'Level 2 or 3', risks: 'Slate roof deterioration, damp in solid-wall construction, chimney stack movement' },
  { town: 'Wilmslow', stock: 'Mixed period and modern detached', recommended: 'Level 2', risks: 'Flat roof sections on extensions, cavity wall tie corrosion on 1960s-1980s builds' },
  { town: 'Alderley Edge', stock: 'Large detached, period and luxury', recommended: 'Level 2 or 3', risks: 'Complex roof structures, basement damp, sandstone boundary walls, annexe compliance' },
  { town: 'Prestbury', stock: 'Premium detached, mixed period', recommended: 'Level 2 or 3', risks: 'Extensive grounds drainage, outbuilding structural integrity, historical extensions' },
  { town: 'Macclesfield', stock: 'Victorian terraces, stone-built', recommended: 'Level 2', risks: 'Stone pointing deterioration, rear extension subsidence, shared drainage' },
  { town: 'Crewe', stock: 'Post-war semis, modern estates', recommended: 'Level 1 or 2', risks: 'NHBC warranty coverage on new builds, cavity insulation defects on 1970s stock' },
  { town: 'Northwich', stock: 'Mixed 20th century, new builds', recommended: 'Level 2', risks: 'Brine subsidence (high risk zone), salt search mandatory, ground movement monitoring' },
  { town: 'Winsford', stock: 'Post-war estates, modern builds', recommended: 'Level 1 or 2', risks: 'Active salt mine proximity, ground stability assessment on older properties' },
  { town: 'Frodsham', stock: 'Victorian, sandstone, modern infill', recommended: 'Level 2', risks: 'Sandstone damp absorption, hillside drainage, radon in western wards' },
];

const faqs = [
  { question: 'Do I need a survey on a new build in Cheshire?', answer: 'A snagging survey (£300-£500) is more appropriate than a full RICS survey for new builds under NHBC warranty. The snagging inspection checks for cosmetic defects, incomplete finishes, and building regulation compliance issues before the developer\'s handover period expires. NHBC structural warranties cover major defects for 10 years, but the warranty does not cover poor workmanship or cosmetic problems identified after the builder\'s two-year rectification period. Cheshire new builds in Crewe, Winsford, and Northwich developments are covered by this approach.' },
  { question: 'Can I get a survey before my offer is accepted?', answer: 'No. RICS surveyors require access to the property interior, which the seller grants only after accepting an offer. The standard sequence in Cheshire is: offer accepted, mortgage application submitted, surveyor instructed. Instructing a surveyor before an accepted offer wastes the fee if another buyer secures the property. The mortgage lender commissions its own valuation separately - this is not a survey and does not check the property condition.' },
  { question: 'What happens if the survey finds serious problems?', answer: 'Three options exist after a survey flags significant defects. Renegotiate the purchase price by the estimated repair cost - surveyors provide repair cost ranges in Level 2 and detailed estimates in Level 3 reports. Request the seller completes repairs before exchange, verified by a re-inspection. Withdraw from the purchase entirely, losing only the survey fee (£400-£1,500) and any conveyancing costs incurred to that point. In Cheshire, subsidence findings from the salt search or survey require specialist ground investigation before lenders approve the mortgage.' },
  { question: 'Is a mortgage valuation the same as a survey?', answer: 'No. A mortgage valuation confirms the property is adequate security for the loan - it protects the lender, not the buyer. The valuer spends 15-30 minutes on site and checks the property exists, is habitable, and is worth approximately the purchase price. A RICS survey (Level 2 or 3) inspects the property condition in detail over 2-8 hours, identifying defects, repair costs, and risks. The mortgage valuation does not check for damp, subsidence, roof condition, electrical safety, or any of the structural and environmental issues a survey examines.' },
  { question: 'How do I find a surveyor in Cheshire?', answer: 'The RICS Find a Surveyor directory (rics.org/find-a-surveyor) lists chartered surveyors by location and specialism. Filter by "Building Survey" or "HomeBuyer Report" and set the location to Cheshire. Local knowledge matters - a surveyor familiar with Chester\'s sandstone construction, Nantwich\'s timber frames, or Northwich\'s subsidence history provides more relevant commentary than a generalist. Expect 1-2 weeks between instruction and the completed report. Fees are agreed upfront and paid before or on the day of inspection.' },
  { question: 'How long does a Cheshire property survey take?', answer: 'A Level 1 Condition Report takes 1-2 hours on site. A Level 2 HomeBuyer Report requires 2-4 hours depending on property size. A Level 3 Building Survey takes 4-8 hours for a full structural inspection. The written report arrives 3-5 working days after the site visit. Larger properties in the Golden Triangle - particularly those with outbuildings, annexes, or extensive grounds - extend toward the upper time range. Chester properties with cellars, Nantwich listed buildings, and properties flagged for subsidence risk add inspection time.' },
  { question: 'What is a snagging survey?', answer: 'A snagging survey is a pre-handover inspection of a new-build property that identifies cosmetic defects, incomplete work, and building regulation non-compliance before the buyer moves in. Common findings include poorly fitted doors, unfinished paintwork, gaps in sealant, drainage gradient errors, and minor plumbing faults. The survey costs £300-£500 and takes 2-4 hours. The developer is obligated to fix snagging items within the NHBC two-year builder rectification period. Snagging surveys are distinct from RICS surveys - they assess build quality against the specification, not structural condition.' },
  { question: 'Should I attend the survey in person?', answer: 'RICS surveyors permit buyers to attend the tail end of the inspection (the final 30-60 minutes) on most Level 2 and Level 3 surveys. Attending allows the surveyor to point out specific issues in context - showing you the crack pattern in a Chester sandstone wall or the damp readings in a Nantwich cellar is more informative than reading about it in the report. Not all surveyors offer this, so confirm when instructing. Do not attend the full inspection - the surveyor needs to work methodically without conversation.' },
];

const relatedSpokes = [
  { label: 'Stamp Duty in Cheshire', href: '/buying-guide/stamp-duty-cheshire', tag: 'Buying Guide' },
  { label: 'Average House Price in Cheshire', href: '/house-prices/average-house-price-cheshire', tag: 'Prices' },
  { label: 'Best Places to Live in Cheshire', href: '/where-to-live/best-places-cheshire', tag: 'Area Guide' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://movetocheshire.uk' },
    { '@type': 'ListItem', position: 2, name: 'Buying Guide', item: 'https://movetocheshire.uk/buying-guide' },
    { '@type': 'ListItem', position: 3, name: 'Survey Types in Cheshire', item: 'https://movetocheshire.uk/buying-guide/survey-types-cheshire' },
  ],
};

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How to choose the right survey for a Cheshire property',
  step: [
    { '@type': 'HowToStep', text: 'Assess the property age - new builds (under 10 years) need Level 1, post-1960 standard homes need Level 2, pre-1960 and listed buildings need Level 3' },
    { '@type': 'HowToStep', text: 'Check Cheshire area risks - Chester sandstone, Nantwich timber frames, and Northwich subsidence zones increase survey requirements' },
    { '@type': 'HowToStep', text: 'Compare the three RICS survey levels by inspection depth, cost, and the repair advice each provides' },
    { '@type': 'HowToStep', text: 'Get quotes from local RICS-accredited surveyors with experience in your specific Cheshire town and property type' },
  ],
};

const webApplicationSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  additionalType: 'https://schema.org/FinancialProduct',
  name: 'Cheshire Survey Recommendation Tool',
  description: 'Recommends the appropriate RICS survey level for Cheshire properties based on property age, location, and purchase price. Provides cost estimates and Cheshire-specific risk notes.',
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'Web browser',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'GBP' },
  areaServed: {
    '@type': 'AdministrativeArea',
    name: 'Cheshire',
    containedInPlace: { '@type': 'Country', name: 'England' },
  },
  audience: { '@type': 'Audience', audienceType: 'Home buyers purchasing property in Cheshire' },
  potentialAction: {
    '@type': 'UseAction',
    name: 'Get a Cheshire survey recommendation',
    target: 'https://movetocheshire.uk/buying-guide/survey-types-cheshire#recommendation-tool',
  },
  isPartOf: { '@type': 'WebPage', url: 'https://movetocheshire.uk/buying-guide/survey-types-cheshire' },
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Survey Types for Cheshire Properties',
  description: 'RICS Level 1, 2, and 3 property surveys explained for Cheshire housing stock. Covers survey costs at 10 Cheshire price points, town-by-town recommendations for Chester, Nantwich, Knutsford, Wilmslow, and the Golden Triangle, plus Cheshire-specific risks including brine subsidence and the mandatory salt search.',
  datePublished: '2026-02-26',
  dateModified: '2026-02-26',
  author: { '@type': 'Organization', name: 'movetocheshire.uk' },
  publisher: { '@type': 'Organization', name: 'movetocheshire.uk', url: 'https://movetocheshire.uk' },
};
---

<BaseLayout
  title="Survey Types for Cheshire Properties | RICS Levels 1, 2 & 3 | movetocheshire.uk"
  description="RICS property survey types explained for Cheshire housing stock. Level 1, 2, and 3 costs at 10 price points from Crewe to Prestbury. Town-by-town recommendations covering Chester sandstone, Nantwich timber frames, brine subsidence, and Golden Triangle period homes."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webApplicationSchema)} />
  </Fragment>

  <!-- Breadcrumb -->
  <div class="section-pad" style="padding-top: 20px; padding-bottom: 0;">
    <div class="section-inner">
      <nav aria-label="Breadcrumb" style="font-family: Inter, Arial, sans-serif; font-size: 13px; color: #999999;">
        <a href="/" style="color: #999999; text-decoration: none;">Home</a>
        <span style="margin: 0 8px;">/</span>
        <a href="/buying-guide" style="color: #999999; text-decoration: none;">Buying Guide</a>
        <span style="margin: 0 8px;">/</span>
        <span style="color: #1C1C1E;">Survey Types</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="section-pad" style="padding-top: 40px;">
    <div class="section-inner" style="max-width: 720px;">
      <span class="section-label">Property surveys</span>
      <h1 style="font-family: Georgia, serif; font-size: clamp(28px, 4.5vw, 44px); font-weight: 700; color: #1C1C1E; line-height: 1.15; margin: 0 0 20px 0; letter-spacing: -0.02em;">Survey Types for Cheshire Properties</h1>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 18px; line-height: 1.7; color: #444444; margin: 0 0 24px 0;">
        Cheshire's housing stock spans six centuries of construction methods, and the correct RICS survey level depends on both property age and location. This 2026 guide covers survey costs at 10 Cheshire price points from Crewe to Prestbury, the mandatory salt search, and town-by-town recommendations for Chester's sandstone, Nantwich's timber frames, and the Golden Triangle's period homes.
      </p>
      <span style="display: inline-block; font-family: Inter, Arial, sans-serif; font-size: 12px; font-weight: 600; color: #3D5A3E; background-color: rgba(61, 90, 62, 0.08); padding: 6px 12px; letter-spacing: 0.02em;">Last updated: February 2026</span>
      <nav aria-label="Page sections" style="display: flex; flex-wrap: wrap; gap: 8px; margin-top: 20px;">
        {[
          { label: 'Survey levels', href: '#survey-levels' },
          { label: 'Cheshire costs', href: '#cheshire-costs' },
          { label: 'Town guide', href: '#town-guide' },
          { label: 'Cheshire issues', href: '#cheshire-issues' },
          { label: 'Renegotiation', href: '#renegotiation' },
          { label: 'FAQ', href: '#faq' },
        ].map((link) => (
          <a href={link.href} style="font-family: Inter, Arial, sans-serif; font-size: 13px; font-weight: 500; color: #3D5A3E; text-decoration: none; padding: 5px 12px; border: 1px solid rgba(61, 90, 62, 0.25); transition: border-color 0.2s, background-color 0.2s;">{link.label}</a>
        ))}
      </nav>
    </div>
  </section>

  <!-- Stat Bar -->
  <section class="section-pad" style="padding-top: 0;">
    <div class="section-inner">
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px;">
        {[
          { value: '85%', label: 'Cheshire property surveys flag at least one issue', source: 'RICS, 2025' },
          { value: '£8,000', label: 'Average Cheshire buyer saving from survey findings', source: 'Compare My Move, 2025' },
          { value: '£79', label: 'Cheshire Salt Search (mandatory)', source: 'Law Society' },
        ].map((stat) => (
          <div style="background-color: #FFFFFF; border: 1px solid #E5E0D8; padding: 28px 24px;">
            <p class="data-tile-value" style="margin: 0 0 8px 0;">{stat.value}</p>
            <p style="font-family: Inter, Arial, sans-serif; font-size: 14px; font-weight: 600; color: #1C1C1E; margin: 0 0 4px 0;">{stat.label}</p>
            <p style="font-family: Inter, Arial, sans-serif; font-size: 12px; color: #999999; margin: 0;">{stat.source}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TLDR -->
  <section class="section-pad">
    <div class="section-inner" style="max-width: 720px;">
      <span class="section-label">Cheshire survey summary</span>
      <h2 style="font-family: Georgia, serif; font-size: clamp(22px, 3vw, 30px); font-weight: 700; color: #1C1C1E; line-height: 1.25; margin: 0 0 24px 0;">
        Most Cheshire buyers need a Level 2 survey - but older towns need Level 3
      </h2>
      <div style="display: flex; flex-direction: column; gap: 16px;">
        <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #1C1C1E; margin: 0;"><strong>A property survey is a professional inspection that assesses the structural condition, defects, and repair requirements of a building before purchase</strong> (RICS). Three standardised levels exist - Level 1 (visual), Level 2 (detailed), and Level 3 (comprehensive structural) - each covering progressively more of the property's fabric and systems.</p>
        <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #1C1C1E; margin: 0;"><strong>Cheshire's housing stock spans six centuries of construction methods</strong>, from Nantwich's 15th-century timber frames and Chester's Georgian sandstone terraces to post-war estates in Crewe and modern developments across Northwich. The appropriate survey level depends on both the property's age and its Cheshire location - a Victorian terrace in Chester requires Level 3 for sandstone assessment, while the same age property in Macclesfield needs only Level 2.</p>
        <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0;">Level 2 HomeBuyer Reports suit standard post-1960 properties across Cheshire's commuter towns - Wilmslow, Macclesfield, Frodsham, and modern Crewe estates. Level 3 Building Surveys are necessary for Chester's sandstone buildings, Nantwich's timber frames, and period homes throughout the Golden Triangle where construction predates 1960. Survey costs range from £400 to £1,500 depending on the level and property value.</p>
        <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0;">Cheshire carries three location-specific survey risks absent from most English counties: brine subsidence from historical salt mining (concentrated around Northwich, Winsford, and Middlewich), radon gas accumulation in western Cheshire wards, and sandstone deterioration in Chester's Conservation Area. The mandatory Cheshire Salt Search (£79) is a separate requirement from the property survey itself.</p>
        <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0;">The tables below map survey recommendations and costs to 11 Cheshire towns at 10 price points from £185,000 in Crewe to £1,000,000 in Prestbury.</p>
      </div>
    </div>
  </section>

  <!-- Centerpiece: Survey Recommendation Tool -->
  <section id="recommendation-tool" class="section-pad" style="background-color: #FFFFFF; border-top: 1px solid #E5E0D8; border-bottom: 1px solid #E5E0D8;">
    <div class="section-inner" style="max-width: 720px;">
      <span class="section-label">Survey recommendation tool</span>
      <h2 style="font-family: Georgia, serif; font-size: clamp(22px, 3vw, 30px); font-weight: 700; color: #1C1C1E; line-height: 1.25; margin: 0 0 16px 0;">Which survey for your Cheshire property?</h2>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0 0 24px 0;">Cheshire property surveys range from £300 for a Level 1 Condition Report on a Crewe new build to £1,800 for a Level 3 Building Survey on a Prestbury period home. Select your property details to receive a survey level recommendation with Cheshire-specific notes.</p>

      <div style="display: flex; flex-direction: column; gap: 20px; margin-bottom: 24px;">
        <div>
          <label for="survey-age" style="font-family: Inter, Arial, sans-serif; font-size: 13px; font-weight: 600; color: #1C1C1E; display: block; margin-bottom: 6px;">Cheshire property age</label>
          <select id="survey-age" style="font-family: Inter, Arial, sans-serif; font-size: 16px; color: #1C1C1E; border: 1px solid #E5E0D8; background: #FFFFFF; padding: 10px 14px; width: 100%; max-width: 360px;">
            <option value="">Select property age</option>
            <option value="new">New build (under 10 years)</option>
            <option value="modern">Modern (10-30 years)</option>
            <option value="postwar">Post-war (1945-1970)</option>
            <option value="victorian">Victorian-Edwardian (1837-1914)</option>
            <option value="period">Pre-1837 period</option>
            <option value="listed">Listed building</option>
          </select>
        </div>
        <div>
          <label for="survey-area" style="font-family: Inter, Arial, sans-serif; font-size: 13px; font-weight: 600; color: #1C1C1E; display: block; margin-bottom: 6px;">Cheshire area</label>
          <select id="survey-area" style="font-family: Inter, Arial, sans-serif; font-size: 16px; color: #1C1C1E; border: 1px solid #E5E0D8; background: #FFFFFF; padding: 10px 14px; width: 100%; max-width: 360px;">
            <option value="">Select Cheshire area</option>
            <option value="chester">Chester</option>
            <option value="nantwich">Nantwich</option>
            <option value="knutsford">Knutsford</option>
            <option value="wilmslow">Wilmslow</option>
            <option value="macclesfield">Macclesfield</option>
            <option value="crewe">Crewe</option>
            <option value="northwich">Northwich</option>
            <option value="winsford">Winsford</option>
            <option value="frodsham">Frodsham</option>
            <option value="alderley">Alderley Edge</option>
            <option value="prestbury">Prestbury</option>
            <option value="other">Other Cheshire area</option>
          </select>
        </div>
        <div>
          <label for="survey-price" style="font-family: Inter, Arial, sans-serif; font-size: 13px; font-weight: 600; color: #1C1C1E; display: block; margin-bottom: 6px;">Cheshire property price</label>
          <div style="display: flex; align-items: center; border: 1px solid #E5E0D8; background: #FFFFFF; max-width: 280px;">
            <span style="font-family: Inter, Arial, sans-serif; font-size: 16px; font-weight: 600; color: #999999; padding: 10px 0 10px 14px;">£</span>
            <input type="text" id="survey-price" inputmode="numeric" placeholder="350,000" style="font-family: Inter, Arial, sans-serif; font-size: 16px; color: #1C1C1E; border: none; outline: none; padding: 10px 14px 10px 4px; background: transparent; width: 100%;" />
          </div>
        </div>
        <button id="survey-calc-btn" type="button" style="font-family: Inter, Arial, sans-serif; font-size: 14px; font-weight: 600; color: #FFFFFF; background-color: #3D5A3E; border: none; padding: 12px 28px; cursor: pointer; align-self: flex-start; transition: background-color 0.2s;">Get Cheshire survey recommendation</button>
      </div>

      <div id="survey-result" style="display: none; border: 1px solid #E5E0D8; padding: 24px;">
        <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 16px;">
          <div>
            <p style="font-family: Inter, Arial, sans-serif; font-size: 12px; font-weight: 600; color: #999999; text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 4px 0;">Recommended Cheshire survey level</p>
            <p id="survey-level-result" style="font-family: Georgia, serif; font-size: 32px; font-weight: 700; color: #C4933F; margin: 0;">Level 2</p>
          </div>
          <div style="text-align: right;">
            <p style="font-family: Inter, Arial, sans-serif; font-size: 12px; font-weight: 600; color: #999999; text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 4px 0;">Estimated Cheshire survey cost</p>
            <p id="survey-cost-result" style="font-family: Georgia, serif; font-size: 20px; font-weight: 700; color: #1C1C1E; margin: 0;">£400-£600</p>
          </div>
        </div>
        <div id="survey-notes" style="display: flex; flex-direction: column; gap: 8px; margin-bottom: 16px;"></div>
        <p id="survey-roi" style="font-family: Inter, Arial, sans-serif; font-size: 13px; color: #999999; margin: 0;"></p>
      </div>
    </div>
  </section>

  <!-- Three RICS Survey Levels -->
  <section id="survey-levels" class="section-pad" style="background-color: #FFFFFF; border-top: 1px solid #E5E0D8; border-bottom: 1px solid #E5E0D8;">
    <div class="section-inner" style="max-width: 720px;">
      <span class="section-label">RICS survey levels</span>
      <h2 style="font-family: Georgia, serif; font-size: clamp(22px, 3vw, 30px); font-weight: 700; color: #1C1C1E; line-height: 1.25; margin: 0 0 16px 0;">What are the three RICS survey levels for Cheshire properties?</h2>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0 0 24px 0; max-width: 720px;">RICS standardised property surveys into three levels in 2020, replacing the previous Condition Report, HomeBuyer Report, and Building Survey names with a numbered system (RICS). Each level increases inspection depth, report detail, and cost. The table below compares all three across seven criteria relevant to Cheshire property purchases.</p>

      <div style="max-width: 720px; margin: 0 auto 24px auto;">
        <img src="/images/buying-guide/rics-survey-levels-compared.png" alt="RICS survey levels compared showing Level 1 visual-only inspection at £300-£950 for new builds, Level 2 all accessible areas at £400-£1,000 for standard Cheshire homes, and Level 3 comprehensive structural analysis at £600-£1,500+ for period properties and listed buildings" style="width: 100%; height: auto; border: 1px solid #E5E0D8;" />
      </div>

