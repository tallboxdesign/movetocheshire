              <th style="text-align: right; padding: 12px 16px; font-weight: 700; color: #1C1C1E;">Avg price</th>
              <th style="text-align: center; padding: 12px 16px; font-weight: 700; color: #1C1C1E;">Typical offer</th>
              <th style="text-align: center; padding: 12px 16px; font-weight: 700; color: #1C1C1E;">Competition</th>
