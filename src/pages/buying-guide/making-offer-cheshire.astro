---
import BaseLayout from '../../layouts/BaseLayout.astro';

const offerDynamics = [
  { area: 'Wilmslow', zone: 'Golden Triangle', avgPrice: '£550,000', typicalOffer: '98-102%', competition: 'High', notes: 'Fierce competition for premium homes; sealed bids common for rare plots' },
  { area: 'Knutsford', zone: 'Golden Triangle', avgPrice: '£480,000', typicalOffer: '97-100%', competition: 'High', notes: 'Period properties attract multiple offers; historic character premium' },
  { area: 'Alderley Edge', zone: 'Golden Triangle', avgPrice: '£700,000+', typicalOffer: '95-100%', competition: 'High', notes: 'Prestige market with £3m-£7m top end; specialist advice essential' },
  { area: 'Chester', zone: 'Mid-Cheshire', avgPrice: '£305,000', typicalOffer: '93-97%', competition: 'Medium', notes: 'Diverse market from £216k FTB entry to Victorian villas' },
  { area: 'Macclesfield', zone: 'Mid-Cheshire', avgPrice: '£300,000', typicalOffer: '92-96%', competition: 'Medium', notes: 'Balanced market; turnkey family homes move faster' },
  { area: 'Frodsham', zone: 'Mid-Cheshire', avgPrice: '£340,000', typicalOffer: '93-97%', competition: 'Medium', notes: 'Village premium for quality of life; limited stock' },
  { area: 'Crewe', zone: 'Affordable', avgPrice: '£185,000', typicalOffer: '88-93%', competition: 'Low-Medium', notes: 'FTB and investor market; more negotiation room' },
  { area: 'Northwich', zone: 'Affordable', avgPrice: '£220,000', typicalOffer: '90-95%', competition: 'Low-Medium', notes: 'Entry from £141,500 in Witton; regeneration upside' },
  { area: 'Warrington', zone: 'Affordable', avgPrice: '£245,000', typicalOffer: '91-95%', competition: 'Medium', notes: 'Strong commuter demand; new builds competitive' },
];

const offerTimeline = [
  { step: 1, name: 'Prepare to offer', duration: '1-7 days before viewing', description: 'Secure mortgage agreement in principle, instruct solicitor, set budget ceiling including SDLT and fees' },
  { step: 2, name: 'View and research', duration: '1-3 viewings', description: 'Check Land Registry sold prices, days on market, property condition, EPC rating' },
  { step: 3, name: 'Make your offer', duration: '1-2 days', description: 'Verbal offer via estate agent with proof of funds and solicitor details' },
  { step: 4, name: 'Negotiate', duration: '1-7 days', description: 'Counter-offers, sealed bids if multiple buyers compete' },
  { step: 5, name: 'Offer accepted (SSTC)', duration: 'Day 1 of conveyancing', description: 'Memorandum of sale issued by agent; not yet legally binding' },
  { step: 6, name: 'Protect your position', duration: 'Ongoing until exchange', description: 'Progress conveyancing, book survey, maintain regular contact with agent and solicitor' },
];

const faqs = [
  { question: 'How much below asking price should I offer in Cheshire?', answer: 'Offer ranges vary by area and market conditions. Golden Triangle properties in Wilmslow, Knutsford, and Alderley Edge typically sell at 95-102% of asking price due to high competition (Rightmove, 2025). Mid-Cheshire towns like Chester and Macclesfield see accepted offers at 92-97%. Affordable areas including Crewe and Northwich allow 7-12% below asking when properties have been listed for 60+ days. Properties on the market for over 120 days across all areas carry the strongest negotiation position.' },
  { question: 'What is gazumping and is it legal in Cheshire?', answer: 'Gazumping occurs when a seller accepts a higher offer from a second buyer after already accepting an offer from the first buyer. Gazumping is legal in England because accepted offers remain "subject to contract" and carry no binding obligation until exchange of contracts (Law Society). The practice affects approximately 1 in 3 transactions that fall through before completion (HomeOwners Alliance, 2025). Lock-out agreements and Home Buyer Protection Insurance from £74 are the two primary defences available to buyers.' },
  { question: 'Do I need a mortgage agreement in principle before offering in Cheshire?', answer: 'A mortgage agreement in principle (AiP) demonstrates borrowing capacity to the estate agent and seller. Most Cheshire estate agents require proof of funds before presenting an offer to the vendor (NAEA Propertymark). An AiP takes 24-48 hours to obtain from most lenders and is valid for 60-90 days. Cash buyers provide a bank statement or proof of deposit instead. In competitive Golden Triangle markets, buyers without an AiP are routinely deprioritised against those with confirmed funding.' },
  { question: 'What are sealed bids and when are they used in Cheshire?', answer: 'Sealed bids (best-and-final offers) require all interested buyers to submit their highest offer by a deadline, typically in a sealed envelope or email to the estate agent. The seller reviews all bids simultaneously and selects the strongest overall package - not necessarily the highest price. Cheshire agents use sealed bids when three or more buyers express interest, most commonly in the Golden Triangle for detached properties and period homes in Knutsford. The process typically runs 5-10 working days from announcement to deadline.' },
  { question: 'Can I make an offer on a Cheshire property from outside the area?', answer: 'Remote offers are accepted by all Cheshire estate agents. Buyers relocating from London, Manchester, or overseas routinely make offers after virtual viewings or a single in-person visit. The estate agent presents the offer to the vendor regardless of the buyer\'s location. Proof of funds, a named solicitor, and a clear timeline strengthen a remote offer. Chain-free buyers relocating from a sold property carry the same weight as local buyers in the same position.' },
  { question: 'What happens if my Cheshire property offer is rejected?', answer: 'A rejected offer is not a dead end. The estate agent communicates the rejection and may indicate whether the seller would consider a revised figure. Common responses include increasing the offer by 2-3%, improving the terms (shortening the completion timeline, waiving conditions), or walking away. In Cheshire, 40% of properties that reject initial offers accept a revised second offer within 7 days (NAEA Propertymark regional data). The agent is legally obligated under the Estate Agents Act 1979 to present all offers to the vendor.' },
  { question: 'Should I offer on more than one Cheshire property at a time?', answer: 'Making simultaneous offers on multiple properties is legal but carries reputational risk with Cheshire estate agents. Agents communicate with each other, particularly within the same town. A buyer known for making multiple concurrent offers is perceived as uncommitted, which weakens each individual offer. The recommended approach is to make one offer at a time, withdraw formally before making another, and maintain clear communication with the agent throughout.' },
  { question: 'What is gazundering and when does it happen in Cheshire?', answer: 'Gazundering occurs when the buyer reduces their accepted offer price shortly before exchange of contracts. The buyer leverages the seller\'s sunk costs (conveyancing fees, time, emotional investment) to force a price reduction. Gazundering is legal in England for the same reason gazumping is legal - no binding contract exists until exchange. The practice increases during falling markets and is more common on properties where the survey reveals defects. Sellers can reject the lower offer, but risk restarting the sale process from scratch.' },
];

const relatedSpokes = [
  { label: 'Stamp Duty in Cheshire', href: '/buying-guide/stamp-duty-cheshire', tag: 'Buying Guide' },
  { label: 'Survey Types for Cheshire Properties', href: '/buying-guide/survey-types-cheshire', tag: 'Buying Guide' },
  { label: 'Conveyancing in Cheshire', href: '/buying-guide/conveyancing-cheshire', tag: 'Buying Guide' },
];


const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://movetocheshire.uk' },
    { '@type': 'ListItem', position: 2, name: 'Buying Guide', item: 'https://movetocheshire.uk/buying-guide' },
    { '@type': 'ListItem', position: 3, name: 'Making an Offer', item: 'https://movetocheshire.uk/buying-guide/making-offer-cheshire' },
  ],
};


const webApplicationSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  additionalType: 'https://schema.org/FinancialProduct',
  name: 'Cheshire Offer Strategy Calculator',
  description: 'Calculate a recommended offer range for Cheshire properties based on area, property condition, days on market, and buyer position. Covers Golden Triangle, Chester, mid-Cheshire, and affordable areas.',
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'Web browser',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'GBP' },
  areaServed: {
    '@type': 'AdministrativeArea',
    name: 'Cheshire',
    containedInPlace: { '@type': 'Country', name: 'England' },
  },
  audience: { '@type': 'Audience', audienceType: 'Home buyers making offers on property in Cheshire' },
  potentialAction: {
    '@type': 'UseAction',
    name: 'Calculate your Cheshire offer strategy',
    target: 'https://movetocheshire.uk/buying-guide/making-offer-cheshire#calculator',
  },
  isPartOf: { '@type': 'WebPage', url: 'https://movetocheshire.uk/buying-guide/making-offer-cheshire' },
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Making an Offer on a Cheshire Property',
  description: 'How Cheshire property offers work: area-specific pricing dynamics from the Golden Triangle to Crewe, sealed bids, gazumping protection, estate agent obligations under the Estate Agents Act 1979, and an offer strategy calculator.',
  datePublished: '2026-02-27',
  dateModified: '2026-02-27',
  image: {
    '@type': 'ImageObject',
    url: 'https://movetocheshire.uk/images/buying-guide/cheshire-offer-dynamics-comparison.webp',
    width: 720,
    height: 443,
  },
  author: { '@type': 'Organization', name: 'movetocheshire.uk' },
  publisher: { '@type': 'Organization', name: 'movetocheshire.uk', url: 'https://movetocheshire.uk', logo: { '@type': 'ImageObject', url: 'https://movetocheshire.uk/favicon.svg' } },
};
---

<BaseLayout
  title="Making an Offer in Cheshire | Area Pricing & Calculator"
  description="How to make an offer on a Cheshire property in 2026: area-specific pricing from Golden Triangle sealed bids to affordable market negotiation. Calculator and gazumping protection."
  ogImage="/images/buying-guide/cheshire-offer-dynamics-comparison.webp"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webApplicationSchema)} />
  </Fragment>

  <!-- Breadcrumb -->
  <div class="section-pad" style="padding-top: 20px; padding-bottom: 0;">
    <div class="section-inner">
      <nav aria-label="Breadcrumb" style="font-family: Inter, Arial, sans-serif; font-size: 13px; color: #999999;">
        <a href="/" style="color: #999999; text-decoration: none;">Home</a>
        <span style="margin: 0 8px;">/</span>
        <a href="/buying-guide" style="color: #999999; text-decoration: none;">Buying Guide</a>
        <span style="margin: 0 8px;">/</span>
        <span style="color: #1C1C1E;">Making an Offer</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="section-pad" style="padding-top: 40px;">
    <div class="section-inner" style="max-width: 720px;">
      <span class="section-label">Offer strategy</span>
      <h1 style="font-family: Georgia, serif; font-size: clamp(28px, 4.5vw, 44px); font-weight: 700; color: #1C1C1E; line-height: 1.15; margin: 0 0 20px 0; letter-spacing: -0.02em;">Making an Offer on a Cheshire Property</h1>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 18px; line-height: 1.7; color: #444444; margin: 0 0 24px 0;">
        Cheshire buyers making offers in 2026 face three distinct markets across nine towns - sealed bids in the Golden Triangle where offers reach 102% of asking price, balanced negotiation in Chester and Macclesfield, and affordable markets in Crewe and Northwich where 7-12% below asking is realistic. This guide covers the legal framework, gazumping protection strategies, and an interactive offer calculator.
      </p>
      <span style="display: inline-block; font-family: Inter, Arial, sans-serif; font-size: 12px; font-weight: 600; color: #3D5A3E; background-color: rgba(61, 90, 62, 0.08); padding: 6px 12px; letter-spacing: 0.02em;">Last updated: 27 February 2026</span>
      <nav aria-label="Page sections" style="display: flex; flex-wrap: wrap; gap: 8px; margin-top: 20px;">
        {[
          { label: 'How Cheshire offers work', href: '#how-offers-work' },
          { label: 'Cheshire price research', href: '#research' },
          { label: 'Cheshire market dynamics', href: '#market-dynamics' },
          { label: 'Cheshire sealed bids', href: '#sealed-bids' },
          { label: 'Gazumping protection', href: '#gazumping' },
          { label: 'Cheshire agent duties', href: '#estate-agent' },
          { label: 'Cheshire offer calculator', href: '#calculator' },
          { label: 'Cheshire buyer FAQ', href: '#faq' },
        ].map((link) => (
          <a href={link.href} style="font-family: Inter, Arial, sans-serif; font-size: 13px; font-weight: 500; color: #3D5A3E; text-decoration: none; padding: 5px 12px; border: 1px solid rgba(61, 90, 62, 0.25); transition: border-color 0.2s, background-color 0.2s;">{link.label}</a>
        ))}
      </nav>
    </div>
  </section>

  <!-- Stat Bar -->
  <section class="section-pad" style="padding-top: 0;">
    <div class="section-inner">
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px;">
        {[
          { value: '1 in 3', label: 'Cheshire and England property purchases that fall through before completion', source: 'HomeOwners Alliance, 2025' },
          { value: '88-102%', label: 'Cheshire accepted offer range across nine towns', source: 'Rightmove, 2025' },
          { value: 'Not binding', label: 'Cheshire accepted offers remain subject to contract until exchange', source: 'Law Society, 2025' },
        ].map((stat) => (
          <div style="background-color: #FFFFFF; border: 1px solid #E5E0D8; padding: 28px 24px;">
            <p class="data-tile-value" style="margin: 0 0 8px 0;">{stat.value}</p>
            <p style="font-family: Inter, Arial, sans-serif; font-size: 14px; font-weight: 600; color: #1C1C1E; margin: 0 0 4px 0;">{stat.label}</p>
            <p style="font-family: Inter, Arial, sans-serif; font-size: 12px; color: #999999; margin: 0;">{stat.source}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TLDR -->
  <section class="section-pad">
    <div class="section-inner" style="max-width: 720px;">
      <span class="section-label">Cheshire offer summary</span>
      <h2 style="font-family: Georgia, serif; font-size: clamp(22px, 3vw, 30px); font-weight: 700; color: #1C1C1E; line-height: 1.25; margin: 0 0 24px 0;">
        What do Cheshire property offers look like in 2026?
      </h2>
      <div style="display: flex; flex-direction: column; gap: 16px;">
        <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #1C1C1E; margin: 0;"><strong>Making an offer on a Cheshire property follows the same legal process as the rest of England - verbal offer through the estate agent, "subject to contract" until exchange - but the offer amount that succeeds varies dramatically by area</strong> (Law Society). Golden Triangle properties in Wilmslow, Knutsford, and Alderley Edge attract offers at 95-102% of asking price, while affordable towns like Crewe and Northwich see accepted offers at 88-95%.</p>
        <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #1C1C1E; margin: 0;"><strong>Accepted offers carry no legal obligation until exchange of contracts</strong> (Law Society). This gap - the period between acceptance and exchange, typically 8-12 weeks in Cheshire - is when buyer costs accumulate without protection: conveyancing (£500-£1,800), survey (£400-£1,500), and mortgage fees average £2,700 in abortive costs when a purchase collapses (HomeOwners Alliance, 2025). Buyer position, speed, and protection strategy are as important as the offer price itself.</p>
        <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0;">Nine Cheshire towns across three market tiers are analysed below with area-specific offer ranges, the sealed bid process used in the Golden Triangle, four gazumping defences, and estate agent obligations under the Estate Agents Act 1979.</p>
      </div>
    </div>
  </section>

  <!-- Offer Strategy Calculator (CENTERPIECE) -->
  <section id="calculator" class="section-pad" style="background-color: #FFFFFF; border-top: 1px solid #E5E0D8; border-bottom: 1px solid #E5E0D8;">
    <div class="section-inner" style="max-width: 720px;">
      <span class="section-label">Cheshire offer calculator</span>
      <h2 style="font-family: Georgia, serif; font-size: clamp(22px, 3vw, 30px); font-weight: 700; color: #1C1C1E; line-height: 1.25; margin: 0 0 16px 0;">What percentage of asking price should you offer in Cheshire?</h2>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0 0 24px 0;">Cheshire property offer ranges vary from 78% to 105% of asking price depending on area, condition, days on market, and buyer position (Rightmove, 2025). Select your circumstances below to generate a recommended offer range with tactical notes, gazumping risk assessment, and a next-steps checklist specific to your Cheshire purchase.</p>

      <!-- Calculator Form -->
      <div style="border: 2px solid #3D5A3E; padding: 28px; margin-bottom: 24px;">
        <p style="font-family: Inter, Arial, sans-serif; font-size: 14px; font-weight: 700; color: #3D5A3E; margin: 0 0 20px 0; text-transform: uppercase; letter-spacing: 0.05em;">Cheshire Offer Strategy Calculator</p>

        <div style="display: flex; flex-direction: column; gap: 20px; margin-bottom: 24px;">
          <div>
            <label for="offer-area" style="font-family: Inter, Arial, sans-serif; font-size: 13px; font-weight: 600; color: #1C1C1E; display: block; margin-bottom: 6px;">Cheshire area</label>
            <select id="offer-area" style="font-family: Inter, Arial, sans-serif; font-size: 15px; color: #1C1C1E; border: 1px solid #E5E0D8; padding: 10px 14px; background: #FFFFFF; width: 100%; max-width: 360px;">
              <option value="golden-triangle">Golden Triangle (Wilmslow, Knutsford, Alderley Edge)</option>
              <option value="chester">Chester and surrounds</option>
              <option value="mid-cheshire" selected>Mid-Cheshire (Macclesfield, Frodsham, Nantwich)</option>
              <option value="affordable">South and East Cheshire (Crewe, Northwich, Warrington)</option>
            </select>
          </div>

          <div>
            <label for="offer-condition" style="font-family: Inter, Arial, sans-serif; font-size: 13px; font-weight: 600; color: #1C1C1E; display: block; margin-bottom: 6px;">Cheshire property condition</label>
            <select id="offer-condition" style="font-family: Inter, Arial, sans-serif; font-size: 15px; color: #1C1C1E; border: 1px solid #E5E0D8; padding: 10px 14px; background: #FFFFFF; width: 100%; max-width: 360px;">
              <option value="turnkey">Turnkey - no work required</option>
              <option value="light-refurb" selected>Light refurb needed</option>
              <option value="major-renovation">Major renovation</option>
              <option value="new-build">New build</option>
            </select>
          </div>

          <div>
            <label for="offer-days" style="font-family: Inter, Arial, sans-serif; font-size: 13px; font-weight: 600; color: #1C1C1E; display: block; margin-bottom: 6px;">Days on Cheshire market</label>
            <select id="offer-days" style="font-family: Inter, Arial, sans-serif; font-size: 15px; color: #1C1C1E; border: 1px solid #E5E0D8; padding: 10px 14px; background: #FFFFFF; width: 100%; max-width: 360px;">
              <option value="under-14">Under 14 days</option>
              <option value="14-60" selected>14-60 days</option>
              <option value="60-120">60-120 days</option>
              <option value="120-plus">120+ days</option>
            </select>
          </div>

          <div>
            <label for="offer-position" style="font-family: Inter, Arial, sans-serif; font-size: 13px; font-weight: 600; color: #1C1C1E; display: block; margin-bottom: 6px;">Your Cheshire buyer position</label>
            <select id="offer-position" style="font-family: Inter, Arial, sans-serif; font-size: 15px; color: #1C1C1E; border: 1px solid #E5E0D8; padding: 10px 14px; background: #FFFFFF; width: 100%; max-width: 360px;">
              <option value="ftb">First-time buyer with AiP</option>
              <option value="chain-free" selected>Chain-free with cash or mortgage offer</option>
              <option value="in-chain">In a chain</option>
              <option value="investor">Investor</option>
            </select>
          </div>
        </div>

        <button id="offer-calc-btn" type="button" style="font-family: Inter, Arial, sans-serif; font-size: 14px; font-weight: 600; color: #FFFFFF; background-color: #3D5A3E; border: none; padding: 12px 28px; cursor: pointer; transition: background-color 0.2s;">Calculate your Cheshire offer strategy</button>
      </div>

      <!-- Calculator Result -->
      <div id="offer-result" style="display: none; border: 1px solid #E5E0D8; padding: 24px;">
        <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 16px; flex-wrap: wrap; gap: 12px;">
          <div>
            <p style="font-family: Inter, Arial, sans-serif; font-size: 12px; font-weight: 600; color: #999999; text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 4px 0;">Recommended Cheshire offer range</p>
            <p id="offer-range" style="font-family: Georgia, serif; font-size: 32px; font-weight: 700; color: #C4933F; margin: 0;">90-95%</p>
          </div>
          <div style="text-align: right;">
            <p style="font-family: Inter, Arial, sans-serif; font-size: 12px; font-weight: 600; color: #999999; text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 4px 0;">Cheshire gazumping risk</p>
            <p id="offer-risk" style="font-family: Georgia, serif; font-size: 20px; font-weight: 700; color: #1C1C1E; margin: 0;">Medium</p>
          </div>
        </div>
        <div id="offer-tactical" style="font-family: Inter, Arial, sans-serif; font-size: 15px; line-height: 1.7; color: #444444; margin-bottom: 16px; padding: 16px; background-color: rgba(61, 90, 62, 0.04); border-left: 3px solid #3D5A3E;"></div>
        <div id="offer-checklist" style="display: flex; flex-direction: column; gap: 8px;"></div>
      </div>
    </div>
  </section>

  <!-- Offer Timeline -->
  <section class="section-pad">
    <div class="section-inner" style="max-width: 720px;">
      <span class="section-label">Offer process</span>
      <h2 style="font-family: Georgia, serif; font-size: clamp(22px, 3vw, 30px); font-weight: 700; color: #1C1C1E; line-height: 1.25; margin: 0 0 16px 0;">What is the Cheshire offer-to-SSTC timeline?</h2>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0 0 24px 0;">The Cheshire offer process runs through six stages from preparation to protecting your position after acceptance, with the full sequence typically taking 2-4 weeks before conveyancing begins.</p>

      <figure style="margin: 0 auto 24px; max-width: 720px;">
        <img src="/images/buying-guide/cheshire-offer-process-flowchart.webp" alt="Cheshire offer process flowchart showing six steps from preparing to offer through viewing, making an offer, negotiating, offer accepted SSTC, and protecting your position" loading="lazy" width="720" height="299" style="width: 720px; max-width: 100%; aspect-ratio: 720/299; border: 1px solid #E5E0D8;" />
        <figcaption style="font-family: Inter, Arial, sans-serif; font-size: 12px; color: #999999; margin-top: 8px;">The Cheshire offer-to-SSTC process typically takes 2-4 weeks. Golden Triangle sealed bids may compress steps 3-5 into a single deadline.</figcaption>
      </figure>

      <div style="display: flex; flex-direction: column; gap: 0;">
        {offerTimeline.map((step, i) => (
          <div style={`display: flex; gap: 16px; padding: 16px 0; ${i < offerTimeline.length - 1 ? 'border-bottom: 1px solid #F0EDE8;' : ''}`}>
            <div style="min-width: 36px; height: 36px; border-radius: 50%; background-color: #3D5A3E; color: #FFFFFF; display: flex; align-items: center; justify-content: center; font-family: Inter, Arial, sans-serif; font-size: 14px; font-weight: 700; flex-shrink: 0;">{step.step}</div>
            <div>
              <p style="font-family: Inter, Arial, sans-serif; font-size: 15px; font-weight: 600; color: #1C1C1E; margin: 0 0 2px 0;">{step.name} <span style="font-weight: 400; color: #999999; font-size: 13px;">- {step.duration}</span></p>
              <p style="font-family: Inter, Arial, sans-serif; font-size: 14px; color: #444444; margin: 0; line-height: 1.5;">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How Offers Work -->
  <section id="how-offers-work" class="section-pad" style="background-color: #FFFFFF; border-top: 1px solid #E5E0D8; border-bottom: 1px solid #E5E0D8;">
    <div class="section-inner" style="max-width: 720px;">
      <span class="section-label">Cheshire offer legal process</span>
      <h2 style="font-family: Georgia, serif; font-size: clamp(22px, 3vw, 30px); font-weight: 700; color: #1C1C1E; line-height: 1.25; margin: 0 0 16px 0;">How does making an offer work for Cheshire buyers?</h2>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0 0 20px 0;"><strong>The offer process for Cheshire buyers follows the England-wide system - buyer, estate agent, and seller operating through a legal framework that gives the agent a duty to present every offer received</strong> (<a href="https://www.legislation.gov.uk/ukpga/1979/38/section/21" style="color: #3D5A3E;" rel="nofollow noopener">Estate Agents Act 1979, Section 21</a>). The buyer communicates an offer amount verbally or in writing to the agent, who passes it to the seller along with details of the buyer's financial position and chain status. No written contract exists at this stage.</p>

      <h3 style="font-family: Georgia, serif; font-size: 20px; font-weight: 700; color: #1C1C1E; margin: 24px 0 12px 0;">What does "subject to contract" mean for Cheshire buyers?</h3>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0 0 16px 0;">"Subject to contract" is the phrase that appears on the memorandum of sale the agent issues after the seller accepts an offer - it signals that both parties have agreed a price but neither is contractually committed until solicitors exchange signed contracts (Law Society). Either party can withdraw at any point before exchange without financial penalty or legal consequence.</p>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0;">This differs from Scotland, where an accepted offer becomes legally binding immediately. In England, the period between acceptance and exchange - typically 8-12 weeks for a standard Cheshire purchase - is the vulnerability window where gazumping, survey issues, and chain collapses derail transactions.</p>

      <h3 style="font-family: Georgia, serif; font-size: 20px; font-weight: 700; color: #1C1C1E; margin: 24px 0 12px 0;">What happens between offer acceptance and exchange in Cheshire?</h3>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0 0 16px 0;">The estate agent issues a memorandum of sale to all parties - buyer, seller, and both solicitors - listing the agreed price and each party's details. The property listing changes to "Sold Subject to Contract" (SSTC). The buyer's solicitor begins the <a href="/buying-guide/conveyancing-cheshire" style="color: #3D5A3E;">conveyancing process</a>: ordering local authority searches, the mandatory Cheshire Salt Search (£79), environmental searches, and raising pre-contract enquiries.</p>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0;">The buyer books a <a href="/buying-guide/survey-types-cheshire" style="color: #3D5A3E;">property survey</a> - RICS Level 2 for standard Cheshire homes (£400-£1,000) or Level 3 for older properties and conversions (£630-£1,500). The mortgage lender instructs a valuation. Exchange occurs when both solicitors confirm the contract terms, the buyer transfers the deposit (typically 10%), and completion dates are fixed.</p>

      <h3 style="font-family: Georgia, serif; font-size: 20px; font-weight: 700; color: #1C1C1E; margin: 24px 0 12px 0;">Why do 1 in 3 Cheshire purchases fall through?</h3>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0 0 16px 0;">The five primary causes of purchase collapse are: buyer or seller changing their mind (28%), chain collapse where one transaction in a linked sequence fails (26%), survey revealing structural defects or subsidence risk (18%), mortgage valuation coming in below the offer price (15%), and gazumping by a competing buyer (13%) (HomeOwners Alliance, 2025).</p>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0;">Cheshire-specific risks include the salt subsidence assessment flagging historical brine mining damage, local authority search delays (5-21 working days depending on Cheshire East or Cheshire West council), and the Golden Triangle's high-value market attracting competing offers during the SSTC period. The average buyer who loses a purchase spends £2,700 in abortive conveyancing, survey, and mortgage fees (HomeOwners Alliance, 2025).</p>
    </div>
  </section>

  <!-- Research -->
  <section id="research" class="section-pad">
    <div class="section-inner" style="max-width: 720px;">
      <span class="section-label">Cheshire price research</span>
      <h2 style="font-family: Georgia, serif; font-size: clamp(22px, 3vw, 30px); font-weight: 700; color: #1C1C1E; line-height: 1.25; margin: 0 0 16px 0;">How do you research the right offer price in Cheshire?</h2>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0 0 20px 0;"><strong>Researching the right offer price requires comparing three data sources: Land Registry sold prices for the street or postcode, the property's current asking price against comparable listings, and the number of days on market</strong> (Money Helper, 2025). These three inputs together establish whether the asking price reflects current market value, is aspirational, or is already discounted.</p>

      <h3 style="font-family: Georgia, serif; font-size: 20px; font-weight: 700; color: #1C1C1E; margin: 24px 0 12px 0;">How do sold prices compare to asking prices in Cheshire?</h3>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0 0 16px 0;"><a href="https://www.gov.uk/search-property-information-land-registry" style="color: #3D5A3E;" rel="nofollow noopener">Land Registry</a> records every completed sale price in England and Wales, searchable by postcode within 6-8 weeks of completion. Comparing the asking price to sold prices for similar properties on the same street or postcode provides the strongest evidence base for an offer.</p>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0 0 16px 0;">Rightmove's sold prices tool and the ONS House Price Index offer complementary views - Rightmove shows individual transactions while ONS provides ward-level averages.</p>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0;">Cheshire's price variation between wards makes postcode-level research essential. A three-bedroom semi in Wilmslow (CH9) averages £450,000, while the same property type in Crewe (CW1) averages £165,000 (ONS, Q4 2025). Using town-level averages without drilling into the specific ward produces misleading offer calculations.</p>

      <h3 style="font-family: Georgia, serif; font-size: 20px; font-weight: 700; color: #1C1C1E; margin: 24px 0 12px 0;">How long has the Cheshire property been on the market?</h3>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0 0 16px 0;">Days on market correlates directly with seller pricing pressure. A Cheshire property listed for under 14 days carries no pricing pressure - the seller is still receiving primary market feedback. By 60-120 days, agents typically advise a price review, as sustained marketing without an offer signals buyer resistance to the asking price.</p>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0 0 16px 0;">At 120+ days, Rightmove and Zoopla price history usually show at least one reduction, and the seller's motivation to negotiate has measurably increased. Cheshire properties in the affordable tier (Crewe, Northwich, Warrington) average 52 days on market compared to 28 days in the Golden Triangle (Rightmove, 2025).</p>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0;">Rightmove and Zoopla display the listing date. A property that has been reduced in price and relisted resets the counter - check the price history to identify properties that have been marketed for longer than the displayed figure suggests.</p>

      <h3 style="font-family: Georgia, serif; font-size: 20px; font-weight: 700; color: #1C1C1E; margin: 24px 0 12px 0;">What condition is the property in?</h3>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0 0 16px 0;">Property condition directly affects the offer range. A turnkey property (no work required) in a desirable area commands full asking price because competing buyers face the same low refurbishment cost. A property requiring a new roof (£5,000-£15,000), rewiring (£3,000-£5,000), or damp treatment (£2,000-£8,000) gives the buyer a quantifiable reason to reduce the offer by the estimated repair cost.</p>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0;">Cheshire's pre-1919 housing stock - concentrated in Chester's city centre, Knutsford's King Street, and the rural villages - carries higher maintenance risk than post-war estates. Period properties with original sash windows, lime render, and solid walls command a character premium but require specialist maintenance budgets that reduce the net value compared to modernised equivalents.</p>

      <h3 style="font-family: Georgia, serif; font-size: 20px; font-weight: 700; color: #1C1C1E; margin: 24px 0 12px 0;">How does energy efficiency affect a Cheshire offer?</h3>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0 0 16px 0;">Cheshire properties rated EPC D or below cost £500-£1,200 per year more in energy bills than an EPC C equivalent, and this gap gives buyers quantifiable leverage on the offer price. Lenders including Barclays, NatWest, and Nationwide offer green mortgage products with 0.1-0.2% lower interest rates for EPC A-C properties.</p>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0;">A low EPC rating gives the buyer leverage to reduce the offer by the estimated upgrade cost - insulation, double glazing, or heat pump installation typically totals £5,000-£20,000 depending on the property size and current rating.</p>
    </div>
  </section>

  <!-- Market Dynamics -->
  <section id="market-dynamics" class="section-pad" style="background-color: #FFFFFF; border-top: 1px solid #E5E0D8; border-bottom: 1px solid #E5E0D8;">
    <div class="section-inner" style="max-width: 720px;">
      <span class="section-label">Cheshire area comparison</span>
      <h2 style="font-family: Georgia, serif; font-size: clamp(22px, 3vw, 30px); font-weight: 700; color: #1C1C1E; line-height: 1.25; margin: 0 0 16px 0;">How does Cheshire's property market affect your offer?</h2>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0 0 24px 0;"><strong>Cheshire operates as three distinct property markets with different offer dynamics</strong> (Rightmove, 2025). The Golden Triangle (Wilmslow, Knutsford, Alderley Edge) is a seller's market where competition pushes offers above asking price. Mid-Cheshire (Chester, Macclesfield, Frodsham) balances supply and demand with moderate negotiation room. Affordable Cheshire (Crewe, Northwich, Warrington) favours buyers with 5-12% below asking regularly accepted.</p>

      <!-- Offer Dynamics Table -->
      <div style="overflow-x: auto; margin-bottom: 24px;">
        <table style="width: 100%; border-collapse: collapse; font-family: Inter, Arial, sans-serif; font-size: 14px; min-width: 700px;">
          <thead>
            <tr style="border-bottom: 2px solid #3D5A3E;">
              <th style="text-align: left; padding: 12px 16px; font-weight: 700; color: #1C1C1E;">Area</th>
