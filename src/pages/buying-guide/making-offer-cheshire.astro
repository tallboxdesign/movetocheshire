            </tr>
          </thead>
          <tbody>
            {offerDynamics.map((row, i) => (
              <tr style={`border-bottom: 1px solid #E5E0D8; ${i % 2 === 0 ? '' : 'background-color: rgba(61, 90, 62, 0.02);'}`}>
                <td style="padding: 14px 16px; font-weight: 600; color: #1C1C1E;">{row.area}</td>
                <td style={`padding: 14px 16px; color: ${row.zone === 'Golden Triangle' ? '#C4933F' : row.zone === 'Mid-Cheshire' ? '#3D5A3E' : '#444444'};`}>{row.zone}</td>
                <td style="padding: 14px 16px; color: #444444; text-align: right;">{row.avgPrice}</td>
                <td style="padding: 14px 16px; color: #1C1C1E; font-weight: 600; text-align: center;">{row.typicalOffer}</td>
                <td style={`padding: 14px 16px; text-align: center; font-weight: 600; color: ${row.competition === 'High' ? '#C4933F' : row.competition === 'Medium' ? '#3D5A3E' : '#444444'};`}>{row.competition}</td>
                <td style="padding: 14px 16px; color: #444444; font-size: 13px;">{row.notes}</td>
