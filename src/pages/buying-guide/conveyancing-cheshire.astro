          <p style="font-family: Inter, Arial, sans-serif; font-size: 12px; font-weight: 600; color: #999999; text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 4px 0;">Estimated Cheshire conveyancing timeline</p>
          <p id="conv-total" style="font-family: Georgia, serif; font-size: 32px; font-weight: 700; color: #C4933F; margin: 0;">8-12 weeks</p>
        </div>
        <div id="conv-stages" style="display: flex; flex-direction: column; gap: 4px; margin-bottom: 16px;"></div>
        <div id="conv-notes" style="display: flex; flex-direction: column; gap: 4px; margin-bottom: 16px;"></div>
