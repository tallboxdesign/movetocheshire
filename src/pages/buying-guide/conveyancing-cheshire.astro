---
import BaseLayout from '../../layouts/BaseLayout.astro';

const conveyancingStages = [
  { stage: 1, name: 'Instruct solicitor', duration: '1-3 days', description: 'ID verification, AML checks, file setup' },
  { stage: 2, name: 'Searches and contract pack', duration: '2-4 weeks', description: 'Local authority, environmental, salt search ordered' },
  { stage: 3, name: 'Enquiries and mortgage', duration: '2-6 weeks', description: 'Legal questions raised, mortgage offer issued' },
  { stage: 4, name: 'Exchange of contracts', duration: '1-2 days', description: 'Deposit paid (10%), completion date fixed' },
  { stage: 5, name: 'Completion', duration: '1-4 weeks after exchange', description: 'Funds transfer, keys released' },
  { stage: 6, name: 'Post-completion', duration: '4-12 weeks', description: 'SDLT filed, Land Registry registration' },
];

const conveyancingCosts = [
  { price: '185,000', location: 'Crewe', legalFees: '£500-£700', searches: '£250-£350', landReg: '£95', total: '£845-£1,145' },
  { price: '220,000', location: 'Northwich', legalFees: '£550-£750', searches: '£280-£380', landReg: '£95', total: '£925-£1,225' },
  { price: '266,000', location: 'Chester avg', legalFees: '£600-£800', searches: '£280-£400', landReg: '£270', total: '£1,150-£1,470' },
  { price: '300,000', location: 'Macclesfield', legalFees: '£650-£850', searches: '£300-£400', landReg: '£270', total: '£1,220-£1,520' },
  { price: '350,000', location: 'Knutsford entry', legalFees: '£700-£900', searches: '£300-£420', landReg: '£270', total: '£1,270-£1,590' },
  { price: '400,000', location: 'Wilmslow entry', legalFees: '£750-£950', searches: '£300-£430', landReg: '£270', total: '£1,320-£1,650' },
  { price: '480,000', location: 'Knutsford avg', legalFees: '£800-£1,000', searches: '£320-£440', landReg: '£270', total: '£1,390-£1,710' },
  { price: '550,000', location: 'Wilmslow avg', legalFees: '£850-£1,050', searches: '£320-£450', landReg: '£540', total: '£1,710-£2,040' },
  { price: '750,000', location: 'Alderley Edge', legalFees: '£950-£1,150', searches: '£350-£450', landReg: '£540', total: '£1,840-£2,140' },
  { price: '1,000,000', location: 'Prestbury', legalFees: '£1,000-£1,200', searches: '£350-£470', landReg: '£910', total: '£2,260-£2,580' },
];

const searchTypes = [
  { search: 'Local authority', purpose: 'Planning history, building control, conservation areas, highways', cost: '£100-£250', timeline: '5-22 working days' },
  { search: 'Environmental', purpose: 'Flood risk, contaminated land, ground stability', cost: '£35-£75', timeline: '1-3 working days' },
  { search: 'Water and drainage', purpose: 'Public water and sewer connections, drainage maps', cost: '£35-£60', timeline: '1-5 working days' },
  { search: 'Cheshire salt search', purpose: 'Brine subsidence history, compensation claims', cost: '£79', timeline: '1 working day' },
  { search: 'Coal mining', purpose: 'Mining subsidence risk (north-east Cheshire)', cost: '£40-£60', timeline: '1-3 working days' },
  { search: 'Chancel repair', purpose: 'Church repair liability on the title', cost: '£15-£25', timeline: '1-2 working days' },
];

const laSearchTimelines = [
  { authority: 'Cheshire East', areas: 'Crewe, Nantwich, Macclesfield, Knutsford, Wilmslow', days: 21 },
  { authority: 'Cheshire West and Chester', areas: 'Chester, Northwich, Winsford, Frodsham, Ellesmere Port', days: 20 },
  { authority: 'Warrington', areas: 'Warrington borough', days: 5 },
];

const faqs = [
  { question: 'How long does conveyancing take in Cheshire?', answer: 'Conveyancing on a standard freehold Cheshire purchase takes 8-12 weeks from instruction to completion (Law Society, 2025). Leasehold purchases add 2-4 weeks for freeholder enquiries and lease review. Chain transactions add a further 2-4 weeks because each linked sale must synchronise exchange dates. Cheshire East local authority searches take 21 working days compared to 5 working days in Warrington - the council processing speed directly affects the Stage 2 timeline.' },
  { question: 'What is a Cheshire salt search?', answer: 'The Cheshire salt search (formally the Cheshire Brine Subsidence Compensation District search) checks whether a property sits within a zone affected by historical brine extraction. The search costs £79 including VAT and returns within 1 working day. It reveals any subsidence claims, compensation payments, or commutation awards recorded against the property. The Law Society mandates this search for all purchases within the Brine Compensation District, which covers Cheshire East, Cheshire West and Chester, Warrington, and parts of Trafford.' },
  { question: 'Do I need a local solicitor for a Cheshire property?', answer: 'English conveyancing law applies uniformly, so any qualified solicitor or licensed conveyancer in England and Wales can act on a Cheshire purchase. Local solicitors offer knowledge of Cheshire-specific issues - the salt search requirement, Chester conservation area restrictions, and Cheshire East planning patterns. Online conveyancers charge £200-£400 less on average but rely on standard protocols and may not flag area-specific risks unprompted. CQS-accredited firms (Law Society Conveyancing Quality Scheme) meet audit standards regardless of location.' },
  { question: 'What is the difference between exchange and completion?', answer: 'Exchange of contracts is the point at which the purchase becomes legally binding - the buyer pays a 10% deposit and both parties commit to complete on the agreed date. Neither party can withdraw after exchange without forfeiting the deposit or facing breach-of-contract claims. Completion is the day the remaining funds transfer from the buyer\'s solicitor to the seller\'s solicitor, ownership passes, and the buyer collects the keys. The gap between exchange and completion ranges from 1 day to 4 weeks, with 2 weeks being typical in Cheshire chain transactions.' },
  { question: 'Can I speed up Cheshire conveyancing?', answer: 'Three factors accelerate Cheshire conveyancing. Instructing a solicitor before the offer is accepted saves 1-2 weeks on AML checks and file setup. Ordering searches on instruction rather than waiting for the contract pack saves 1-3 weeks because searches run in parallel with the seller\'s solicitor preparing documents. Responding to solicitor information requests within 48 hours prevents delays - the most common cause of slow conveyancing is the buyer taking weeks to return signed forms or provide requested documents.' },
  { question: 'What happens if the chain collapses?', answer: 'A chain collapse before exchange of contracts means the buyer loses conveyancing fees incurred to that point (typically £500-£1,200 in legal fees plus £250-£450 in search costs) but does not lose a deposit. After exchange, withdrawal costs the 10% deposit plus potential damages. Home buyer protection insurance (from £74) covers lost conveyancing and survey fees if the purchase fails before exchange. Chain collapses affect approximately 30% of English property transactions (HomeOwners Alliance, 2025).' },
  { question: 'What extra costs does a leasehold purchase add?', answer: 'Leasehold conveyancing adds £300-£600 to the legal bill. The freeholder or managing agent charges a notice fee (£100-£200) for registering the new owner, a management pack fee (£200-£400) containing service charge accounts, insurance details, and lease terms, and potentially a deed of covenant fee (£50-£150). Ground rent and service charge apportionments require calculation at completion. Chester city centre flats and Northwich apartment developments are the most common leasehold purchases in Cheshire.' },
  { question: 'What is CQS accreditation?', answer: 'The Conveyancing Quality Scheme (CQS) is a Law Society accreditation programme that audits conveyancing firms against defined standards for case management, client communication, file handling, and regulatory compliance. CQS firms undergo annual assessment and must demonstrate professional indemnity insurance, complaints handling procedures, and staff training records. Most mortgage lenders require the buyer\'s solicitor to hold CQS accreditation before releasing funds. The CQS directory at lawsociety.org.uk lists accredited firms searchable by location.' },
];

const relatedSpokes = [
  { label: 'Stamp Duty in Cheshire', href: '/buying-guide/stamp-duty-cheshire', tag: 'Buying Guide' },
  { label: 'Survey Types for Cheshire Properties', href: '/buying-guide/survey-types-cheshire', tag: 'Buying Guide' },
  { label: 'Average House Price in Cheshire', href: '/house-prices/average-house-price-cheshire', tag: 'Prices' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://movetocheshire.uk' },
    { '@type': 'ListItem', position: 2, name: 'Buying Guide', item: 'https://movetocheshire.uk/buying-guide' },
    { '@type': 'ListItem', position: 3, name: 'Conveyancing in Cheshire', item: 'https://movetocheshire.uk/buying-guide/conveyancing-cheshire' },
  ],
};


const webApplicationSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  additionalType: 'https://schema.org/FinancialProduct',
  name: 'Cheshire Conveyancing Timeline Estimator',
  description: 'Estimates the conveyancing timeline for Cheshire property purchases based on property type, chain status, local authority area, and buyer type. Includes Cheshire-specific search timelines and cost estimates.',
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'Web browser',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'GBP' },
  areaServed: {
    '@type': 'AdministrativeArea',
    name: 'Cheshire',
    containedInPlace: { '@type': 'Country', name: 'England' },
  },
  audience: { '@type': 'Audience', audienceType: 'Home buyers purchasing property in Cheshire' },
  potentialAction: {
    '@type': 'UseAction',
    name: 'Estimate your Cheshire conveyancing timeline',
    target: 'https://movetocheshire.uk/buying-guide/conveyancing-cheshire#timeline-tool',
  },
  isPartOf: { '@type': 'WebPage', url: 'https://movetocheshire.uk/buying-guide/conveyancing-cheshire' },
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Conveyancing When Buying a Cheshire Property',
  description: 'The conveyancing process for Cheshire property purchases explained in six stages. Covers the mandatory salt search, local authority search timelines across Cheshire East, CWaC, and Warrington, solicitor costs at 10 price points, and how to choose a conveyancer with CQS accreditation.',
  datePublished: '2026-02-27',
  dateModified: '2026-02-27',
  author: { '@type': 'Organization', name: 'movetocheshire.uk' },
  publisher: { '@type': 'Organization', name: 'movetocheshire.uk', url: 'https://movetocheshire.uk' },
};
---

<BaseLayout
  title="Conveyancing in Cheshire | Costs, Timeline & Solicitor Guide"
  description="Cheshire conveyancing costs £750-£1,600 over 8-12 weeks. Covers the mandatory salt search (£79), LA search times (Cheshire East 21 days vs Warrington 5), 6-stage process, and CQS solicitor selection."
  ogImage="https://movetocheshire.uk/images/buying-guide/cheshire-conveyancing-timeline-composite.webp"

  publishDate="2026-02-01"
  updatedDate="2026-03-01"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webApplicationSchema)} />
  </Fragment>

  <!-- Breadcrumb -->
  <div class="section-pad" style="padding-top: 20px; padding-bottom: 0;">
    <div class="section-inner">
      <nav aria-label="Breadcrumb" style="font-family: Inter, Arial, sans-serif; font-size: 13px; color: #999999;">
        <a href="/" style="color: #999999; text-decoration: none;">Home</a>
        <span style="margin: 0 8px;">/</span>
        <a href="/buying-guide" style="color: #999999; text-decoration: none;">Buying Guide</a>
        <span style="margin: 0 8px;">/</span>
        <span style="color: #1C1C1E;">Conveyancing</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="section-pad" style="padding-top: 40px;">
    <div class="section-inner" style="max-width: 720px;">
      <span class="section-label">Legal process</span>
      <h1 style="font-family: Georgia, serif; font-size: clamp(28px, 4.5vw, 44px); font-weight: 700; color: #1C1C1E; line-height: 1.15; margin: 0 0 20px 0; letter-spacing: -0.02em;">Conveyancing When Buying a Cheshire Property</h1>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 18px; line-height: 1.7; color: #444444; margin: 0 0 24px 0;">
        Conveyancing in Cheshire follows a six-stage legal process from solicitor instruction to Land Registry registration, typically completing in 8-12 weeks (Law Society, 2025). Cheshire purchases carry additional requirements - the mandatory brine subsidence search, local authority search delays of up to 21 working days in Cheshire East, and conservation area restrictions in Chester - that extend timelines beyond the national average.
      </p>
      <span style="display: inline-block; font-family: Inter, Arial, sans-serif; font-size: 12px; font-weight: 600; color: #3D5A3E; background-color: rgba(61, 90, 62, 0.08); padding: 6px 12px; letter-spacing: 0.02em;">Last updated: February 2026</span>
      <nav aria-label="Page sections" style="display: flex; flex-wrap: wrap; gap: 8px; margin-top: 20px;">
        {[
          { label: 'Process', href: '#process' },
          { label: 'Cheshire difference', href: '#cheshire-difference' },
          { label: 'Timeline', href: '#timeline-tool' },
          { label: 'Costs', href: '#costs' },
          { label: 'Searches', href: '#searches' },
          { label: 'Choosing a solicitor', href: '#solicitor' },
          { label: 'FAQ', href: '#faq' },
        ].map((link) => (
          <a href={link.href} style="font-family: Inter, Arial, sans-serif; font-size: 13px; font-weight: 500; color: #3D5A3E; text-decoration: none; padding: 5px 12px; border: 1px solid rgba(61, 90, 62, 0.25); transition: border-color 0.2s, background-color 0.2s;">{link.label}</a>
        ))}
      </nav>
    </div>
  </section>

  <!-- Stat Bar -->
  <section class="section-pad" style="padding-top: 0;">
    <div class="section-inner">
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px;">
        {[
          { value: '8-12 weeks', label: 'Standard Cheshire conveyancing timeline', source: 'Law Society, 2025' },
          { value: '£750-£1,600', label: 'Cheshire conveyancing cost excluding SDLT', source: 'Compare My Move, 2025' },
          { value: '£79', label: 'Cheshire salt search (mandatory in brine districts)', source: 'Cheshire Brine Board' },
        ].map((stat) => (
          <div style="background-color: #FFFFFF; border: 1px solid #E5E0D8; padding: 28px 24px;">
            <p class="data-tile-value" style="margin: 0 0 8px 0;">{stat.value}</p>
            <p style="font-family: Inter, Arial, sans-serif; font-size: 14px; font-weight: 600; color: #1C1C1E; margin: 0 0 4px 0;">{stat.label}</p>
            <p style="font-family: Inter, Arial, sans-serif; font-size: 12px; color: #999999; margin: 0;">{stat.source}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Hero image - Tier 3 composite (photo + CSS baked) -->
  <section class="section-pad" style="padding-top: 0; padding-bottom: 0;">
    <div class="section-inner" style="max-width: 720px;">
      <figure style="margin: 0 auto 0;">
        <img src="/images/buying-guide/cheshire-conveyancing-timeline-composite.webp"
          alt="Cheshire conveyancing timeline showing six stages from solicitor instruction to Land Registry registration over 8-12 weeks, with salt search and conservation area callouts"
          loading="eager"
          style="width: 720px; max-width: 100%; aspect-ratio: 720/480; border: 1px solid #E5E0D8;" />
        <figcaption style="font-family: Inter, Arial, sans-serif; font-size: 12px; color: #999999; margin-top: 8px;">Total conveyancing cost excluding SDLT ranges from £750 to £1,600 depending on property price and transaction complexity (Compare My Move, 2025).</figcaption>
      </figure>
    </div>
  </section>

  <!-- TLDR -->
  <section class="section-pad">
    <div class="section-inner" style="max-width: 720px;">
      <span class="section-label">Cheshire conveyancing summary</span>
      <h2 style="font-family: Georgia, serif; font-size: clamp(22px, 3vw, 30px); font-weight: 700; color: #1C1C1E; line-height: 1.25; margin: 0 0 24px 0;">
        What does conveyancing involve when buying in Cheshire?
      </h2>
      <div style="display: flex; flex-direction: column; gap: 16px;">
        <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #1C1C1E; margin: 0;"><strong>Conveyancing is the legal transfer of property ownership from seller to buyer, conducted by a solicitor or licensed conveyancer who manages searches, contract review, fund transfers, and Land Registry registration.</strong></p>
        <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #1C1C1E; margin: 0;">The process applies to every residential property purchase in England and Wales - buyers cannot complete a purchase without instructing a conveyancer.</p>
        <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #1C1C1E; margin: 0;"><strong>Cheshire conveyancing costs £845-£1,600 for standard freehold purchases at prices from £185,000 in Crewe to £480,000 in Knutsford, rising to £2,580 on £1,000,000 Prestbury properties</strong> (Compare My Move, 2025). The Cheshire salt search adds £79 to the standard search pack - a requirement specific to the Brine Compensation District that covers the entire county.</p>
        <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0;">Cheshire East council processes local authority searches in 21 working days, Cheshire West and Chester in 20, and Warrington in 5. The council where the property sits determines whether Stage 2 (searches and contract pack) takes 2 weeks or 5 weeks - the single largest variable in the Cheshire conveyancing timeline.</p>
        <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0;">This guide covers 6 stages, costs at 10 Cheshire price points from £185,000 to £1,000,000, 6 property searches with Cheshire-specific timelines, and CQS solicitor selection criteria.</p>
      </div>
    </div>
  </section>

  <!-- Cheshire Difference -->
  <section id="cheshire-difference" class="section-pad" style="background-color: #FFFFFF; border-top: 1px solid #E5E0D8; border-bottom: 1px solid #E5E0D8;">
    <div class="section-inner" style="max-width: 720px;">
      <span class="section-label">Cheshire-specific requirements</span>
      <h2 style="font-family: Georgia, serif; font-size: clamp(22px, 3vw, 30px); font-weight: 700; color: #1C1C1E; line-height: 1.25; margin: 0 0 16px 0;">What makes Cheshire conveyancing different?</h2>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0 0 24px 0;">Cheshire conveyancing diverges from the national standard in four areas: a mandatory geological search, conservation area complications, local authority processing delays, and a concentration of leasehold city-centre stock.</p>

      <h3 style="font-family: Georgia, serif; font-size: 20px; font-weight: 700; color: #1C1C1E; margin: 24px 0 12px 0;">The mandatory Cheshire salt search</h3>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0 0 16px 0;">The Cheshire Brine Subsidence Compensation District search costs £79 and returns within 1 working day. The Law Society mandates this search for every property purchase within the District, which covers Cheshire East, Cheshire West and Chester, Warrington, and parts of Trafford (Brine Subsidence Compensation Act 1891, amended 1952). Historical brine extraction - pumping water into underground salt deposits to dissolve and extract the mineral - caused mine collapses and ground subsidence across the county.</p>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0;">The search reveals any subsidence claims, compensation payments, or commutation awards against the property. A commutation payment equals the property's market value and is offered when damage is too severe to repair economically. Northwich, Winsford, and Middlewich carry the highest subsidence risk due to concentrated historical extraction. The Winsford salt mine remains the largest and oldest active salt mine in the UK.</p>

      <h3 style="font-family: Georgia, serif; font-size: 20px; font-weight: 700; color: #1C1C1E; margin: 24px 0 12px 0;">Conservation areas and listed buildings in Chester</h3>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0;">Chester's city centre sits within an extensive Conservation Area containing approximately 1,200 listed buildings (Cheshire West and Chester Council). Conservation designation restricts permitted development rights - external alterations including window replacement, rendering, satellite dishes, and extensions require local authority consent.</p>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0;">Your conveyancer raises additional enquiries on conservation area status, Article 4 directions (which remove further permitted development rights), and any outstanding enforcement notices. These enquiries add 1-2 weeks to Stage 3 and increase legal fees by £100-£200 for the additional work.</p>

      <h3 style="font-family: Georgia, serif; font-size: 20px; font-weight: 700; color: #1C1C1E; margin: 24px 0 12px 0;">Local authority search timelines across Cheshire</h3>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0 0 16px 0;">Local authority search processing times vary by a factor of four across Cheshire's three councils. The local authority search (LLC1 and CON29) is the slowest element in the standard search pack and the primary bottleneck in Stage 2.</p>
      <div style="overflow-x: auto; margin-bottom: 16px;">
        <table style="width: 100%; border-collapse: collapse; font-family: Inter, Arial, sans-serif; font-size: 14px; min-width: 480px;">
          <thead>
            <tr style="border-bottom: 2px solid #3D5A3E;">
              <th style="text-align: left; padding: 12px 16px; font-weight: 700; color: #1C1C1E;">Local authority</th>
              <th style="text-align: left; padding: 12px 16px; font-weight: 700; color: #1C1C1E;">Areas covered</th>
              <th style="text-align: right; padding: 12px 16px; font-weight: 700; color: #1C1C1E;">Working days</th>
            </tr>
          </thead>
          <tbody>
            {laSearchTimelines.map((row, i) => (
              <tr style={`background-color: ${i % 2 === 0 ? '#FFFFFF' : '#F9F7F4'}; border-bottom: 1px solid #E5E0D8;`}>
                <td style="padding: 14px 16px; font-weight: 600; color: #1C1C1E;">{row.authority}</td>
                <td style="padding: 14px 16px; color: #444444;">{row.areas}</td>
                <td style="padding: 14px 16px; color: #C4933F; font-weight: 700; text-align: right;">{row.days}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 12px; color: #999999; margin: 0;">Source: Local authority published turnaround times, February 2026. Times vary by workload and peak periods.</p>
      <figure style="margin: 20px auto 0; max-width: 720px;">
        <img src="/images/buying-guide/cheshire-la-search-timeline-comparison.webp" alt="Horizontal bar chart comparing local authority search processing times across three Cheshire councils - Warrington at 5 working days, Cheshire West and Chester at 20 days, and Cheshire East at 21 days" loading="lazy" style="width: 720px; max-width: 100%; aspect-ratio: 720/330; border: 1px solid #E5E0D8;" />
        <figcaption style="font-family: Inter, Arial, sans-serif; font-size: 12px; color: #999999; margin-top: 8px;">Warrington processes searches 4x faster than Cheshire East - a key factor when choosing between Cheshire locations under time pressure.</figcaption>
      </figure>

      <h3 style="font-family: Georgia, serif; font-size: 20px; font-weight: 700; color: #1C1C1E; margin: 24px 0 12px 0;">Leasehold flats in Chester city centre</h3>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0;">Chester city centre flats and Northwich apartment developments constitute the majority of leasehold purchases in Cheshire. Leasehold conveyancing requires additional enquiries to the freeholder or managing agent covering the management pack (£200-£400), notice of transfer (£100-£200), and deed of covenant (£50-£150).</p>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0;">These freeholder-imposed charges add £350-£750 to the disbursement bill and extend the timeline by 2-4 weeks because the freeholder's response is outside your solicitor's control.</p>
    </div>
  </section>

  <!-- Timeline Estimator Tool -->
  <section id="timeline-tool" class="section-pad" style="background-color: #FFFFFF; border-top: 1px solid #E5E0D8; border-bottom: 1px solid #E5E0D8;">
    <div class="section-inner" style="max-width: 720px;">
      <span class="section-label">Conveyancing timeline estimator</span>
      <h2 style="font-family: Georgia, serif; font-size: clamp(22px, 3vw, 30px); font-weight: 700; color: #1C1C1E; line-height: 1.25; margin: 0 0 16px 0;">How long does conveyancing take in Cheshire?</h2>
      <p style="font-family: Inter, Arial, sans-serif; font-size: 16px; line-height: 1.75; color: #444444; margin: 0 0 24px 0;">Cheshire conveyancing timelines range from 5 weeks for a chain-free cash purchase in Warrington to 20+ weeks for a leasehold chain transaction in Cheshire East. Select your purchase details to estimate the timeline for your specific situation.</p>

      <div style="display: flex; flex-direction: column; gap: 20px; margin-bottom: 24px;">
        <div>
          <label for="conv-property-type" style="font-family: Inter, Arial, sans-serif; font-size: 13px; font-weight: 600; color: #1C1C1E; display: block; margin-bottom: 6px;">Cheshire property type</label>
          <select id="conv-property-type" style="font-family: Inter, Arial, sans-serif; font-size: 16px; color: #1C1C1E; border: 1px solid #E5E0D8; padding: 10px 14px; background: #FFFFFF; max-width: 320px; width: 100%;">
