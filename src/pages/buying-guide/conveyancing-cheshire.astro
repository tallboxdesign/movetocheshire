          <label for="conv-chain" style="font-family: Inter, Arial, sans-serif; font-size: 13px; font-weight: 600; color: #1C1C1E; display: block; margin-bottom: 6px;">Chain status</label>
          <select id="conv-chain" style="font-family: Inter, Arial, sans-serif; font-size: 16px; color: #1C1C1E; border: 1px solid #E5E0D8; padding: 10px 14px; background: #FFFFFF; max-width: 320px; width: 100%;">
            <option value="chain-free">Chain-free</option>
            <option value="chain">In a chain</option>
            <option value="new-build">New build</option>
          </select>
        </div>
        <div>
          <label for="conv-location" style="font-family: Inter, Arial, sans-serif; font-size: 13px; font-weight: 600; color: #1C1C1E; display: block; margin-bottom: 6px;">Cheshire local authority area</label>
          <select id="conv-location" style="font-family: Inter, Arial, sans-serif; font-size: 16px; color: #1C1C1E; border: 1px solid #E5E0D8; padding: 10px 14px; background: #FFFFFF; max-width: 320px; width: 100%;">
            <option value="cheshire-east">Cheshire East</option>
            <option value="cwac">Cheshire West and Chester</option>
            <option value="warrington">Warrington</option>
            <option value="other">Other</option>
          </select>
        </div>
        <div>
          <label for="conv-buyer" style="font-family: Inter, Arial, sans-serif; font-size: 13px; font-weight: 600; color: #1C1C1E; display: block; margin-bottom: 6px;">Buyer type</label>
          <select id="conv-buyer" style="font-family: Inter, Arial, sans-serif; font-size: 16px; color: #1C1C1E; border: 1px solid #E5E0D8; padding: 10px 14px; background: #FFFFFF; max-width: 320px; width: 100%;">
            <option value="ftb">First-time buyer</option>
