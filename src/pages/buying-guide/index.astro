---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HubLayout from '../../components/HubLayout.astro';

const spokes = [
  { label: 'Stamp Duty in Cheshire', href: '/buying-guide/stamp-duty-cheshire', description: "Stamp Duty Land Tax calculations for typical Cheshire purchase prices. Includes first-time buyer relief and second home surcharge scenarios." },
  { label: 'Survey Types Explained', href: '/buying-guide/survey-types-cheshire', description: "RICS Level 1, 2, and 3 surveys - which type is appropriate for Cheshire's housing stock, and what typical survey costs look like locally." },
  { label: 'Conveyancing in Cheshire', href: '/buying-guide/conveyancing-cheshire', description: 'What to expect from the conveyancing process in a competitive Cheshire market, with realistic timelines and notes on local solicitors.' },
  { label: 'Making an Offer in Cheshire', href: '/buying-guide/making-offer-cheshire', description: "How Cheshire's property market works: sealed bids, asking price competition, and when offers below asking are realistic." },
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://movetocheshire.uk' },
    { '@type': 'ListItem', position: 2, name: 'Buying a Home in Cheshire', item: 'https://movetocheshire.uk/buying-guide' },
  ],
};

const collectionPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Buying a Home in Cheshire',
  description: 'A practical guide to buying property in Cheshire: stamp duty, survey types, conveyancing, and what to expect from the purchase process.',
  url: 'https://movetocheshire.uk/buying-guide',
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Stamp Duty in Cheshire', url: 'https://movetocheshire.uk/buying-guide/stamp-duty-cheshire' },
      { '@type': 'ListItem', position: 2, name: 'Survey Types Explained', url: 'https://movetocheshire.uk/buying-guide/survey-types-cheshire' },
      { '@type': 'ListItem', position: 3, name: 'Conveyancing in Cheshire', url: 'https://movetocheshire.uk/buying-guide/conveyancing-cheshire' },
      { '@type': 'ListItem', position: 4, name: 'Making an Offer in Cheshire', url: 'https://movetocheshire.uk/buying-guide/making-offer-cheshire' },
    ],
  },
};

const relatedHubs = [
  { label: 'House Prices', href: '/house-prices' },
  { label: 'Investment', href: '/investment' },
];
---

<BaseLayout
  title="Buying a Home in Cheshire | Process Guide | movetocheshire.uk"
  description="A practical guide to buying property in Cheshire: stamp duty, survey types, conveyancing, and what to expect from the purchase process. Cheshire-specific timelines and considerations."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(collectionPageSchema)} />
  </Fragment>
  <HubLayout
    tag="Process Guide"
    title="Buying a Home in Cheshire"
    description="A practical guide to the full purchase process: stamp duty, survey types, local solicitors, and what to expect from conveyancing in a competitive market. Includes Cheshire-specific timelines and considerations."
    spokes={spokes}
    relatedHubs={relatedHubs}
  />
</BaseLayout>
